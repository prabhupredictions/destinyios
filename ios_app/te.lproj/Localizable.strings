"yoga_formation_bhratrumoola_dhanaprapti_yoga_137" = "3వ ప్రభువు 2వ మరియు 11వ గృహాలకు (వర్. 2) అనుసంధానించబడ్డాడు.";

// [−] Bhratrusapa Sutakshaya Yoga
