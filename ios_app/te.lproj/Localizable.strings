"yoga_formation_kalanirdesat_putranasa_yoga_229" = "5వ ప్రభువు నిర్దిష్ట దుర్మార్గపు దశ (వర్ణం 1) సమయంలో బాధపడ్డాడు.";

// [−] Kalanirdesat Putranasa Yoga (230)
"yoga_name_kalanirdesat_putranasa_yoga_230" = "కలనిర్దేశాత్ పుత్రనాశ యోగ (230)";
