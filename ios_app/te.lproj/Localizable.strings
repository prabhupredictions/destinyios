// [+] Garuda Yoga
"yoga_name_garuda_yoga" = "గరుడ యోగము";
"yoga_outcome_garuda_yoga" = "డేగ వంటి దృష్టి; ప్రత్యర్థులను నాశనం చేస్తుంది మరియు పోటీ కంటే పైకి లేస్తుంది.";
