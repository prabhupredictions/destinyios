"yoga_name_matrudeerghayur_yoga_196" = "మాతృదీర్ఘాయుర్ యోగా (196)";
"yoga_outcome_matrudeerghayur_yoga_196" = "తల్లికి దీర్ఘాయువు; వ్యక్తి విస్తారమైన తల్లి ఉనికిని మరియు మద్దతును పొందుతాడు.";
"yoga_formation_matrudeerghayur_yoga_196" = "4వ అధిపతి ప్రయోజనకరమైన అంశాలతో బలంగా ఉన్నాడు, చంద్రుడు మంచి స్థానంలో ఉన్నాడు (వర్. 1).";

// [+] Matrudeerghayur Yoga (197)
"yoga_name_matrudeerghayur_yoga_197" = "మాతృదీర్ఘాయుర్ యోగా (197)";
"yoga_outcome_matrudeerghayur_yoga_197" = "ప్రసూతి దీర్ఘాయువు మరియు కుటుంబ వాతావరణం పెంపొందించడం నిర్ధారించబడింది.";
"yoga_formation_matrudeerghayur_yoga_197" = "వీనస్ మరియు మూన్ సపోర్టివ్, 4వ హౌస్ రక్షిత (వర్. 2).";

// [−] Matrugami Yoga
"yoga_name_matrugami_yoga" = "మాతృగామి యోగం";
"yoga_outcome_matrugami_yoga" = "తల్లి సంబంధాలలో అనారోగ్యకరమైన లేదా తగని అటాచ్‌మెంట్ నమూనాలు.";
"yoga_formation_matrugami_yoga" = "నిర్దిష్ట నిషిద్ధ కలయికలలో శుక్రుడు మరియు 4వ అధిపతి.";

// [+] Matrumooladhana Yoga
"yoga_name_matrumooladhana_yoga" = "మాతృమూలధన యోగం";
"yoga_outcome_matrumooladhana_yoga" = "తల్లి వారసత్వం, రియల్ ఎస్టేట్ లేదా మాతృభూమి కనెక్షన్ల ద్వారా సంపద.";
"yoga_formation_matrumooladhana_yoga" = "4వ ప్రభువు 2వ మరియు 11వ స్థానాలకు ప్రయోజనకరమైన మద్దతుతో అనుసంధానించబడ్డాడు.";

// [−] Matrunasa Yoga (198)
"yoga_name_matrunasa_yoga_198" = "మాతృనాస యోగా (198)";
"yoga_outcome_matrunasa_yoga_198" = "తల్లిని త్వరగా కోల్పోవడం లేదా తీవ్రమైన తల్లి ఆరోగ్య సంక్షోభం.";
"yoga_formation_matrunasa_yoga_198" = "4వ అధిపతి మరియు చంద్రుడు దుష్ప్రవర్తనతో తీవ్రంగా బాధపడుతున్నారు (వర్. 1).";

// [−] Matrunasa Yoga (199)
"yoga_name_matrunasa_yoga_199" = "మాతృనాస యోగా (199)";
"yoga_outcome_matrunasa_yoga_199" = "తల్లి ప్రాణాంతక పరిస్థితులను ఎదుర్కొంటుంది; ప్రమాదంలో మాతృ సంక్షేమం.";
"yoga_formation_matrunasa_yoga_199" = "కుజుడు మరియు శని 4వ ఇంటిని మరియు చంద్రుని (వర్. 2) బాధపెట్టడం.";

// [−] Matrusapa Sutakshaya Yoga
"yoga_name_matrusapa_sutakshaya_yoga" = "మాతృసాప సుతక్షయ యోగం";
"yoga_outcome_matrusapa_sutakshaya_yoga" = "సంతానాన్ని ప్రభావితం చేసే తల్లి శాపం; పరిష్కరించని మాతృ కర్మ పిల్లలపై ప్రభావం చూపుతుంది.";
"yoga_formation_matrusapa_sutakshaya_yoga" = "చంద్రుడు అశుభ కలయికలలో 5వ అధిపతితో బాధపడ్డాడు.";

// [+] Matsya Yoga
"yoga_name_matsya_yoga" = "మత్స్య యోగము";
"yoga_outcome_matsya_yoga" = "లోతైన, సముద్రం లాంటి జ్ఞానం మరియు ఆధ్యాత్మిక జ్ఞానం; నేర్చుకున్న, దయగల, విస్తృతంగా ప్రయాణించారు.";
"yoga_formation_matsya_yoga" = "లగ్నము/9వ స్థానములో దోషములు, 5వ స్థానములో శుభములు, 4/8వ స్థానములో మిశ్రమం.";

// [−] Mooka Yoga
"yoga_name_mooka_yoga" = "మూక యోగా";
"yoga_outcome_mooka_yoga" = "స్పీచ్ అవరోధాలు లేదా కమ్యూనికేషన్ ఇబ్బందులు; చికిత్స మరియు నివారణలు సహాయపడవచ్చు.";
"yoga_formation_mooka_yoga" = "బుధుడు తీవ్రంగా బాధపడ్డాడు, 2వ అధిపతి అశుభాలతో బలహీనపడ్డాడు.";

// [+] Mridanga Yoga
"yoga_name_mridanga_yoga" = "మృదంగ యోగము";
"yoga_outcome_mridanga_yoga" = "ఉత్సవ డ్రమ్ వంటి సుప్రీం రాజ హోదా; కీర్తి భూమి అంతటా మారుమోగుతుంది.";
"yoga_formation_mridanga_yoga" = "లగ్నాధిపతి బలవంతుడు, అన్ని గ్రహాలు కేంద్రాలు/త్రికోణాలలో ఉంటాయి.";

// [+] Ardha Chandra Yoga
"yoga_name_nabhasa_ardha_chandra" = "అర్ధ చంద్ర యోగం";
"yoga_outcome_nabhasa_ardha_chandra" = "హాఫ్ మూన్ ఏర్పడటం; ఆర్మీ కమాండర్, శారీరకంగా బలమైన, ఆకర్షణీయమైన మరియు ధనవంతుడు.";
"yoga_formation_nabhasa_ardha_chandra" = "ఒక కేంద్రం నుండి వరుసగా ఏడు ఇళ్లలో అన్ని గ్రహాలు.";

// [+] Chandra Yoga (Nabhasa)
"yoga_name_nabhasa_chandra" = "చంద్ర యోగం (నభస)";
"yoga_outcome_nabhasa_chandra" = "చంద్ర నిర్మాణం; ఆహ్లాదకరమైన రూపం, కమాండింగ్ స్థాయి, రాజ సలహాదారులు.";
"yoga_formation_nabhasa_chandra" = "రాశిచక్రం ఎగువ భాగంలో ఉన్న అన్ని గ్రహాలు (7వ-12వ ఇళ్ళు).";

// [+] Chapa Yoga (Nabhasa)
"yoga_name_nabhasa_chapa" = "చాప యోగ (నభస)";
"yoga_outcome_nabhasa_chapa" = "విల్లు నిర్మాణం; నిజాయతీ, గార్డ్స్ నిధి, ప్రారంభ మరియు చివరి జీవితంలో ఆనందం.";
"yoga_formation_nabhasa_chapa" = "10-4 గృహాలలోని అన్ని గ్రహాలు (10 నుండి 4 వ వ్యవధి).";

// [+] Chhatra Yoga
"yoga_name_nabhasa_chhatra" = "ఛత్ర యోగా";
"yoga_outcome_nabhasa_chhatra" = "గొడుగు నిర్మాణం; ఇతరుల రక్షకుడు, అందరికీ సహాయకారిగా, సౌకర్యవంతమైన వృద్ధాప్యం.";
"yoga_formation_nabhasa_chhatra" = "7-1 ఇళ్లలోని అన్ని గ్రహాలు (7వ నుండి 1వ వ్యవధి వరకు).";

// [+] Damini Yoga
"yoga_name_nabhasa_damini" = "దామిని యోగం";
"yoga_outcome_nabhasa_damini" = "మెరుపు నిర్మాణం; ఉదార, సహాయ, సంపన్న, మరియు దాతృత్వ స్వభావం.";
"yoga_formation_nabhasa_damini" = "ఆరు వరుస గృహాలలో అన్ని గ్రహాలు.";

// [+] Danda Yoga
"yoga_name_nabhasa_danda" = "దండ యోగా";
"yoga_outcome_nabhasa_danda" = "సిబ్బంది ఏర్పాటు; కుటుంబం లేదా ఒంటరితనం కోల్పోవడం; సేవా ఆధారిత జీవితం.";
"yoga_formation_nabhasa_danda" = "10వ తేదీ నుండి వరుసగా నాలుగు గృహాలలో గ్రహాలు.";

// [+] Gada Yoga
"yoga_name_nabhasa_gada" = "గదా యోగము";
"yoga_outcome_nabhasa_gada" = "జాపత్రి లాంటి బలం; ఆచారాలు, మతపరమైన కార్యకలాపాలు లేదా సాంప్రదాయిక కార్యకలాపాల ద్వారా సంపద.";
"yoga_formation_nabhasa_gada" = "రెండు వరుస కేంద్ర గృహాలలో గ్రహాలు.";

// [+] Gola Yoga (Nabhasa)
"yoga_name_nabhasa_gola" = "గోల యోగ (నభస)";
"yoga_outcome_nabhasa_gola" = "గోళాల నిర్మాణం; పేద, మురికి, అజ్ఞానం, కానీ బలమైన మరియు సంచరించే స్వభావం.";
"yoga_formation_nabhasa_gola" = "అన్ని గ్రహాలు ఒకే ఇంట్లో.";

// [+] Hala Yoga
"yoga_name_nabhasa_hala" = "హల యోగా";
"yoga_outcome_nabhasa_hala" = "వ్యవసాయ శ్రేయస్సు; మధ్యతరగతి సౌకర్యాలతో కష్టపడి పనిచేసే స్వభావం.";
"yoga_formation_nabhasa_hala" = "కేంద్రాలు కాకుండా ఇతర ఇళ్లలోని గ్రహాలు నాగలి ఆకారాన్ని ఏర్పరుస్తాయి.";

// [+] Ishu Yoga
"yoga_name_nabhasa_ishu" = "ఇషు యోగం";
"yoga_outcome_nabhasa_ishu" = "బాణం నిర్మాణం; మిలిటరీ, పోలీసు లేదా జైలు పరిపాలనకు కనెక్ట్ చేయబడింది.";
"yoga_formation_nabhasa_ishu" = "4వ తేదీ నుంచి వరుసగా నాలుగు ఇళ్లలో గ్రహాలు.";

// [+] Kamala Yoga
"yoga_name_nabhasa_kamala" = "కమల యోగం";
"yoga_outcome_nabhasa_kamala" = "లోటస్ నిర్మాణం; శాశ్వతమైన కీర్తి, ధర్మబద్ధమైన జీవితం మరియు వంద సంవత్సరాల శ్రేయస్సు.";
"yoga_formation_nabhasa_kamala" = "నాలుగు కేంద్ర గృహాలలోని అన్ని గ్రహాలు (1/4/7/10).";

// [+] Kedara Yoga
"yoga_name_nabhasa_kedara" = "కేదార యోగము";
"yoga_outcome_nabhasa_kedara" = "ఫీల్డ్ నిర్మాణం; వ్యవసాయ సంపద, అనేకమందికి సహాయకారిగా, సత్యవంతులు.";
"yoga_formation_nabhasa_kedara" = "ఐదు వరుస ఇళ్లలో అన్ని గ్రహాలు.";

// [+] Kuta Yoga
"yoga_name_nabhasa_kuta" = "కుట యోగా";
"yoga_outcome_nabhasa_kuta" = "కోట నిర్మాణం; అబద్ధాలకోరు లేదా దౌత్యవేత్త, జైళ్లు లేదా నిర్బంధ పాత్రలతో అనుసంధానించబడినవారు.";
"yoga_formation_nabhasa_kuta" = "4-10 ఇళ్లలోని అన్ని గ్రహాలు.";

// [+] Mala Yoga
"yoga_name_nabhasa_mala" = "మాల యోగా";
"yoga_outcome_nabhasa_mala" = "గార్లాండ్ నిర్మాణం; వాహనాలు, ఆస్తులు మరియు శాశ్వతమైన ఆనందంతో సౌకర్యవంతమైన జీవితం.";
"yoga_formation_nabhasa_mala" = "మూడు వరుస త్రికోణాలలో గ్రహాలు (1-5-9, 2-6-10, లేదా 3-7-11).";

// [+] Musala Yoga
"yoga_name_nabhasa_musala" = "ముసల యోగం";
"yoga_outcome_nabhasa_musala" = "దృఢ సంకల్పం, కీర్తి మరియు సంపద; స్థిరమైన, నిశ్చయమైన పాత్ర.";
"yoga_formation_nabhasa_musala" = "స్థిర సంకేతాలలో అన్ని గ్రహాలు (వృషభం, సింహం, వృశ్చికం, కుంభం).";

// [+] Nala Yoga
"yoga_name_nabhasa_nala" = "నల యోగా";
"yoga_outcome_nabhasa_nala" = "బహుముఖ, అనేక రంగాలలో నైపుణ్యం; హెచ్చుతగ్గుల అదృష్టంతో అందమైన ప్రదర్శన.";
"yoga_formation_nabhasa_nala" = "ద్వంద్వ రాశులలో అన్ని గ్రహాలు (జెమిని, కన్య, ధనుస్సు, మీనం).";

// [+] Nauka Yoga
"yoga_name_nabhasa_nauka" = "నౌకా యోగం";
"yoga_outcome_nabhasa_nauka" = "పడవ నిర్మాణం; నీటికి సంబంధించిన పనుల ద్వారా సంపద, సముద్రాలపై కీర్తి.";
"yoga_formation_nabhasa_nauka" = "1-7 ఇళ్లలోని అన్ని గ్రహాలు (రాశిచక్రం యొక్క సగం).";

// [−] Pasa Yoga
"yoga_name_nabhasa_pasa" = "పాస యోగా";
"yoga_outcome_nabhasa_pasa" = "నూస్ నిర్మాణం; కష్టాల్లో చిక్కుకోవడం, ఖైదు చేయబడిన లేదా సేవకుడి లాంటి ఉనికి.";
"yoga_formation_nabhasa_pasa" = "గ్రహాలు నిర్దిష్ట బౌండ్ నమూనాలలో మాత్రమే.";

// [+] Rajju Yoga
"yoga_name_nabhasa_rajju" = "రజ్జు యోగా";
"yoga_outcome_nabhasa_rajju" = "ప్రయాణం ప్రేమ, సంచరించే స్వభావం; చలనశీలత మరియు అనుకూలత ద్వారా విజయం.";
"yoga_formation_nabhasa_rajju" = "కదిలే సంకేతాలలో అన్ని గ్రహాలు (మేషం, కర్కాటకం, తుల, మకరం).";

// [+] Samudra Yoga
"yoga_name_nabhasa_samudra" = "సముద్ర యోగము";
"yoga_outcome_nabhasa_samudra" = "మహాసముద్ర నిర్మాణం; ధనవంతుడు, అనేక భోగాలు, ఆనందంలో రాజుతో సమానం.";
"yoga_formation_nabhasa_samudra" = "అన్ని కేంద్ర సమూహాలలో గ్రహాలు సమానంగా పంపిణీ చేయబడ్డాయి.";

// [−] Sarpa Yoga
"yoga_name_nabhasa_sarpa" = "సర్ప యోగం";
"yoga_outcome_nabhasa_sarpa" = "కష్టాలు, పేదరికం మరియు పాములాంటి బాధ; జీవనోపాధి కోసం ఇతరులపై ఆధారపడుతున్నారు.";
"yoga_formation_nabhasa_sarpa" = "కార్డినల్ హౌస్‌లలోని అన్ని గ్రహాలు (లగ్నం నుండి 4వ/8వ/12వ స్థానం).";

// [−] Shakata Yoga
"yoga_name_nabhasa_shakata" = "శకట యోగము";
"yoga_outcome_nabhasa_shakata" = "బండిలాంటి జీవితం — హెచ్చు తగ్గులు; సంపద తరువాత చక్రాలలో పేదరికం.";
"yoga_formation_nabhasa_shakata" = "1వ మరియు 7వ గృహాలలో మాత్రమే గ్రహాలు.";

// [+] Shakti Yoga
"yoga_name_nabhasa_shakti" = "శక్తి యోగము";
"yoga_outcome_nabhasa_shakti" = "స్పియర్ నిర్మాణం; సోమరితనం కానీ పట్టుదల ద్వారా సంపదను పొందుతారు.";
"yoga_formation_nabhasa_shakti" = "7వ తేదీ నుంచి వరుసగా నాలుగు ఇళ్లలో గ్రహాలు.";

// [+] Shringataka Yoga
"yoga_name_nabhasa_shringataka" = "శృంగాటక యోగం";
"yoga_outcome_nabhasa_shringataka" = "పీక్ నిర్మాణం; సంతృప్తి, దాతృత్వం మరియు స్నేహపూర్వక స్వభావం.";
"yoga_formation_nabhasa_shringataka" = "త్రికోణ గృహాలలో (1వ, 5వ, 9వ) గ్రహాలు.";

// [−] Shula Yoga
"yoga_name_nabhasa_shula" = "శూల యోగం";
"yoga_outcome_nabhasa_shula" = "త్రిశూల నిర్మాణం; పదునైన, పరాక్రమమైన, కానీ పేద; అనారోగ్యం-పీడిత మరియు ఘర్షణ.";
"yoga_formation_nabhasa_shula" = "మూడు వరుస ఇళ్లలో గ్రహాలు.";

// [+] Vajra Yoga
"yoga_name_nabhasa_vajra" = "వజ్ర యోగము";
"yoga_outcome_nabhasa_vajra" = "డైమండ్ వంటి ప్రకాశం; అందమైన, యవ్వనం మరియు వృద్ధాప్యంలో సంతోషంగా, యుద్ధ శౌర్యం.";
"yoga_formation_nabhasa_vajra" = "1వ/7వ స్థానంలో బెనిఫిక్స్, 4వ/10వ స్థానంలో దుర్వినియోగం.";

// [+] Vapi Yoga
"yoga_name_nabhasa_vapi" = "వాపి యోగం";
"yoga_outcome_nabhasa_vapi" = "బావి నిర్మాణం; సంపద సంచితం, నిల్వ చేసే ధోరణి, శాశ్వత అదృష్టం.";
"yoga_formation_nabhasa_vapi" = "కేంద్రేతర గృహాలలోని అన్ని గ్రహాలు (పనపర/అపోక్లిమ).";

// [+] Veena Yoga
"yoga_name_nabhasa_veena" = "వినా యోగం";
"yoga_outcome_nabhasa_veena" = "వీణ నిర్మాణం; సంగీతం, నృత్యం మరియు కళల ప్రేమికుడు; నైపుణ్యం మరియు సంతోషకరమైన స్వభావం.";
"yoga_formation_nabhasa_veena" = "ఏడు వరుస ఇళ్లలో మొత్తం ఏడు గ్రహాలు.";

// [+] Vihaga Yoga
"yoga_name_nabhasa_vihaga" = "విహాగ యోగం";
"yoga_outcome_nabhasa_vihaga" = "పక్షి లాంటి స్వేచ్ఛ; రాయబారి స్వభావం, సంచారం మరియు సందేశాన్ని మోసే పాత్రలు.";
"yoga_formation_nabhasa_vihaga" = "4వ మరియు 10వ గృహాలలో మాత్రమే గ్రహాలు.";

// [+] Yava Yoga
"yoga_name_nabhasa_yava" = "యవ యోగా";
"yoga_outcome_nabhasa_yava" = "బార్లీ-ధాన్యం నమూనా; దాన స్వభావం, మధ్య వయస్సులో ఆనందం.";
"yoga_formation_nabhasa_yava" = "4వ/10వ స్థానంలో బెనిఫిక్స్, 1వ/7వ స్థానంలో దుర్వినియోగం.";

// [+] Yuga Yoga
"yoga_name_nabhasa_yuga" = "యుగ యోగము";
"yoga_outcome_nabhasa_yuga" = "యోక్ నిర్మాణం; మతవిశ్వాశాల, పేద, బహిష్కృత ధోరణులు; అసాధారణ మార్గం.";
"yoga_formation_nabhasa_yuga" = "రెండు వరుస గృహాలలో అన్ని గ్రహాలు.";

// [+] Yupa Yoga
"yoga_name_nabhasa_yupa" = "యుప యోగా";
"yoga_outcome_nabhasa_yupa" = "త్యాగం చేసే పోస్ట్; ఉదారమైన, నేర్చుకున్న, మతపరమైన మరియు దృష్టి కేంద్రీకరించిన స్వభావం.";
"yoga_formation_nabhasa_yupa" = "లగ్నము నుండి మొదలుకొని వరుసగా నాలుగు గృహాలలో గ్రహములు.";

// [−] Netranasa Yoga
"yoga_name_netranasa_yoga" = "నేత్రనాస యోగం";
"yoga_outcome_netranasa_yoga" = "కంటి సమస్యలు లేదా దృష్టి లోపానికి గురికావడం; సాధారణ కంటి సంరక్షణ అవసరం.";
"yoga_formation_netranasa_yoga" = "2వ/12వ రాశివారు దుష్ప్రవర్తనతో బాధపడుతున్నారు, సూర్యుడు/చంద్రుడు బలహీనంగా ఉన్నారు.";

// [+] Nishkapata Yoga (205)
"yoga_name_nishkapata_yoga_205" = "నిష్కపట యోగా (205)";
"yoga_outcome_nishkapata_yoga_205" = "పారదర్శక, మోసపూరిత స్వభావాన్ని మంజూరు చేస్తుంది; సహజంగా నిజాయితీ మరియు చిత్తశుద్ధి ద్వారా గౌరవం పొందుతారు.";
"yoga_formation_nishkapata_yoga_205" = "చిత్తశుద్ధిని సూచించే ప్రయోజనకరమైన గ్రహ కలయికలు (var. 1).";

// [+] Nishkapata Yoga (206)
"yoga_name_nishkapata_yoga_206" = "నిష్కపట యోగా (206)";
"yoga_outcome_nishkapata_yoga_206" = "సూటిగా ఉండే పాత్ర మరియు నైతిక స్వచ్ఛతను అందిస్తుంది; నిజాయితీతో కూడిన వ్యవహారాల ద్వారా అభివృద్ధి చెందుతుంది.";
"yoga_formation_nishkapata_yoga_206" = "చిత్తశుద్ధిని సూచించే ప్రయోజనకరమైన గ్రహ కలయికలు (వర్. 2).";

// [−] Nishturabhashi Yoga
"yoga_name_nishturabhashi_yoga" = "నిష్టురభాషి యోగం";
"yoga_outcome_nishturabhashi_yoga" = "కఠినమైన ప్రసంగం వైపు ధోరణిని సూచిస్తుంది; బుద్ధిపూర్వకమైన కమ్యూనికేషన్ సూచించబడింది.";
"yoga_formation_nishturabhashi_yoga" = "మాలిఫిక్స్ మెర్క్యురీ మరియు 2వ ఇంటిని ప్రభావితం చేస్తాయి.";

// [+] Obhayachari Yoga
"yoga_name_obhayachari_yoga" = "ఓభయాచారి యోగా";
"yoga_outcome_obhayachari_yoga" = "వాక్చాతుర్యాన్ని, అందమైన రూపాన్ని, రాజరికపు బేరింగ్ మరియు జీవితంలో ప్రత్యేకతను ప్రసాదిస్తుంది.";
"yoga_formation_obhayachari_yoga" = "గ్రహాలు (చంద్రుడు/రాహువు/కేతు మినహా) సూర్యుడి నుండి 2వ మరియు 12వ స్థానంలో ఉన్నాయి.";

// [+] Parakrama Yoga
"yoga_name_parakrama_yoga" = "పరాక్రమ యోగము";
"yoga_outcome_parakrama_yoga" = "ధైర్యసాహసాలు అవసరమయ్యే పనిలో అసాధారణమైన ధైర్యం, శారీరక బలం మరియు సాహసోపేత స్ఫూర్తిని అందిస్తుంది.";
"yoga_formation_parakrama_yoga" = "ప్రయోజనకరమైన ప్రభావాలతో ప్రయోజనకరమైన నవాంశలో 3వ అధిపతి; అనుకూలమైన గౌరవంలో కుజుడు.";

// [−] Parannabhojana Yoga
"yoga_name_parannabhojana_yoga" = "పరాన్నభోజన యోగం";
"yoga_outcome_parannabhojana_yoga" = "ఆహారం కోసం ఇతరులపై ఆధారపడుతుంది; ఆర్థిక పరిమితులు దాతృత్వం లేదా పోషణపై ఆధారపడేలా చేస్తాయి.";
"yoga_formation_parannabhojana_yoga" = "2వ అధిపతి బలహీనుడు, 6వ అధిపతి ఆహార గృహాలను ప్రభావితం చేస్తాడు.";

// [+] Parihasaka Yoga
"yoga_name_parihasaka_yoga" = "పరిహాసక యోగము";
"yoga_outcome_parihasaka_yoga" = "సహజమైన తెలివి, హాస్యం మరియు వినోదాత్మక వ్యక్తిత్వం; సాంఘిక సమావేశాలకు ఆనందాన్ని కలిగిస్తుంది.";
"yoga_formation_parihasaka_yoga" = "నిర్దిష్ట గృహాలలోని ప్రయోజనాలు హాస్య స్వభావాన్ని సృష్టిస్తాయి.";

// [+] Parijatha Yoga
"yoga_name_parijatha_yoga" = "పారిజాత యోగా";
"yoga_outcome_parijatha_yoga" = "యోగ్యత మరియు పట్టుదల ద్వారా క్రమంగా కానీ ఆపలేని అధికారం.";
"yoga_formation_parijatha_yoga" = "లగ్నాధిపతి యొక్క డిస్పోజిటర్ గొలుసు కేంద్రం/త్రికోణంలో సొంత/ఉన్నతమైన గ్రహానికి దారి తీస్తుంది.";

// [+] Parvata Yoga
"yoga_name_parvata_yoga" = "పర్వత యోగా";
"yoga_outcome_parvata_yoga" = "పర్వతం లాంటి కెరీర్ స్థిరత్వం, సంపద, కీర్తి మరియు దాతృత్వం.";
"yoga_formation_parvata_yoga" = "కేంద్రాలలో ప్రయోజనాలు; 6వ మరియు 8వ గృహాలు ఖాళీ/బాధపడనివి.";

// [−] Peenasaroga Yoga
"yoga_name_peenasaroga_yoga" = "పినసరోగ యోగం";
"yoga_outcome_peenasaroga_yoga" = "దీర్ఘకాలిక సైనసిటిస్, నాసికా రుగ్మతలు లేదా శ్వాసకోశ అలెర్జీలు.";
"yoga_formation_peenasaroga_yoga" = "చంద్రుడు మరియు 4వ అధిపతి శని మరియు రాహువులచే బాధింపబడ్డారు.";

// [−] Pisacha Grastha Yoga
"yoga_name_pisacha_grastha_yoga" = "పిశాచ గ్రస్త యోగా";
"yoga_outcome_pisacha_grastha_yoga" = "మానసిక అవాంతరాలు లేదా అహేతుక భయాలు; మానసిక ఆరోగ్య పద్ధతులు ఉపశమనాన్ని అందిస్తాయి.";
"yoga_formation_pisacha_grastha_yoga" = "రాహు/కేతు సంయోగం చంద్రుడు లేదా లగ్నాధిపతి ఎటువంటి ప్రయోజనకరమైన ఉపశమనం లేదు.";

// [−] Pitrusapa Sutakshaya Yoga
"yoga_name_pitrusapa_sutakshaya_yoga" = "పితృసప సుతక్షయ యోగం";
"yoga_outcome_pitrusapa_sutakshaya_yoga" = "సంతానాన్ని ప్రభావితం చేసే తండ్రి శాపం; పరిష్కరించని పితృ కర్మ పిల్లలపై ప్రభావం చూపుతుంది.";
"yoga_formation_pitrusapa_sutakshaya_yoga" = "అశుభ కలయికలలో 5వ అధిపతితో సూర్యుడు బాధపడ్డాడు.";

// [−] Pittaroga Yoga
"yoga_name_pittaroga_yoga" = "పిత్తరోగ యోగము";
"yoga_outcome_pittaroga_yoga" = "పిట్టా సంబంధిత రుగ్మతలకు (మంట, ఆమ్లత్వం, కాలేయ సమస్యలు) గ్రహణశీలత.";
"yoga_formation_pittaroga_yoga" = "సూర్యుడు మరియు కుజుడు లగ్నాన్ని/6వ అగ్ని-మూలక అసమతుల్యతతో బాధపడుతున్నారు.";

// [−] Pretasapa Yoga
"yoga_name_pretasapa_yoga" = "ప్రేతసప యోగా";
"yoga_outcome_pretasapa_yoga" = "కుటుంబాన్ని ప్రభావితం చేసే పూర్వీకుల ఆత్మ బాధ; ఆధ్యాత్మిక ప్రక్షాళన సిఫార్సు చేయబడింది.";
