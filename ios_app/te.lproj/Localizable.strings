"yoga_formation_kalanirdesat_putranasa_yoga_230" = "5వ ప్రభువు నిర్దిష్ట దుర్మార్గపు దశ (వర్ణం 2) సమయంలో బాధపడ్డాడు.";

// [+] Kalatramooladhana Yoga
