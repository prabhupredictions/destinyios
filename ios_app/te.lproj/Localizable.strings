"yoga_outcome_bharathi_yoga" = "అసాధారణమైన స్కాలర్‌షిప్, వాక్చాతుర్యం, అభ్యాసంలో కీర్తి మరియు కళలు మరియు శాస్త్రాలలో నైపుణ్యాన్ని మంజూరు చేస్తుంది.";
"yoga_formation_bharathi_yoga" = "2వ/5వ/11వ అధిపతి యొక్క నవాంశాధిపతి ఉత్కృష్టుడు మరియు 9వ అధిపతితో కలిసి ఉన్నాడు.";

// [−] Bharyasahavyabhicharya Yoga
"yoga_name_bharyasahavyabhicharya_yoga" = "భార్యాసహవ్యభిచార్య యోగం";
"yoga_outcome_bharyasahavyabhicharya_yoga" = "వివాహంలో ట్రస్ట్ సమస్యలు; పారదర్శకత మరియు భావోద్వేగ కనెక్షన్‌కు ప్రాధాన్యత ఇవ్వాలి.";
"yoga_formation_bharyasahavyabhicharya_yoga" = "శుక్రుడు మరియు 7వ ఇంటి బాధలు అవిశ్వాసాన్ని సూచిస్తాయి.";

// [+] Bhaskara Yoga
"yoga_name_bhaskara_yoga" = "భాస్కర యోగం";
"yoga_outcome_bhaskara_yoga" = "నేర్చుకోవడంలో సౌర-వంటి ప్రకాశం; బోధన ద్వారా ఇతరులకు వెలుగునిస్తుంది.";
"yoga_formation_bhaskara_yoga" = "సూర్యుని నుండి 2వ స్థానంలో బుధుడు, 11వ స్థానంలో చంద్రుడు, బుధుడు నుండి త్రికోణంలో బృహస్పతి.";

// [+] Bheri Yoga
"yoga_name_bheri_yoga" = "భేరి యోగా";
"yoga_outcome_bheri_yoga" = "డ్రమ్ లాంటి కీర్తి; శ్రేయస్సు, ధైర్యం, శాశ్వత కీర్తి మరియు రాజ హోదా.";
"yoga_formation_bheri_yoga" = "9వ అధిపతి నుండి పరస్పర కేంద్రాలలో శుక్రుడు, గురు, లగ్నాధిపతి.";

