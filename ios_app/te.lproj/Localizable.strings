"yoga_formation_bhojana_soukhya_yoga" = "2వ ఇంటిపై ప్రయోజనకరమైన అంశాలతో 2వ ప్రభువు బలవంతుడు.";

// [+] Bhratrumoola Dhanaprapti (136)
"yoga_name_bhratrumoola_dhanaprapti_yoga_136" = "భ్రాత్రమూల ధనప్రాప్తి (136)";
