"yoga_outcome_amaranantha_dhana_yoga" = "பரம்பரை பரம்பரையாகப் பராமரிக்கப்படும் நிரந்தரமான, குறையாத செல்வத்தை வழங்குகிறது.";
"yoga_formation_amaranantha_dhana_yoga" = "பரஸ்பர ஆதரவில் வலுவான பாதிக்கப்படாத 2 மற்றும் 11 ஆம் அதிபதிகள்.";

// [+] Amsavatara Yoga
"yoga_name_amsavatara_yoga" = "அம்சாவதார யோகம்";
"yoga_outcome_amsavatara_yoga" = "தெய்வீக அவதார குணங்கள்; தனிநபர் ஒரு சிறப்பு ஆன்மீக பணி அல்லது நோக்கத்தை கொண்டு செல்கிறார்.";
"yoga_formation_amsavatara_yoga" = "லக்ன அதிபதியிலிருந்து கேந்திரத்தில் சுக்கிரன், திரிகோணத்தில் வியாழன்.";

// [−] Anapathya Yoga
"yoga_name_anapathya_yoga" = "அனபத்திய யோகம்";
"yoga_outcome_anapathya_yoga" = "சந்ததியினர் முழுமையாக இல்லாமை; பெற்றோரின் உள்ளுணர்வுகளின் தத்தெடுப்பு அல்லது ஆன்மீக பதங்கமாதல்.";
"yoga_formation_anapathya_yoga" = "5 ஆம் அதிபதி, வியாழன் மற்றும் 5 ஆம் வீடுகள் அனைத்தும் கடுமையாக பாதிக்கப்பட்டுள்ளன.";

// [+] Anapha Yoga
"yoga_name_anapha_yoga" = "அனபா யோகா";
"yoga_outcome_anapha_yoga" = "நல்ல உடலமைப்பு, வலிமையான குணம் மற்றும் பெரிய துன்பங்கள் இல்லாத வசதியான வாழ்க்கை முறையை வழங்குகிறது.";
"yoga_formation_anapha_yoga" = "சந்திரனில் இருந்து 12வது வீட்டில் உள்ள கிரகம் (சூரியன்/ராகு/கேது தவிர).";

// [−] Andha Yoga
"yoga_name_andha_yoga" = "அந்த யோகா";
"yoga_outcome_andha_yoga" = "கடுமையான கண் தொடர்பான உடல்நலக் கவலைகள்; ஆரம்ப மற்றும் வழக்கமான தலையீடு முக்கியமானது.";
"yoga_formation_andha_yoga" = "லுமினரிகள் மற்றும் 2வது/12வது வீடுகள் கடுமையாக பாதிக்கப்பட்டுள்ளன (வர். 3).";

// [−] Andha Yoga (288)
"yoga_name_andha_yoga_288" = "அந்த யோகா (288)";
"yoga_outcome_andha_yoga_288" = "குறிப்பிடத்தக்க பார்வை சவால்கள்; கண் ஆரோக்கியம் மற்றும் தடுப்பு நடவடிக்கைகளுக்கு முன்னுரிமை கொடுங்கள்.";
"yoga_formation_andha_yoga_288" = "சூரியன்/சந்திரன் 6வது/8வது/12வது (வர். 1) இல் உள்ள தீய சக்திகளால் பாதிக்கப்பட்டவர்கள்.";

// [−] Andha Yoga (289)
"yoga_name_andha_yoga_289" = "அந்த யோகா (289)";
"yoga_outcome_andha_yoga_289" = "முற்போக்கான பார்வை இழப்பு பாதிப்பு; கண் மருத்துவ பராமரிப்பு பரிந்துரைக்கப்படுகிறது.";
"yoga_formation_andha_yoga_289" = "சுக்கிரனும் 2ம் அதிபதியும் தீய அம்சங்களுடன் வலுவிழந்தனர் (வர். 2).";

// [−] Angaheena Yoga
"yoga_name_angaheena_yoga" = "அங்கஹீன யோகா";
"yoga_outcome_angaheena_yoga" = "உடல் ரீதியான சவால்கள் அல்லது இயலாமை; உடல் வரம்புகளை கடக்க உறுதி தேவை.";
"yoga_formation_angaheena_yoga" = "துஸ்தானத்தில் லக்னாதிபதியால் பாதிக்கப்பட்ட லக்னத்தில் தோஷம்.";

// [+] Annadana Yoga
"yoga_name_annadana_yoga" = "அன்னதான யோகம்";
"yoga_outcome_annadana_yoga" = "தாராள உணவு வழங்குபவர்; தனிநபர் மற்றவர்களுக்கு உணவளிக்கிறார் மற்றும் தொண்டு விருந்தோம்பலுக்கு பெயர் பெற்றவர்.";
"yoga_formation_annadana_yoga" = "2ஆம் அதிபதி வியாழனின் அம்சத்துடன் கேந்திரம்/திரிகோணத்தில்.";

// [+] Anthya Vayasi Dhana Yoga
"yoga_name_anthya_vayasi_dhana_yoga" = "அந்திய வயசி தன யோகம்";
"yoga_outcome_anthya_vayasi_dhana_yoga" = "பிற்கால வாழ்க்கையில் (55+ ஆண்டுகள்) செழிப்பைக் குறிக்கிறது; ஓய்வு ஆறுதல் அளிக்கிறது.";
"yoga_formation_anthya_vayasi_dhana_yoga" = "பிற்கால தசா காலங்களில் செல்வத்தைக் குறிக்கும் சக்திகள் செயல்படுகின்றன.";

// [−] Apakeerti Yoga
"yoga_name_apakeerti_yoga" = "அபகீர்த்தி யோகம்";
"yoga_outcome_apakeerti_yoga" = "புகழ் அல்லது சேதமடைந்த நற்பெயரின் அபாயத்தைக் குறிக்கிறது; கவனத்துடன் நடத்துவது அவசியம்.";
"yoga_formation_apakeerti_yoga" = "லக்னம் மற்றும் 10 ஆம் வீட்டில் தோஷ தாக்கங்கள்.";

// [−] Aputra Yoga
"yoga_name_aputra_yoga" = "அபுத்ர யோகம்";
"yoga_outcome_aputra_yoga" = "குழந்தை இல்லாமை அல்லது சந்ததியைப் பெறுவதில் மிகுந்த சிரமம்; மறுசீரமைப்பு நடவடிக்கைகள் அறிவுறுத்தப்பட்டுள்ளன.";
"yoga_formation_aputra_yoga" = "5 ஆம் அதிபதியும் வியாழனும் துஸ்தானத்தில் கடுமையாகப் பாதிக்கப்பட்டுள்ளனர்.";

// [−] Asatyavadi Yoga
"yoga_name_asatyavadi_yoga" = "அசத்யவாதி யோகம்";
"yoga_outcome_asatyavadi_yoga" = "பொய்மை அல்லது மிகைப்படுத்தல் நோக்கிய போக்கு; நனவான நேர்மை பயிற்சி தேவை.";
"yoga_formation_asatyavadi_yoga" = "2ம் வீட்டில் புதன் தோஷம்.";

// [+] Ayatna Griha Prapta (189)
"yoga_name_ayatna_griha_prapta_yoga_189" = "ஆயத்னா க்ரிஹ பிராப்தா (189)";
"yoga_outcome_ayatna_griha_prapta_yoga_189" = "முயற்சி இல்லாமல் சொத்து கையகப்படுத்தல் - பரம்பரை, பரிசுகள் அல்லது அதிர்ஷ்டமான ஒப்பந்தங்கள் மூலம்.";
"yoga_formation_ayatna_griha_prapta_yoga_189" = "4 ஆம் அதிபதி நன்மையான அம்சங்களுடன் நன்கு இடம் பெற்றுள்ளார் (வர். 1).";

// [+] Ayatna Griha Prapta (190)
"yoga_name_ayatna_griha_prapta_yoga_190" = "ஆயத்னா க்ரிஹ பிராப்தா (190)";
"yoga_outcome_ayatna_griha_prapta_yoga_190" = "சாதகமான சூழ்நிலையில் வீடுகள் மற்றும் ரியல் எஸ்டேட்களை சிரமமின்றி கையகப்படுத்துதல்.";
"yoga_formation_ayatna_griha_prapta_yoga_190" = "வலுவான கிரகங்களிலிருந்து 4 வது வீட்டில் பலன் தாக்கம் (வர். 2).";

// [+] Ayatnadhanalabha Yoga
"yoga_name_ayatnadhanalabha_yoga" = "ஆயத்னதனலாப யோகம்";
"yoga_outcome_ayatnadhanalabha_yoga" = "சிரமமில்லாத செல்வத்தை வழங்குகிறது - திடீர் இழப்பு, பரம்பரை அல்லது அதிர்ஷ்ட வாய்ப்புகள்.";
"yoga_formation_ayatnadhanalabha_yoga" = "வியாழன்/சுக்கிரன் அம்சங்களுடன் 2ஆம் அதிபதி 11இல் அல்லது நேர்மாறாக.";

// [+] Bahu Stree Yoga
"yoga_name_bahu_stree_yoga" = "பஹு ஸ்திரீ யோகம்";
"yoga_outcome_bahu_stree_yoga" = "பல குறிப்பிடத்தக்க உறவுகள் அல்லது எதிர் பாலினத்திடமிருந்து வலுவான ஈர்ப்பு; காந்த காதல் இருப்பு.";
"yoga_formation_bahu_stree_yoga" = "லக்னா அதிபதி மற்றும் 7 ஆம் அதிபதி இணைந்து அல்லது பரஸ்பர அம்சத்தில்.";

// [+] Bahudravyarjana Yoga
"yoga_name_bahudravyarjana_yoga" = "பஹுத்ரவ்யர்ஜன யோகம்";
"yoga_outcome_bahudravyarjana_yoga" = "வாழ்நாள் முழுவதும் பல ஆதாரங்களில் இருந்து பல்வேறு சொத்துக்கள் மற்றும் செல்வத்தை கையகப்படுத்துவதை உறுதி செய்கிறது.";
"yoga_formation_bahudravyarjana_yoga" = "வலுவான பரஸ்பர நிலைகளில் பல செல்வம்-குறியீடுகள்.";

// [+] Bahuputra Yoga (220)
"yoga_name_bahuputra_yoga_220" = "பகுபுத்ரா யோகா (220)";
"yoga_outcome_bahuputra_yoga_220" = "மகிழ்ச்சியையும் குடும்ப தொடர்ச்சியையும் தரும் பல குழந்தைகளுடன் ஆசீர்வதிக்கப்பட்டவர்.";
"yoga_formation_bahuputra_yoga_220" = "5 ஆம் அதிபதி வியாழனின் அம்சத்துடன் கேந்திரம்/திரிகோணத்தில் வலுவாக இருக்கிறார் (வர். 1).";

// [+] Bahuputra Yoga (221)
"yoga_name_bahuputra_yoga_221" = "பகுபுத்ரா யோகா (221)";
"yoga_outcome_bahuputra_yoga_221" = "நல்ல ஆரோக்கியம் மற்றும் பண்புடன் கூடிய பல சந்ததிகள்; குடும்பம் வளரும்.";
"yoga_formation_bahuputra_yoga_221" = "வியாழன் மற்றும் 5 ஆம் அதிபதி பரஸ்பர ஆதரவில் நன்மை இணைப்புகளுடன் (வர். 2).";

// [+] Balya Dhana Yoga
"yoga_name_balya_dhana_yoga" = "பால்ய தன யோகம்";
"yoga_outcome_balya_dhana_yoga" = "குடும்ப செல்வம் அல்லது பரம்பரை மூலம் ஆரம்பகால நிதி நன்மைகளை வழங்குகிறது.";
"yoga_formation_balya_dhana_yoga" = "பிறப்பிலிருந்து ஆரம்ப தசா வரை செல்வத்தைக் குறிப்பவர்கள் செயலில் உள்ளனர்.";

// [−] Bandhana Yoga
"yoga_name_bandhana_yoga" = "பந்தன யோகம்";
"yoga_outcome_bandhana_yoga" = "சிறைவாசம், சிறைவாசம் அல்லது விருப்பமில்லாமல் சுதந்திரத்தை கட்டுப்படுத்தும் ஆபத்து.";
"yoga_formation_bandhana_yoga" = "லக்னாதிபதியும் 6ஆம் அதிபதியும் சனி/ராகுவுடன் இணைந்துள்ளனர்.";

// [+] Bandhu Pujya Yoga (193)
"yoga_name_bandhu_pujya_yoga_193" = "பந்து பூஜ்ய யோகா (193)";
"yoga_outcome_bandhu_pujya_yoga_193" = "குடும்பம் மற்றும் உறவினர்களிடமிருந்து மரியாதை மற்றும் பாசத்தை வழங்குகிறது; தனிநபர் ஒரு குடும்ப நங்கூரம்.";
"yoga_formation_bandhu_pujya_yoga_193" = "4ம் அதிபதி நன்மையான அம்சங்களுடன் சுப ஸ்தானத்திலும், லக்னத்தில் புதன்.";

// [+] Bandhu Pujya Yoga (194)
"yoga_name_bandhu_pujya_yoga_194" = "பந்து பூஜ்ய யோகா (194)";
"yoga_outcome_bandhu_pujya_yoga_194" = "குடும்ப உறவுகளை பலப்படுத்துகிறது மற்றும் உறவினர் மற்றும் நம்பகமான ஆலோசனை மூலம் மரியாதை தருகிறது.";
"yoga_formation_bandhu_pujya_yoga_194" = "வியாழன் அம்சம் அல்லது தொழில் மூலம் 4 வது வீட்டிற்கு இணைக்கப்பட்டுள்ளது.";

// [−] Bandhubhisthyaktha Yoga
"yoga_name_bandhubhisthyaktha_yoga" = "பந்துபிஸ்த்யக்த யோகம்";
"yoga_outcome_bandhubhisthyaktha_yoga" = "உறவினர்களிடமிருந்து விலகுதல் மற்றும் சாத்தியமான குடும்ப மோதல்கள் அல்லது தனிமைப்படுத்துதல் ஆகியவற்றைக் குறிக்கிறது.";
"yoga_formation_bandhubhisthyaktha_yoga" = "4வது வீட்டிற்கும், அதிபதிக்கும் பலன் ஆதரவு இல்லாத தோஷம்.";

// [+] Bhadra Yoga
"yoga_name_bhadra_yoga" = "பத்ர யோகம்";
"yoga_outcome_bhadra_yoga" = "கூர்மையான அறிவுத்திறன், சொற்பொழிவு, வணிக புத்திசாலித்தனம் மற்றும் பகுப்பாய்வுத் தொழில்களில் சிறந்து விளங்குகிறது.";
"yoga_formation_bhadra_yoga" = "புதன் ஒரு கேந்திரத்தில் (1/4/7/10) சொந்த ராசியில் (மிதுனம்/கன்னி) அல்லது உயர்நிலையில் (கன்னி).";

// [+] Bhaga Chumbana Yoga
"yoga_name_bhaga_chumbana_yoga" = "பக சும்பன யோகம்";
"yoga_outcome_bhaga_chumbana_yoga" = "உயர்ந்த உடல் காந்தத்தன்மை மற்றும் நெருக்கமான நிறைவுடன் தீவிரமான, உணர்ச்சிமிக்க காதல் வாழ்க்கை.";
"yoga_formation_bhaga_chumbana_yoga" = "சுக்கிரனும் 7ம் அதிபதியும் உடல் ஈர்ப்பைக் குறிக்கும் குறிப்பிட்ட சேர்க்கைகளில்.";

// [+] Bhagya Yoga
"yoga_name_bhagya_yoga" = "பாக்ய யோகம்";
"yoga_outcome_bhagya_yoga" = "விதிவிலக்கான அதிர்ஷ்டம், அதிர்ஷ்டம் மற்றும் தெய்வீக அருள்; சரியான நேரத்தில் வாய்ப்புகளால் ஆசீர்வதிக்கப்பட்டது.";
"yoga_formation_bhagya_yoga" = "9ம் அதிபதி கேந்திரம்/திரிகோணத்தில் பலன் பலன்களுடன் இருக்கிறார்.";

// [+] Bharathi Yoga
"yoga_name_bharathi_yoga" = "பாரதி யோகா";
"yoga_outcome_bharathi_yoga" = "விதிவிலக்கான புலமை, பேச்சுத்திறன், கற்றலில் புகழ், கலை மற்றும் அறிவியலில் தேர்ச்சி ஆகியவற்றை வழங்குகிறது.";
"yoga_formation_bharathi_yoga" = "2/5/11ஆம் அதிபதியின் நவாம்ச அதிபதி 9ஆம் அதிபதியுடன் இணைந்தவர்.";

// [−] Bharyasahavyabhicharya Yoga
"yoga_name_bharyasahavyabhicharya_yoga" = "பர்யாஸஹவ்யாபிசார்ய யோகம்";
"yoga_outcome_bharyasahavyabhicharya_yoga" = "திருமணத்தில் நம்பிக்கை சிக்கல்கள்; வெளிப்படைத்தன்மை மற்றும் உணர்வுபூர்வமான இணைப்புக்கு முன்னுரிமை அளிக்கப்பட வேண்டும்.";
"yoga_formation_bharyasahavyabhicharya_yoga" = "துரோகத்தைக் குறிக்கும் சுக்கிரன் மற்றும் 7 ஆம் வீட்டின் துன்பங்கள்.";

// [+] Bhaskara Yoga
"yoga_name_bhaskara_yoga" = "பாஸ்கர யோகம்";
"yoga_outcome_bhaskara_yoga" = "கற்றலில் சூரிய ஒளி போன்ற புத்திசாலித்தனம்; கற்பித்தல் மூலம் மற்றவர்களுக்கு வெளிச்சம் தருகிறது.";
"yoga_formation_bhaskara_yoga" = "சூரியனிலிருந்து 2-ல் புதன், 11-ல் சந்திரன், புதனிலிருந்து திரிகோணத்தில் வியாழன்.";

// [+] Bheri Yoga
"yoga_name_bheri_yoga" = "பேரி யோகா";
"yoga_outcome_bheri_yoga" = "பறை போன்ற புகழ்; செழிப்பு, தைரியம், நீடித்த புகழ் மற்றும் அரச அந்தஸ்து.";
"yoga_formation_bheri_yoga" = "9ம் அதிபதியிலிருந்து பரஸ்பர கேந்திரங்களில் சுக்கிரன், வியாழன், லக்ன அதிபதி.";

// [+] Bhojana Soukhya Yoga
"yoga_name_bhojana_soukhya_yoga" = "போஜன சௌக்கிய யோகம்";
"yoga_outcome_bhojana_soukhya_yoga" = "சிறந்த உணவு, சமையல் இன்பங்கள் மற்றும் வசதியான சாப்பாட்டு வாழ்க்கை முறையை அனுபவிக்கிறது.";
"yoga_formation_bhojana_soukhya_yoga" = "2ம் அதிபதி 2ம் வீட்டில் நன்மை தரும் அம்சங்களுடன் வலுவாக இருக்கிறார்.";

// [+] Bhratrumoola Dhanaprapti (136)
"yoga_name_bhratrumoola_dhanaprapti_yoga_136" = "பிரத்ருமுலா தனப்ராப்தி (136)";
"yoga_outcome_bhratrumoola_dhanaprapti_yoga_136" = "உடன்பிறப்புகள், தைரியம் அல்லது தொடர்பு மூலம் செல்வம்; உடன்பிறந்தவர்கள் செழிப்புக்கு உதவுவார்கள்.";
"yoga_formation_bhratrumoola_dhanaprapti_yoga_136" = "3வது அதிபதி 2வது மற்றும் 11வது வீடுகளுடன் இணைக்கப்பட்டுள்ளது (வர். 1).";

// [+] Bhratrumoola Dhanaprapti (137)
"yoga_name_bhratrumoola_dhanaprapti_yoga_137" = "பிரத்ருமுலா தனப்ராப்தி (137)";
"yoga_outcome_bhratrumoola_dhanaprapti_yoga_137" = "உடன்பிறந்த கூட்டு அல்லது கூட்டு முயற்சிகள் மூலம் நிதி ஆதாயம்.";
"yoga_formation_bhratrumoola_dhanaprapti_yoga_137" = "3வது அதிபதி 2வது மற்றும் 11வது வீடுகளுடன் இணைக்கப்பட்டுள்ளது (வர். 2).";

// [−] Bhratrusapa Sutakshaya Yoga
"yoga_name_bhratrusapa_sutakshaya_yoga" = "ப்ரத்ருஷப சுதக்ஷய யோகம்";
"yoga_outcome_bhratrusapa_sutakshaya_yoga" = "சந்ததியை பாதிக்கும் உடன்பிறந்தவர்களின் சாபம்; தீர்க்கப்படாத சகோதர கர்மா குழந்தைகளை பாதிக்கிறது.";
"yoga_formation_bhratrusapa_sutakshaya_yoga" = "செவ்வாய் தோஷ சேர்க்கைகளில் 5 ஆம் அதிபதியுடன் பாதிக்கப்பட்டுள்ளார்.";

// [+] Brahma Yoga
"yoga_name_brahma_yoga" = "பிரம்ம யோகம்";
"yoga_outcome_brahma_yoga" = "அறிவு சார்ந்த தொழில்களில் ஆழ்ந்த ஞானம், அறிவார்ந்த நோக்கங்கள் மற்றும் தெய்வீக பாதுகாப்பை வழங்குகிறது.";
"yoga_formation_brahma_yoga" = "குறிப்பிட்ட தேவைகளுடன் 5 மற்றும் 11 ஆம் அதிபதிகளிடமிருந்து கேந்திரங்களில் உள்ள பலன்கள்.";

// [−] Buddhi Jada Yoga
"yoga_name_buddhi_jada_yoga" = "புத்தி ஜட யோகம்";
"yoga_outcome_buddhi_jada_yoga" = "மெதுவான கற்றல் அல்லது அறிவார்ந்த மந்தநிலை; சிக்கலான கருத்துக்களை புரிந்து கொள்ள கூடுதல் முயற்சி தேவை.";
"yoga_formation_buddhi_jada_yoga" = "புதன் மற்றும் 5 ஆம் வீட்டைத் தாக்கும் சனி, பலன் நிவாரணம் இல்லை.";

// [+] Buddhimaturya Yoga
"yoga_name_buddhimaturya_yoga" = "புத்திமாதுரிய யோகம்";
"yoga_outcome_buddhimaturya_yoga" = "ஒருவரின் வயதுக்கு அப்பாற்பட்ட முதிர்ந்த புத்தி; ஞானம், பகுப்பாய்வு ஆழம் மற்றும் அறிவார்ந்த குணம்.";
"yoga_formation_buddhimaturya_yoga" = "புதன் மற்றும் வியாழன் பரஸ்பர கேந்திரத்தில், 5 ஆம் அதிபதி வலுவாக உள்ளனர்.";

// [+] Budha Aditya Yoga
"yoga_name_budha_aditya_yoga" = "புத ஆதித்ய யோகம்";
"yoga_outcome_budha_aditya_yoga" = "தலைமைத்துவத்துடன் இணைந்த அறிவுசார் புத்திசாலித்தனம்; நிர்வாக திறன் கொண்ட சிறந்த தொடர்பாளர்.";
"yoga_formation_budha_aditya_yoga" = "புதன் சூரியனுடன் ஒரே வீட்டில் இணைந்தது.";

// [+] Budha Yoga
"yoga_name_budha_yoga" = "புத யோகம்";
"yoga_outcome_budha_yoga" = "மெர்குரியல் நுண்ணறிவு - விரைவான அறிவு, கணிதத் திறன் மற்றும் வணிகத் திறன்.";
"yoga_formation_budha_yoga" = "கேந்திரத்தில் புதன் வலுவாக 5ம் இடத்துடன் இணைக்கப்பட்ட நன்மையான அம்சங்களுடன்.";

// [+] Chandika Yoga
"yoga_name_chandika_yoga" = "சண்டிகா யோகம்";
"yoga_outcome_chandika_yoga" = "தலைமைப் பாத்திரங்களில் கடுமையான உறுதியும் தெய்வீகப் பாதுகாப்பும்.";
"yoga_formation_chandika_yoga" = "லக்னாதிபதி கேந்திரத்தில் சந்திரன், வியாழன் ஆகிய கிரகங்களை உயர்த்தினார்.";

// [−] Chandra Mangala Yoga
"yoga_name_chandra_mangala_yoga" = "சந்திர மங்கள யோகம்";
"yoga_outcome_chandra_mangala_yoga" = "உணர்ச்சி தீவிரம் மற்றும் மனக்கிளர்ச்சி போக்குகளை உருவாக்குகிறது. வழக்கத்திற்கு மாறான வழிகள் மூலம் ஆதாயங்களைக் கொண்டு வரலாம் ஆனால் உறவு உராய்வை ஏற்படுத்தும்.";
"yoga_formation_chandra_mangala_yoga" = "சந்திரனும் செவ்வாயும் இணைந்து (ஒரே வீடு).";

// [+] Chapa Yoga
"yoga_name_chapa_yoga" = "சாப யோகா";
"yoga_outcome_chapa_yoga" = "அரச வசதிகள், செழிப்பு, உண்மையுள்ள தைரியம் மற்றும் கண்ணியமான சமூக நிலை ஆகியவற்றை வழங்குகிறது.";
"yoga_formation_chapa_yoga" = "லக்ன அதிபதி உயர்ந்தவர், பரஸ்பர பரிமாற்றத்தில் 4 மற்றும் 10 ஆம் அதிபதிகள்.";

// [+] Chatussagara Yoga
"yoga_name_chatussagara_yoga" = "சதுசாகர யோகம்";
"yoga_outcome_chatussagara_yoga" = "புகழ், செழிப்பு மற்றும் பிராந்தியங்கள் முழுவதும் அறியப்பட்ட செல்வாக்குமிக்க வாழ்க்கையை வழங்குகிறது.";
"yoga_formation_chatussagara_yoga" = "நான்கு கேந்திர வீடுகளும் (1/4/7/10) கிரகங்களால் ஆக்கிரமிக்கப்பட்டுள்ளன.";

// [−] Daridra Yoga
"yoga_name_daridra_yoga" = "தரித்ரா யோகம்";
"yoga_outcome_daridra_yoga" = "நிதி நெருக்கடியின் காலங்கள்; கவனமாக திட்டமிடல் மற்றும் தீர்வு நடவடிக்கைகள் பரிந்துரைக்கப்படுகிறது.";
"yoga_formation_daridra_yoga" = "6/8/12ஆம் வீடுகளில் 2ஆம் மற்றும் 11ஆம் அதிபதிகள்.";

// [−] Daridra Yoga (144)
"yoga_name_daridra_yoga_144" = "தரித்ரா யோகா (144)";
"yoga_outcome_daridra_yoga_144" = "கூட்டாண்மை, சட்டச் சிக்கல்கள் அல்லது அதிகச் செலவுகள் மூலம் நிதி வடிகால்.";
"yoga_formation_daridra_yoga_144" = "லக்னம்-12ம் அதிபதி 7ம் அதிபதி அம்சங்களுடன் பரிவர்த்தனை.";

// [−] Daridra Yoga (145)
"yoga_name_daridra_yoga_145" = "தரித்ரா யோகா (145)";
"yoga_outcome_daridra_yoga_145" = "வருமான உறுதியற்ற தன்மை மற்றும் செல்வத்தை சேமிப்பதில் சிரமம்.";
"yoga_formation_daridra_yoga_145" = "2வது மற்றும் 11வது வீடுகளில் தவறான சேர்க்கைகள் (வர். 2).";

// [−] Daridra Yoga (146)
"yoga_name_daridra_yoga_146" = "தரித்ரா யோகா (146)";
"yoga_outcome_daridra_yoga_146" = "வீணான செலவுகள் அல்லது துரதிர்ஷ்டவசமான நிதி முடிவுகளால் வறுமை.";
"yoga_formation_daridra_yoga_146" = "2வது மற்றும் 11வது வீடுகளில் தவறான சேர்க்கைகள் (வர். 3).";

// [−] Daridra Yoga (147)
"yoga_name_daridra_yoga_147" = "தரித்ரா யோகா (147)";
"yoga_outcome_daridra_yoga_147" = "குடும்பக் கடமைகள் அல்லது பரம்பரைக் கடன்கள் காரணமாக நிதிச் சிக்கல்கள்.";
"yoga_formation_daridra_yoga_147" = "2வது மற்றும் 11வது வீடுகளில் தவறான சேர்க்கைகள் (வர். 4).";

// [−] Daridra Yoga (148)
"yoga_name_daridra_yoga_148" = "தரித்ரா யோகா (148)";
"yoga_outcome_daridra_yoga_148" = "எதிரிகள், வழக்குகள் அல்லது உடல்நலச் செலவுகள் மூலம் செல்வ இழப்பு.";
"yoga_formation_daridra_yoga_148" = "2வது மற்றும் 11வது வீடுகளில் தவறான சேர்க்கைகள் (வர். 5).";

// [−] Daridra Yoga (149)
"yoga_name_daridra_yoga_149" = "தரித்ரா யோகா (149)";
"yoga_outcome_daridra_yoga_149" = "நிலையான வேலை அல்லது நிலையான வருமானத்தை பராமரிப்பதில் சிரமம்.";
"yoga_formation_daridra_yoga_149" = "2வது மற்றும் 11வது வீடுகளில் தவறான சேர்க்கைகள் (வர். 6).";

// [−] Daridra Yoga (150)
"yoga_name_daridra_yoga_150" = "தரித்ரா யோகா (150)";
"yoga_outcome_daridra_yoga_150" = "நிதி விஷயங்களில் முன்முயற்சி அல்லது ஊக்கமின்மை காரணமாக வறுமை.";
"yoga_formation_daridra_yoga_150" = "2வது மற்றும் 11வது வீடுகளில் தவறான சேர்க்கைகள் (வர். 7).";

// [−] Daridra Yoga (151)
"yoga_name_daridra_yoga_151" = "தரித்ரா யோகா (151)";
"yoga_outcome_daridra_yoga_151" = "ஊகங்கள் அல்லது அபாயகரமான முயற்சிகள் மூலம் நிதி இழப்புகள்.";
"yoga_formation_daridra_yoga_151" = "2வது மற்றும் 11வது வீடுகளில் தவறான சேர்க்கைகள் (வர். 8).";

// [−] Daridra Yoga (152)
"yoga_name_daridra_yoga_152" = "தரித்ரா யோகா (152)";
"yoga_outcome_daridra_yoga_152" = "ஒழுக்கமான பண மேலாண்மை தேவைப்படும் நாள்பட்ட நிதி சவால்கள்.";
"yoga_formation_daridra_yoga_152" = "2வது மற்றும் 11வது வீடுகளில் தவறான சேர்க்கைகள் (வர். 9).";

// [−] Daridra Yoga (153)
"yoga_name_daridra_yoga_153" = "தரித்ரா யோகா (153)";
"yoga_outcome_daridra_yoga_153" = "தனிப்பட்ட கட்டுப்பாட்டிற்கு அப்பாற்பட்ட வெளிப்புற சூழ்நிலைகள் மூலம் நிதி அழிவு.";
"yoga_formation_daridra_yoga_153" = "2வது மற்றும் 11வது வீடுகளில் தவறான சேர்க்கைகள் (வர். 10).";

// [+] Dattaputra Yoga (222)
"yoga_name_dattaputra_yoga_222" = "தத்தபுத்திர யோகா (222)";
"yoga_outcome_dattaputra_yoga_222" = "தத்தெடுக்கப்பட்ட குழந்தைகள் அல்லது உயிரியல் அல்லாத வாரிசுகள் மூலம் மகிழ்ச்சி.";
"yoga_formation_dattaputra_yoga_222" = "5 ஆம் அதிபதி சனியின் ஈடுபாட்டுடன் 8/12 க்கு இணைக்கப்பட்டுள்ளது (வர். 1).";

// [+] Dattaputra Yoga (223)
"yoga_name_dattaputra_yoga_223" = "தத்தபுத்ர யோகா (223)";
"yoga_outcome_dattaputra_yoga_223" = "தத்தெடுப்பு மூலம் குடும்ப விரிவாக்கம்; தத்தெடுக்கப்பட்ட குழந்தை நிறைவைத் தருகிறது.";
"yoga_formation_dattaputra_yoga_223" = "தத்தெடுப்பைக் குறிக்கும் குறிப்பிட்ட 5வது வீட்டின் கட்டமைப்புகள் (var. 2).";

// [−] Dehakashta Yoga
"yoga_name_dehakashta_yoga" = "தேஹகாஷ்ட யோகம்";
"yoga_outcome_dehakashta_yoga" = "நாள்பட்ட உடல் அசௌகரியம், உடல் ரீதியான துன்பம் அல்லது தொடர்ச்சியான உடல்நலப் புகார்கள்.";
"yoga_formation_dehakashta_yoga" = "லக்னாதிபதி துஸ்தானத்தில் தீய அம்சங்களுடன் இருக்கிறார், பலன் நிவாரணம் இல்லை.";

// [+] Dehapushti Yoga
"yoga_name_dehapushti_yoga" = "தேஹபுஷ்டி யோகம்";
"yoga_outcome_dehapushti_yoga" = "நன்கு வளர்ந்த உடலமைப்பு, விதிவிலக்கான சகிப்புத்தன்மை மற்றும் உடல் சுறுசுறுப்பு.";
"yoga_formation_dehapushti_yoga" = "செவ்வாய் மற்றும் லக்னாதிபதி வியாழனின் அம்சத்துடன் வலுவாக உள்ளனர்.";

// [+] Dehasthoulya Yoga
"yoga_name_dehasthoulya_yoga" = "தேஹஸ்தௌல்ய யோகம்";
"yoga_outcome_dehasthoulya_yoga" = "வலுவான உடல், ஆரோக்கியமான பசி மற்றும் வலுவான செரிமான அமைப்பு.";
"yoga_formation_dehasthoulya_yoga" = "வியாழன் மற்றும் சந்திரன் நன்கு ஊட்டச்சத்துள்ள அரசியலமைப்பைக் குறிக்கும் நிலைகளில்.";

// [+] Devendra Yoga
"yoga_name_devendra_yoga" = "தேவேந்திர யோகம்";
"yoga_outcome_devendra_yoga" = "தெய்வீக தயவும் இறையருளும்; கருணையுள்ள அதிகாரத்துடன் ராயல்டி போல் நடத்தப்பட்டது.";
"yoga_formation_devendra_yoga" = "லக்னாதிபதி கேந்திரத்தில் 9, 9ஆம் அதிபதி, பலன்களால் அம்சம்.";

// [+] Dhana Yoga (118)
"yoga_name_dhana_yoga_118" = "தன யோகா (118)";
"yoga_outcome_dhana_yoga_118" = "தொழில்முறை சேனல்கள் மூலம் நிலையான வருமானம் மற்றும் செல்வக் குவிப்பை உறுதி செய்கிறது.";
"yoga_formation_dhana_yoga_118" = "2வது மற்றும் 11வது அதிபதிகள் பரஸ்பர கேந்திரம் அல்லது திரிகோண ஸ்தானங்களில் உள்ளனர்.";

// [+] Dhana Yoga (119)
"yoga_name_dhana_yoga_119" = "தன யோகா (119)";
"yoga_outcome_dhana_yoga_119" = "தனிப்பட்ட முயற்சி மற்றும் நிறுவன மூலம் தனிப்பட்ட செல்வத்தை வழங்குகிறது.";
"yoga_formation_dhana_yoga_119" = "லக்னாதிபதி 2வது மற்றும் 11வது அதிபதிகளுடன் இணைப்பு அல்லது அம்சம் மூலம் இணைக்கப்பட்டுள்ளார்.";

// [+] Dhana Yoga (120)
"yoga_name_dhana_yoga_120" = "தன யோகா (120)";
"yoga_outcome_dhana_yoga_120" = "ஊகங்கள், பரம்பரை அல்லது கடந்தகால வாழ்க்கை தகுதி மூலம் அதிர்ஷ்டத்தை வழங்குகிறது.";
"yoga_formation_dhana_yoga_120" = "5 மற்றும் 9 ஆம் அதிபதிகள் 2 மற்றும் 11 ஆம் அதிபதிகளுடன் இணைந்துள்ளனர்.";

// [+] Dhana Yoga (121)
"yoga_name_dhana_yoga_121" = "தன யோகா (121)";
"yoga_outcome_dhana_yoga_121" = "வாழ்நாள் முழுவதும் பல ஆதாரங்களில் இருந்து நிலையான செல்வ ஓட்டத்தை உருவாக்குகிறது.";
"yoga_formation_dhana_yoga_121" = "2வது மற்றும் 11வது வீடுகளில் பலன்கள் வலுவான கண்ணியத்துடன்.";

// [+] Dhana Yoga (122)
"yoga_name_dhana_yoga_122" = "தன யோகா (122)";
"yoga_outcome_dhana_yoga_122" = "சம்பாதிக்கும் திறன் மற்றும் கணிசமான சொத்துக் குவிப்பு ஆகியவற்றைப் பெருக்கும்.";
"yoga_formation_dhana_yoga_122" = "2 வது அதிபதி உயர்ந்தவர் அல்லது சொந்த அடையாளத்தில், 11 வது வீட்டிற்கு இணைக்கப்பட்டுள்ளது.";

// [+] Dhana Yoga (123)
"yoga_name_dhana_yoga_123" = "தன யோகா (123)";
"yoga_outcome_dhana_yoga_123" = "தொழில்முறை நெட்வொர்க்குகள், சங்கங்கள் மற்றும் சமூக இணைப்புகள் ஆகியவற்றிலிருந்து ஆதாயங்களை உறுதி செய்கிறது.";
"yoga_formation_dhana_yoga_123" = "கேந்திரம் அல்லது திரிகோணத்தில் 11ம் அதிபதி நன்மையான அம்சங்களுடன்.";

// [+] Dhana Yoga (124)
"yoga_name_dhana_yoga_124" = "தன யோகா (124)";
"yoga_outcome_dhana_yoga_124" = "தந்தை வழி, அதிர்ஷ்டம் மற்றும் நேர்மையான வருவாய் மூலம் செல்வத்தை வழங்குகிறது.";
"yoga_formation_dhana_yoga_124" = "9ம் மற்றும் லக்ன அதிபதிகள் 2ம் வீட்டின் ஆதரவுடன் பரஸ்பர தொடர்பில் உள்ளனர்.";

// [+] Dhana Yoga (125)
"yoga_name_dhana_yoga_125" = "தன யோகா (125)";
"yoga_outcome_dhana_yoga_125" = "செல்வம் உருவாக்கம் மற்றும் நிதி நிர்வாகத்திற்கான விதிவிலக்கான திறனை உருவாக்குகிறது.";
"yoga_formation_dhana_yoga_125" = "பலமான 2ம் மற்றும் 11ம் வீடுகளில் அதிபதிகள் கண்ணியமான நிலையில் உள்ளனர்.";

// [+] Dhana Yoga (126)
"yoga_name_dhana_yoga_126" = "தன யோகா (126)";
"yoga_outcome_dhana_yoga_126" = "புத்திசாலித்தனம், ஊகங்கள் மற்றும் படைப்பு முயற்சிகள் மூலம் செல்வத்தை அளிக்கிறது.";
"yoga_formation_dhana_yoga_126" = "2வது, 5வது மற்றும் 11வது அதிபதிகள் அம்சம் அல்லது இணைப்பு வழியாக ஒன்றோடொன்று இணைக்கப்பட்டுள்ளனர்.";

// [+] Dhana Yoga (127)
"yoga_name_dhana_yoga_127" = "தன யோகா (127)";
"yoga_outcome_dhana_yoga_127" = "நெறிமுறை அடித்தளத்தில் செல்வத்தை வழங்குகிறது; நீதியான வழிகளில் செழிப்பு.";
"yoga_formation_dhana_yoga_127" = "வியாழன் 2வது மற்றும் 11வது அதிபதிகளின் பார்வை அல்லது இணைந்திருப்பது.";

// [+] Dhana Yoga (128)
"yoga_name_dhana_yoga_128" = "தன யோகா (128)";
"yoga_outcome_dhana_yoga_128" = "ஆடம்பர, கலை, பொழுதுபோக்கு அல்லது அழகுத் தொழில்கள் மூலம் செல்வத்தைக் கொண்டுவருகிறது.";
"yoga_formation_dhana_yoga_128" = "வீனஸ் வலுவான கண்ணியத்துடன் 2 மற்றும் 11 வது வீடுகளுடன் இணைக்கப்பட்டுள்ளது.";

// [−] Dhatrutwa Yoga
"yoga_name_dhatrutwa_yoga" = "தத்ருத்வ யோகம்";
"yoga_outcome_dhatrutwa_yoga" = "உறவுகளை வளர்ப்பதிலும் குடும்ப பாசத்தை வெளிப்படுத்துவதிலும் உள்ள சவால்களைக் குறிக்கிறது.";
"yoga_formation_dhatrutwa_yoga" = "லக்னா அதிபதி மற்றும் நான்காம் வீட்டிற்கு குறிப்பிட்ட கிரக பாதிப்புகள்.";

// [+] Dhurdhura Yoga
"yoga_name_dhurdhura_yoga" = "துர்துர யோகம்";
"yoga_outcome_dhurdhura_yoga" = "தாராள மனப்பான்மை, செல்வம், போக்குவரத்து மற்றும் பரோபகார இயல்பு ஆகியவற்றை வழங்குகிறது.";
"yoga_formation_dhurdhura_yoga" = "சந்திரனில் இருந்து 2வது மற்றும் 12வது இடத்தில் உள்ள கிரகங்கள் (சூரியன்/ராகு/கேது தவிர).";

// [−] Dur Yoga
"yoga_name_dur_yoga" = "துர் யோகா";
"yoga_outcome_dur_yoga" = "தொழில் தொடர்பான நிதி சிக்கல்கள்; விகிதாசார வருமானத்திற்கு மாற்ற முயற்சி தோல்வியடைகிறது.";
"yoga_formation_dur_yoga" = "10ம் அதிபதி 6/8/12ல் ரத்து இல்லாமல்.";

// [−] Durmarana Yoga
"yoga_name_durmarana_yoga" = "துர்மரண யோகம்";
"yoga_outcome_durmarana_yoga" = "வாழ்க்கையின் இயற்கைக்கு மாறான அல்லது கடினமான முடிவைக் குறிக்கிறது; ஆன்மீக நடைமுறைகள் பாதுகாப்பை வழங்குகின்றன.";
"yoga_formation_durmarana_yoga" = "கேந்திரங்கள்/மராக்காக்களில் பல தீமைகள் பயனற்ற தலையீடு இல்லாமல்.";

// [−] Durmukha Yoga (168)
"yoga_name_durmukha_yoga_168" = "துர்முக யோகா (168)";
"yoga_outcome_durmukha_yoga_168" = "அழகற்ற முக அம்சங்கள் அல்லது பல் பிரச்சினைகள்; ஒப்பனை மற்றும் சுகாதார பராமரிப்பு பரிந்துரைக்கப்படுகிறது.";
"yoga_formation_durmukha_yoga_168" = "முகத் தோற்றத்தைப் பாதிக்கும் 2வது வீட்டில் உள்ள குறைபாடுகள் (வர். 1).";

// [−] Durmukha Yoga (169)
"yoga_name_durmukha_yoga_169" = "துர்முக யோகா (169)";
"yoga_outcome_durmukha_yoga_169" = "விரும்பத்தகாத தோற்றம் அல்லது நாள்பட்ட முக சுகாதார பிரச்சினைகள்.";
"yoga_formation_durmukha_yoga_169" = "சந்திரனும் 2ம் அதிபதியும் தீய சக்திகளால் பாதிக்கப்பட்டுள்ளனர் (வர். 2).";

// [+] Ekaputra Yoga
"yoga_name_ekaputra_yoga" = "ஏகபுத்திர யோகம்";
"yoga_outcome_ekaputra_yoga" = "விதிவிலக்காக அர்ப்பணிப்பு மற்றும் வெற்றிகரமான ஒரு குழந்தை; அளவை விட தரம்.";
"yoga_formation_ekaputra_yoga" = "குறிப்பிட்ட வரையறுக்கப்பட்ட கட்டமைப்புகளில் 5வது அதிபதி.";

// [+] Gaja Yoga
"yoga_name_gaja_yoga" = "கஜ யோகம்";
"yoga_outcome_gaja_yoga" = "மகத்தான செழிப்பு, பரோபகாரம் மற்றும் கண்ணியமான, யானை போன்ற அதிகாரம்.";
"yoga_formation_gaja_yoga" = "பலமான 9 மற்றும் 10 ஆம் அதிபதிகள் நன்மை தரும் அம்சங்களுடன்.";

// [+] Gajakesari Yoga
"yoga_name_gajakesari_yoga" = "கஜகேசரி யோகம்";
"yoga_outcome_gajakesari_yoga" = "புத்திசாலித்தனம், பேச்சுத்திறன், நீடித்த நற்பெயர் மற்றும் நல்லொழுக்கமுள்ள, செல்வந்த குணம் ஆகியவற்றை வழங்குகிறது.";
"yoga_formation_gajakesari_yoga" = "சந்திரனில் இருந்து ஒரு கேந்திரத்தில் (1/4/7/10) வியாழன்.";

// [−] Galakarna Yoga
"yoga_name_galakarna_yoga" = "கலகர்ண யோகம்";
"yoga_outcome_galakarna_yoga" = "செவித்திறன் குறைபாடு அல்லது காது தொடர்பான உடல்நலப் பிரச்சினைகள்; செவிப்புல கவனிப்பு தேவை.";
"yoga_formation_galakarna_yoga" = "புதனை பாதிக்கும் 3 மற்றும் 11 ஆம் வீடுகளில் உள்ள தோஷங்கள்.";

// [+] Gandharva Yoga
"yoga_name_gandharva_yoga" = "கந்தர்வ யோகம்";
"yoga_outcome_gandharva_yoga" = "பரலோக கலை திறமை; இசை, நடனம், கலை நிகழ்ச்சிகள் மற்றும் படைப்பு வெளிப்பாடு ஆகியவற்றில் சிறந்து விளங்குகிறது.";
"yoga_formation_gandharva_yoga" = "10ம் அதிபதி காம திரிகோணத்தில் சுக்கிரன் வலுவாகவும், சந்திரன் திரிகோணத்தில் இருக்கிறார்.";

// [+] Garuda Yoga
"yoga_name_garuda_yoga" = "கருட யோகம்";
"yoga_outcome_garuda_yoga" = "கழுகு போன்ற பார்வை; எதிரிகளை அழித்து போட்டிக்கு மேல் உயர்கிறது.";
"yoga_formation_garuda_yoga" = "வியாழன் மற்றும் 9 ஆம் அதிபதி நன்மையான அம்சங்களுடன் சந்திரன் வலுவாக உள்ளது.";

// [+] Gauri Yoga
"yoga_name_gauri_yoga" = "கௌரி யோகம்";
"yoga_outcome_gauri_yoga" = "அழகு, நல்லொழுக்கம், செம்மையான குணம், தாயின் அருள், இல்லற மகிழ்ச்சி ஆகியவற்றை அளிக்கும்.";
"yoga_formation_gauri_yoga" = "9ம் அதிபதியும் சந்திரனும் சொந்த/உயர்ந்த ராசிகளில் கேந்திரம்/திரிகோணத்தில்; அல்லது 10ம் அதிபதியான நவாம்ச அதிபதி லக்ன அதிபதியுடன் 10ல் உச்சம் பெற்றுள்ளார்.";

// [+] Go Yoga
"yoga_name_go_yoga" = "யோகா செல்லுங்கள்";
"yoga_outcome_go_yoga" = "விவசாயம், நிலம் அல்லது நிறுவனங்களை வளர்ப்பதன் மூலம் செழிப்பு.";
"yoga_formation_go_yoga" = "திரிகோணத்தில் வியாழன், நன்மை தரும் நவாம்சத்தில் லக்னாதிபதி.";

// [−] Gohanta Yoga
"yoga_name_gohanta_yoga" = "கோஹந்த யோகா";
"yoga_outcome_gohanta_yoga" = "விலங்குகள் மீதான கொடூரமான போக்குகள்; உயிரினங்களுக்கு எதிரான வன்முறை நடவடிக்கைகளின் கர்ம விளைவுகள்.";
"yoga_formation_gohanta_yoga" = "செவ்வாய் மற்றும் ராகு குறிப்பிட்ட வீடுகளை எந்த நன்மையும் இல்லாமல் பாதிக்கிறது.";

// [+] Gola Yoga
"yoga_name_gola_yoga" = "கோல யோகம்";
"yoga_outcome_gola_yoga" = "ஆன்மீக முழுமை மற்றும் அண்ட புரிதல்; ஒரு நபர் உலகளாவிய உண்மைகளை உணர்கிறார்.";
"yoga_formation_gola_yoga" = "கோள முழுமையை உருவாக்கும் குறிப்பிட்ட கிரக அமைப்பு.";

// [−] Grihanasa Yoga (191)
"yoga_name_grihanasa_yoga_191" = "கிரஹநாச யோகா (191)";
"yoga_outcome_grihanasa_yoga_191" = "துரதிர்ஷ்டவசமான நிகழ்வுகள் அல்லது சட்ட மோதல்கள் மூலம் சொத்து இழப்பு.";
"yoga_formation_grihanasa_yoga_191" = "4 வது அதிபதி துஸ்தானத்தில் தீங்கிழைத்தவர்களால் பாதிக்கப்பட்டார் (வர். 1).";

// [−] Grihanasa Yoga (192)
"yoga_name_grihanasa_yoga_192" = "கிரஹநாச யோகா (192)";
"yoga_outcome_grihanasa_yoga_192" = "சொத்து அழிவு அல்லது கட்டாய விற்பனை; வீட்டு உறுதியற்ற தன்மை.";
"yoga_formation_grihanasa_yoga_192" = "4ஆம் வீட்டில் உள்ள தோஷம், 4ஆம் அதிபதி வலுவிழந்தனர் (வர். 2).";

// [−] Guhyaroga Yoga
"yoga_name_guhyaroga_yoga" = "குஹ்யரோக யோகம்";
"yoga_outcome_guhyaroga_yoga" = "நெருக்கமான வாழ்க்கையை பாதிக்கும் தனியார் உடல்நலப் பிரச்சினைகளுக்கு எளிதில் பாதிக்கப்படுதல்; தடுப்பு பராமரிப்பு பரிந்துரைக்கப்படுகிறது.";
"yoga_formation_guhyaroga_yoga" = "சுக்கிரன், 7 மற்றும் 8 ஆம் வீடுகளுக்கு தோஷம்.";

// [+] Hamsa Yoga
"yoga_name_hamsa_yoga" = "ஹம்ச யோகா";
"yoga_outcome_hamsa_yoga" = "விதிவிலக்கான ஞானம், தார்மீக ஒருமைப்பாடு, ஆன்மீக நாட்டங்கள் மற்றும் சமூகத்தில் ஒரு மரியாதைக்குரிய நிலையை வழங்குகிறது.";
"yoga_formation_hamsa_yoga" = "வியாழன் ஒரு கேந்திரத்தில் (1/4/7/10) சொந்த ராசியில் (தனுசு/மீனம்) அல்லது உயர்நிலையில் (புற்றுநோய்).";

// [+] Harihara Brahma Yoga
"yoga_name_harihara_brahma_yoga" = "ஹரிஹர பிரம்ம யோகம்";
"yoga_outcome_harihara_brahma_yoga" = "பரிசுத்த திரித்துவத்தின் உச்ச தெய்வீக ஆசீர்வாதம்; விதிவிலக்கான ஆன்மீக அதிகாரம் மற்றும் அண்ட இணைப்பு.";
"yoga_formation_harihara_brahma_yoga" = "குறிப்பிட்ட வீடுகளில் 2 மற்றும் 12 ஆம் அதிபதிகளிடமிருந்தோ அல்லது 7 ஆம்/லக்னாதிபதிகளிடமிருந்தோ பலன்கள்.";

// [+] Harsha Yoga
"yoga_name_harsha_yoga" = "ஹர்ஷ யோகா";
"yoga_outcome_harsha_yoga" = "துன்பத்தை நன்மையாக மாற்றுகிறது; எதிரிகளை முறியடித்து வலுவாக வெளிப்படுகிறது.";
"yoga_formation_harsha_yoga" = "6, 8 அல்லது 12வது வீட்டில் 6வது அதிபதி (துஸ்தானத்தில் துஸ்தானம்).";

// [+] Indra Yoga
"yoga_name_indra_yoga" = "இந்திர யோகம்";
"yoga_outcome_indra_yoga" = "இந்திரனைப் போன்ற சக்தி; படைகள், அமைப்புகள் அல்லது பெரிய நிறுவனங்களுக்கு கட்டளையிடுகிறது.";
"yoga_formation_indra_yoga" = "பரஸ்பர கேந்திரங்களில் 5 மற்றும் 11 ம் அதிபதிகள் செவ்வாய் பலன்.";

// [−] Jada Yoga
"yoga_name_jada_yoga" = "ஜட யோகம்";
"yoga_outcome_jada_yoga" = "மன சோம்பல், மந்தமான தன்மை அல்லது மனச்சோர்வு போக்குகள்; சுறுசுறுப்பான வாழ்க்கை முறை மற்றும் தூண்டுதல் உதவி.";
"yoga_formation_jada_yoga" = "சனியின் பார்வையில் சந்திரன் எந்த நன்மையும் இல்லாமல்.";

// [−] Jananatpurvam Pitru Marana Yoga
"yoga_name_jananatpurvam_pitru_marana_yoga" = "ஜனனத்பூர்வம் பித்ரு மரண யோகம்";
"yoga_outcome_jananatpurvam_pitru_marana_yoga" = "தந்தைவழி செல்வாக்கின் ஆரம்ப இழப்பு; சிறு வயதிலிருந்தே தனிமனிதன் தன்னம்பிக்கையை வளர்த்துக் கொள்ள வேண்டும்.";
"yoga_formation_jananatpurvam_pitru_marana_yoga" = "ஆரம்பகால தந்தையின் இழப்பைக் குறிக்கும் குறிப்பிட்ட சூரிய பாதிப்புகள்.";

// [−] Jara Yoga
"yoga_name_jara_yoga" = "ஜர யோகம்";
"yoga_outcome_jara_yoga" = "முன்கூட்டிய முதுமை, முதுமைக் கஷ்டங்கள் அல்லது பிற்காலத்தில் உயிர்ச்சக்தி குறைதல்.";
"yoga_formation_jara_yoga" = "லக்னாதிபதியும், 7ம் அதிபதியும் சனியின் தாக்கத்தால் பாதிக்கப்பட்டுள்ளனர்.";

// [−] Jarajaputra Yoga
"yoga_name_jarajaputra_yoga" = "ஜராஜபுத்திர யோகம்";
"yoga_outcome_jarajaputra_yoga" = "வாழ்க்கையில் மிகவும் தாமதமாகப் பிறந்த குழந்தைகள்; தொடர்புடைய சவால்களுடன் தாமதமான பெற்றோர்.";
"yoga_formation_jarajaputra_yoga" = "5 ஆம் அதிபதி சனியுடன் தாமதமாக செயல்படும் தசாவுடன் இணைக்கப்பட்டுள்ளது.";

// [+] Jaya Yoga
"yoga_name_jaya_yoga" = "ஜெய யோகம்";
"yoga_outcome_jaya_yoga" = "போட்டியாளர்கள் மீது வெற்றி; போட்டி மற்றும் சட்ட விஷயங்களில் வெற்றி.";
"yoga_formation_jaya_yoga" = "6ம் அதிபதி வலுவிழந்தவர், லக்னாதிபதி வலுப்பெற்றவர்.";

// [+] Kahala Yoga
"yoga_name_kahala_yoga" = "கஹல யோகம்";
"yoga_outcome_kahala_yoga" = "சுத்த மன உறுதி மூலம் தைரியமான உறுதியும் அதிகாரமும்.";
"yoga_formation_kahala_yoga" = "4ம் அதிபதியும் வியாழனும் பரஸ்பர கேந்திரங்களில் லக்னாதிபதி வலுவாக உள்ளனர்.";

// [+] Kalanidhi Yoga
"yoga_name_kalanidhi_yoga" = "கலாநிதி யோகம்";
"yoga_outcome_kalanidhi_yoga" = "கலை மற்றும் கற்றலின் பொக்கிஷம்; நுண்கலைகள், இசை மற்றும் கலாச்சார சாதனைகளில் தேர்ச்சி.";
"yoga_formation_kalanidhi_yoga" = "வியாழன் 2வது அல்லது 5வது பார்வையில் புதன் மற்றும் சுக்கிரன்.";

// [+] Kalanirdesat Putra Yoga (227)
"yoga_name_kalanirdesat_putra_yoga_227" = "கலநிர்தேசத் புத்ர யோகா (227)";
"yoga_outcome_kalanirdesat_putra_yoga_227" = "குழந்தைகள் ஒரு குறிப்பிட்ட, ஜோதிட ரீதியாக சாதகமான காலத்திற்கு வருகிறார்கள்.";
"yoga_formation_kalanirdesat_putra_yoga_227" = "5வது அதிபதி குறிப்பிட்ட தசா நேரத்தில் செயல்படுத்தப்பட்டவர் (வர். 1).";

// [+] Kalanirdesat Putra Yoga (228)
"yoga_name_kalanirdesat_putra_yoga_228" = "கலநிர்தேசத் புத்ர யோகா (228)";
"yoga_outcome_kalanirdesat_putra_yoga_228" = "பிரசவ நேரம் கிரக காலங்களுடன் இணைக்கப்பட்டுள்ளது; சாதகமான தருணங்களின் போது குழந்தைகள்.";
"yoga_formation_kalanirdesat_putra_yoga_228" = "5வது அதிபதி குறிப்பிட்ட தசா நேரத்தில் செயல்படுத்தப்பட்டவர் (வர். 2).";

// [−] Kalanirdesat Putranasa Yoga (229)
"yoga_name_kalanirdesat_putranasa_yoga_229" = "கலநிர்தேசத் புத்ராநாச யோகம் (229)";
"yoga_outcome_kalanirdesat_putranasa_yoga_229" = "குறிப்பிட்ட பாதகமான கிரக காலத்தில் குழந்தை இழப்பு.";
"yoga_formation_kalanirdesat_putranasa_yoga_229" = "5வது அதிபதி குறிப்பிட்ட தீய தசாவின் போது பாதிக்கப்பட்டார் (வர். 1).";

// [−] Kalanirdesat Putranasa Yoga (230)
"yoga_name_kalanirdesat_putranasa_yoga_230" = "கலநிர்தேசத் புத்ராநாச யோகம் (230)";
"yoga_outcome_kalanirdesat_putranasa_yoga_230" = "குழந்தை தொடர்பான துக்கம் தவறான கிரக காலங்களின் நேரத்துடன் இணைக்கப்பட்டுள்ளது.";
"yoga_formation_kalanirdesat_putranasa_yoga_230" = "5வது அதிபதி குறிப்பிட்ட தீய தசாவின் போது பாதிக்கப்பட்டார் (வர். 2).";

// [+] Kalatramooladhana Yoga
"yoga_name_kalatramooladhana_yoga" = "களத்திரமூலதன யோகம்";
"yoga_outcome_kalatramooladhana_yoga" = "திருமணம், வணிக கூட்டாண்மை அல்லது மனைவியின் வருவாய் மூலம் செல்வம்.";
"yoga_formation_kalatramooladhana_yoga" = "7ஆம் அதிபதி 2ஆம் மற்றும் 11ஆம் வீடுகளுடன் இணைந்துள்ளார்.";

// [−] Kalatrashanda Yoga
"yoga_name_kalatrashanda_yoga" = "கலத்ரஷண்டா யோகம்";
"yoga_outcome_kalatrashanda_yoga" = "பாலியல் செயலிழப்பு அல்லது இனப்பெருக்க சவால்கள்; மருத்துவ ஆலோசனை பரிந்துரைக்கப்படுகிறது.";
"yoga_formation_kalatrashanda_yoga" = "சுக்கிரன் வலுவிழந்து 7ம் அதிபதியுடன் கடுமையாகப் பாதிக்கப்பட்டுள்ளார்.";

// [−] Kapata Yoga (202)
"yoga_name_kapata_yoga_202" = "கபட யோகா (202)";
"yoga_outcome_kapata_yoga_202" = "தந்திரமான நடத்தைக்கு விருப்பத்தை பரிந்துரைக்கிறது; வெளிப்படைத்தன்மையை வளர்க்க அறிவுறுத்தப்படுகிறது.";
"yoga_formation_kapata_yoga_202" = "ஏமாற்றும் போக்குகளைக் குறிக்கும் குறிப்பிட்ட தீங்கான சேர்க்கைகள் (var. 1).";

// [−] Kapata Yoga (203)
"yoga_name_kapata_yoga_203" = "கபட யோகா (203)";
"yoga_outcome_kapata_yoga_203" = "கையாளுதல் நடத்தைக்கான சாத்தியத்தை குறிக்கிறது; தார்மீக ஒழுக்கம் இதைத் தணிக்க முடியும்.";
"yoga_formation_kapata_yoga_203" = "ஏமாற்றும் போக்குகளைக் குறிக்கும் குறிப்பிட்ட தீங்கான சேர்க்கைகள் (var. 2).";

// [−] Kapata Yoga (204)
"yoga_name_kapata_yoga_204" = "கபட யோகா (204)";
"yoga_outcome_kapata_yoga_204" = "இரட்டிப்புக்கான நாட்டத்தை பரிந்துரைக்கிறது; ஒருமைப்பாடு நடைமுறைகள் மற்றும் சுய விழிப்புணர்வு பரிந்துரைக்கப்படுகிறது.";
"yoga_formation_kapata_yoga_204" = "ஏமாற்றும் போக்குகளைக் குறிக்கும் குறிப்பிட்ட தீங்கான சேர்க்கைகள் (var. 3).";

// [−] Karascheda Yoga
"yoga_name_karascheda_yoga" = "கரசேத யோகா";
"yoga_outcome_karascheda_yoga" = "கை/கை காயங்கள் அல்லது கைகால்கள் சம்பந்தப்பட்ட அறுவை சிகிச்சை முறைகள் ஏற்படும் அபாயம்.";
"yoga_formation_karascheda_yoga" = "செவ்வாய் மற்றும் சனி 3 ஆம் வீட்டையும் லக்னத்தையும் கடுமையாக பாதிக்கிறது.";

// [−] Kemadruma Yoga
"yoga_name_kemadruma_yoga" = "கேமத்ரும யோகம்";
"yoga_outcome_kemadruma_yoga" = "உள்ளார்ந்த திறன்கள் இருந்தபோதிலும் உணர்ச்சித் தனிமை, நிதி ஏற்ற இறக்கங்கள் மற்றும் போராட்டங்களைக் குறிக்கிறது.";
"yoga_formation_kemadruma_yoga" = "சந்திரனில் இருந்து 2வது அல்லது 12வது இடத்தில் கிரகங்கள் இல்லை (சந்திரன் தனிமைப்படுத்தப்பட்டது).";

// [−] Khalawata Yoga
"yoga_name_khalawata_yoga" = "கலவாத யோகம்";
"yoga_outcome_khalawata_yoga" = "கடுமையான அல்லது கலாச்சாரமற்ற நடத்தையை பரிந்துரைக்கிறது; சமூக தொடர்புகளில் செம்மை தேவை.";
"yoga_formation_khalawata_yoga" = "லக்னாதிபதி சனியின் அம்சம் அல்லது சேர்க்கையுடன் செயல்படுகிறார்.";

// [−] Krisanga Yoga
"yoga_name_krisanga_yoga" = "கிருசங்க யோகம்";
"yoga_outcome_krisanga_yoga" = "மெலிந்த, மெலிந்த உடலமைப்பு; எடை அதிகரிப்பது அல்லது உயிர்ச்சக்தியை பராமரிப்பதில் சிரமம்.";
"yoga_formation_krisanga_yoga" = "வியாழன் அம்சம் இல்லாத லக்னத்தையும் சந்திரனையும் பாதிக்கும் சனி.";

// [−] Kshayaroga Yoga
"yoga_name_kshayaroga_yoga" = "க்ஷயரோக யோகம்";
"yoga_outcome_kshayaroga_yoga" = "வீணான நோய்கள் அல்லது நுகர்வுக்கான வாய்ப்பு; சுவாச சுகாதார கண்காணிப்பு அறிவுறுத்தப்படுகிறது.";
"yoga_formation_kshayaroga_yoga" = "சந்திரன் மற்றும் புதனுடன் லக்னம்/6ல் உள்ள தோஷங்கள் வலுவிழந்தன.";

// [+] Kurma Yoga
"yoga_name_kurma_yoga" = "கூர்ம யோகம்";
"yoga_outcome_kurma_yoga" = "ஆமை போன்ற பொறுமையும் நிலைத்து நிற்கும் ஞானமும்; பிரபலமான, நல்லொழுக்கமுள்ள மற்றும் பிறருக்கு ஆதரவான.";
"yoga_formation_kurma_yoga" = "5வது/6வது/7வது குறிப்பிட்ட கண்ணிய நிலைமைகளுடன் பலன்கள்.";

// [−] Kushtarog Yoga (268)
"yoga_name_kushtarog_yoga_268" = "குஷ்டரோக் யோகா (268)";
"yoga_outcome_kushtarog_yoga_268" = "கடுமையான தோல் நோய்களுக்கு பாதிப்பு; தோல் கண்காணிப்பு அவசியம்.";
"yoga_formation_kushtarog_yoga_268" = "தோல் வீடுகளை பாதிக்கும் குறிப்பிட்ட தவறான சேர்க்கைகள் (var. 1).";

// [−] Kushtarog Yoga (269)
"yoga_name_kushtarog_yoga_269" = "குஷ்டரோக் யோகா (269)";
"yoga_outcome_kushtarog_yoga_269" = "நீடித்த சிகிச்சை மற்றும் கவனிப்பு தேவைப்படும் நாள்பட்ட தோல் பாதிப்புகள்.";
"yoga_formation_kushtarog_yoga_269" = "தோல் வீடுகளை பாதிக்கும் குறிப்பிட்ட தவறான சேர்க்கைகள் (var. 2).";

// [+] Kusuma Yoga
"yoga_name_kusuma_yoga" = "குசும யோகம்";
"yoga_outcome_kusuma_yoga" = "தூய, மலர் போன்ற தன்மை; தனிநபர் கருணை, அழகு மற்றும் ஆன்மீக தூய்மை ஆகியவற்றை வெளிப்படுத்துகிறார்.";
"yoga_formation_kusuma_yoga" = "லக்னத்தில் சுக்கிரன், கேந்திரத்தில் சந்திரன், திரிகோணத்தில் வியாழன் மற்றும் சனி.";

// [+] Lakshmi Yoga
"yoga_name_lakshmi_yoga" = "லக்ஷ்மி யோகம்";
"yoga_outcome_lakshmi_yoga" = "லட்சுமி தேவியால் ஆசீர்வதிக்கப்பட்ட ஏராளமான செல்வம், தெய்வீக அருள் மற்றும் அனைத்து சுற்று செழிப்பையும் வழங்குகிறது.";
"yoga_formation_lakshmi_yoga" = "சொந்த/உயர்ந்த லக்னத்தில் கேந்திரத்தில் 9ம் அதிபதி, லக்னாதிபதி பலம்.";

// [+] Madhya Vayasi Dhana Yoga
"yoga_name_madhya_vayasi_dhana_yoga" = "மத்திய வயசி தன யோகம்";
"yoga_outcome_madhya_vayasi_dhana_yoga" = "வாழ்க்கையின் நடுப்பகுதியில் (30-55 ஆண்டுகள்) செல்வம் குவிவதைக் குறிக்கிறது.";
"yoga_formation_madhya_vayasi_dhana_yoga" = "நடுத்தர வயது தசா காலங்களில் செல்வத்தை குறிப்பவர்கள் செயல்படுகிறார்கள்.";

// [+] Mahabhagya Yoga
"yoga_name_mahabhagya_yoga" = "மஹாபாக்ய யோகம்";
"yoga_outcome_mahabhagya_yoga" = "விதிவிலக்கான அதிர்ஷ்டம் மற்றும் பெரிய விதி; தனிநபர் குறிப்பிடத்தக்க வகையில் ஆசீர்வதிக்கப்பட்ட வாழ்க்கையை நடத்துகிறார்.";
"yoga_formation_mahabhagya_yoga" = "ஆண்: பிறந்த நாள், சூரியன்/சந்திரன்/லக்னம் ஒற்றைப்படை ராசிகளில். பெண்: இரவில் பிறப்பு, அனைத்தும் சம அறிகுறிகளில்.";

// [+] Makuta Yoga
"yoga_name_makuta_yoga" = "மகுட யோகம்";
"yoga_outcome_makuta_yoga" = "கிரீடம் போன்ற அதிகாரம்; நிறுவனங்களுக்கு தலைமை தாங்குகிறார் அல்லது தனித்துவத்துடன் ஆட்சி செய்கிறார்.";
"yoga_formation_makuta_yoga" = "வியாழன் 9/10ல் லக்னாதிபதியுடன் உச்சம் பெற்றுள்ளார்.";

// [+] Malavya Yoga
"yoga_name_malavya_yoga" = "மாளவ்ய யோகம்";
"yoga_outcome_malavya_yoga" = "கலைத் திறமைகள், பொருள் செழிப்பு, சுத்திகரிக்கப்பட்ட சுவைகள், வலுவான குடும்பப் பிணைப்புகள் மற்றும் படைப்புத் துறைகளில் வெற்றி ஆகியவற்றை வழங்குகிறது.";
"yoga_formation_malavya_yoga" = "ஒரு கேந்திரத்தில் சுக்கிரன் (1/4/7/10) சொந்த ராசியில் (ரிஷபம்/துலாம்) அல்லது உயர்வு (மீனம்).";

// [+] Malika Yoga
"yoga_name_malika_yoga" = "மாலிகா யோகா";
"yoga_outcome_malika_yoga" = "கிரக பாக்கியத்தின் மாலை; விளைவுகள் சங்கிலியின் தொடக்க வீட்டைப் பொறுத்தது.";
"yoga_formation_malika_yoga" = "தொடர்ச்சியான வீடுகளில் ஏழு அல்லது அதற்கு மேற்பட்ட கிரகங்கள் மாலை வடிவத்தை உருவாக்குகின்றன.";

// [+] Marud Yoga
"yoga_name_marud_yoga" = "மருட் யோகம்";
"yoga_outcome_marud_yoga" = "கற்றலில் காற்று போன்ற வேகம்; பல்வேறு துறைகளில் அறிவை விரைவாக உள்வாங்குகிறது.";
"yoga_formation_marud_yoga" = "சுக்கிரனிலிருந்து கேந்திரத்தில் வியாழன், திரிகோணத்தில் சந்திரன், 5ல் பலன்கள்.";

// [−] Matibhramana Yoga (291)
"yoga_name_matibhramana_yoga_291" = "மதிபிராமண யோகா (291)";
"yoga_outcome_matibhramana_yoga_291" = "மன குழப்பம் அல்லது ஒழுங்கற்ற சிந்தனை; மன ஒழுக்கம் மற்றும் ஸ்திரத்தன்மை நடைமுறைகள் அறிவுறுத்தப்படுகின்றன.";
"yoga_formation_matibhramana_yoga_291" = "குறிப்பிட்ட நிலைகளில் ராகுவுடன் சனியால் பாதிக்கப்பட்ட சந்திரன் (வர். 1).";

// [−] Matibhramana Yoga (292)
"yoga_name_matibhramana_yoga_292" = "மதிபிராமனா யோகா (292)";
"yoga_outcome_matibhramana_yoga_292" = "மனக்கிளர்ச்சி சிந்தனை மற்றும் மோசமான தீர்ப்பு; கோப மேலாண்மை மற்றும் பிரதிபலிப்பு நடைமுறைகள் உதவுகின்றன.";
"yoga_formation_matibhramana_yoga_292" = "குறிப்பிட்ட நிலைகளில் ராகுவுடன் செவ்வாயால் பாதிக்கப்பட்ட சந்திரன் (வர். 2).";

// [−] Matibhramana Yoga (293)
"yoga_name_matibhramana_yoga_293" = "மதிபிராமனா யோகா (293)";
"yoga_outcome_matibhramana_yoga_293" = "தொடர்பு குறைபாடுகள் அல்லது கற்றல் சிரமங்கள்; ஆரம்ப தலையீடு பரிந்துரைக்கப்படுகிறது.";
"yoga_formation_matibhramana_yoga_293" = "பாதகத்தால் பாதிக்கப்பட்ட பாதரசம், நன்மையான அம்சங்கள் இல்லை (வர். 3).";

// [−] Matibhramana Yoga (294)
"yoga_name_matibhramana_yoga_294" = "மதிபிராமனா யோகா (294)";
"yoga_outcome_matibhramana_yoga_294" = "கடுமையான மனநல சவால்களுக்கான சாத்தியம்; தொழில்முறை கவனிப்பு அவசியம்.";
"yoga_formation_matibhramana_yoga_294" = "5 ஆம் அதிபதி சந்திரனில் உள்ள தீங்கான அம்சங்களுடன் வலுவிழந்தார் (வர். 4).";

// [−] Matru Satrutwa Yoga
"yoga_name_matru_satrutwa_yoga" = "மாத்ரு சத்ருத்வ யோகம்";
"yoga_outcome_matru_satrutwa_yoga" = "தாயுடன் பதற்றத்தை பரிந்துரைக்கிறது; தாய்வழி உறவுக்கு நனவான சிகிச்சை தேவைப்படுகிறது.";
"yoga_formation_matru_satrutwa_yoga" = "4 வது வீடு மற்றும் சந்திரன் மீதான தவறான தாக்கங்கள் விரோத இயக்கவியலை உருவாக்குகின்றன.";

// [+] Matru Sneha Yoga
"yoga_name_matru_sneha_yoga" = "மாத்ரு சிநேக யோகம்";
"yoga_outcome_matru_sneha_yoga" = "தாயுடன் ஆழமான, அன்பான உறவையும், அசைக்க முடியாத தாய்வழி ஆதரவையும் குறிக்கிறது.";
"yoga_formation_matru_sneha_yoga" = "4 ஆம் அதிபதி தாய்வழி குறிகாட்டிகளில் நன்மையான தாக்கங்களுடன் நல்ல இடத்தில் இருக்கிறார்.";

// [+] Matrudeerghayur Yoga (196)
"yoga_name_matrudeerghayur_yoga_196" = "மாத்ருதிர்காயூர் யோகா (196)";
"yoga_outcome_matrudeerghayur_yoga_196" = "தாய்க்கு நீண்ட ஆயுள்; ஒரு நபர் நீட்டிக்கப்பட்ட தாய்வழி இருப்பு மற்றும் ஆதரவைப் பெறுகிறார்.";
"yoga_formation_matrudeerghayur_yoga_196" = "4ம் அதிபதி பலன் பலன், சந்திரன் நல்ல இடம் (வர். 1).";

// [+] Matrudeerghayur Yoga (197)
"yoga_name_matrudeerghayur_yoga_197" = "மாத்ருதிர்காயூர் யோகா (197)";
"yoga_outcome_matrudeerghayur_yoga_197" = "தாய்வழி நீண்ட ஆயுளும், குடும்பச் சூழலும் உறுதி செய்யப்பட்டது.";
"yoga_formation_matrudeerghayur_yoga_197" = "வீனஸ் மற்றும் சந்திரன் ஆதரவு, 4 வது வீடு பாதுகாக்கப்படுகிறது (வர். 2).";

// [−] Matrugami Yoga
"yoga_name_matrugami_yoga" = "மாத்ருகாமி யோகம்";
"yoga_outcome_matrugami_yoga" = "தாய்வழி உறவுகளில் ஆரோக்கியமற்ற அல்லது பொருத்தமற்ற இணைப்பு முறைகள்.";
"yoga_formation_matrugami_yoga" = "குறிப்பிட்ட தடை சேர்க்கைகளில் சுக்கிரனும் 4ம் அதிபதியும்.";

// [+] Matrumooladhana Yoga
"yoga_name_matrumooladhana_yoga" = "மாத்ருமூலதன யோகம்";
"yoga_outcome_matrumooladhana_yoga" = "தாய்வழி பரம்பரை, ரியல் எஸ்டேட் அல்லது தாயக இணைப்புகள் மூலம் செல்வம்.";
"yoga_formation_matrumooladhana_yoga" = "4ஆம் அதிபதி 2ஆம் மற்றும் 11ஆம் தேதியுடன் அனுகூல ஆதரவுடன் இணைந்துள்ளார்.";

// [−] Matrunasa Yoga (198)
"yoga_name_matrunasa_yoga_198" = "மாத்ருநாச யோகா (198)";
"yoga_outcome_matrunasa_yoga_198" = "தாயின் ஆரம்ப இழப்பு அல்லது கடுமையான தாய்வழி சுகாதார நெருக்கடி.";
"yoga_formation_matrunasa_yoga_198" = "4வது அதிபதியும் சந்திரனும் தீய சக்திகளால் கடுமையாக பாதிக்கப்பட்டுள்ளனர் (வர். 1).";

// [−] Matrunasa Yoga (199)
"yoga_name_matrunasa_yoga_199" = "மாத்ருநாச யோகா (199)";
"yoga_outcome_matrunasa_yoga_199" = "தாய் உயிருக்கு ஆபத்தான சூழ்நிலைகளை எதிர்கொள்கிறார்; ஆபத்தில் தாய் நலன்.";
"yoga_formation_matrunasa_yoga_199" = "செவ்வாய் மற்றும் சனி 4 வது வீட்டையும் சந்திரனையும் பாதிக்கிறது (வர். 2).";

// [−] Matrusapa Sutakshaya Yoga
"yoga_name_matrusapa_sutakshaya_yoga" = "மாத்ருசப சுதக்ஷய யோகம்";
"yoga_outcome_matrusapa_sutakshaya_yoga" = "சந்ததியைப் பாதிக்கும் தாயின் சாபம்; தீர்க்கப்படாத தாய்வழி கர்மா குழந்தைகளை பாதிக்கிறது.";
"yoga_formation_matrusapa_sutakshaya_yoga" = "சந்திரன் 5 ஆம் அதிபதியுடன் தோஷ சேர்க்கைகளில் பாதிக்கப்பட்டுள்ளார்.";

// [+] Matsya Yoga
"yoga_name_matsya_yoga" = "மத்ஸ்ய யோகம்";
"yoga_outcome_matsya_yoga" = "ஆழமான, கடல் போன்ற ஞானம் மற்றும் ஆன்மீக அறிவு; கற்றறிந்த, இரக்கமுள்ள, பரந்த பயணம்.";
"yoga_formation_matsya_yoga" = "லக்னம்/9ல் தோஷம், 5ல் பலன்கள், 4ல்/8ல் கலவை.";

// [−] Mooka Yoga
"yoga_name_mooka_yoga" = "முக யோகம்";
"yoga_outcome_mooka_yoga" = "பேச்சு குறைபாடுகள் அல்லது தகவல் தொடர்பு சிக்கல்கள்; சிகிச்சை மற்றும் வைத்தியம் உதவலாம்.";
"yoga_formation_mooka_yoga" = "புதன் கடுமையாக பாதிக்கப்பட்டு, 2ம் அதிபதி தோஷத்தால் பலவீனமடைந்தார்.";

// [+] Mridanga Yoga
"yoga_name_mridanga_yoga" = "மிருதங்க யோகம்";
"yoga_outcome_mridanga_yoga" = "சம்பிரதாயமான டிரம் போன்ற உச்ச அரச நிலை; புகழ் நாடு முழுவதும் ஒலிக்கிறது.";
"yoga_formation_mridanga_yoga" = "லக்னாதிபதி வலிமையானவர், கேந்திரங்கள்/திரிகோணங்களில் உள்ள அனைத்து கிரகங்களும்.";

// [+] Ardha Chandra Yoga
"yoga_name_nabhasa_ardha_chandra" = "அர்த்த சந்திர யோகம்";
"yoga_outcome_nabhasa_ardha_chandra" = "அரை நிலவு உருவாக்கம்; இராணுவத் தளபதி, உடல் ரீதியாக வலிமையானவர், கவர்ச்சிகரமானவர் மற்றும் செல்வந்தர்.";
"yoga_formation_nabhasa_ardha_chandra" = "ஒரு கேந்திரத்தில் இருந்து அடுத்தடுத்து ஏழு வீடுகளில் உள்ள அனைத்து கிரகங்களும்.";

// [+] Chandra Yoga (Nabhasa)
"yoga_name_nabhasa_chandra" = "சந்திர யோகம் (நபசா)";
"yoga_outcome_nabhasa_chandra" = "சந்திர உருவாக்கம்; இனிமையான தோற்றம், கட்டளையிடும் அந்தஸ்து, அரச ஆலோசகர்கள்.";
"yoga_formation_nabhasa_chandra" = "ராசியின் மேல் பாதியில் உள்ள அனைத்து கிரகங்களும் (7-12 வீடுகள்).";

// [+] Chapa Yoga (Nabhasa)
"yoga_name_nabhasa_chapa" = "சாப யோகா (நபசா)";
"yoga_outcome_nabhasa_chapa" = "வில் உருவாக்கம்; உண்மையுள்ள, புதையலைக் காக்கிறது, ஆரம்ப மற்றும் பிற்பகுதியில் மகிழ்ச்சி.";
"yoga_formation_nabhasa_chapa" = "10-4 வீடுகளில் உள்ள அனைத்து கிரகங்களும் (10 முதல் 4 வது இடைவெளி).";

// [+] Chhatra Yoga
"yoga_name_nabhasa_chhatra" = "சத்ர யோகம்";
"yoga_outcome_nabhasa_chhatra" = "குடை உருவாக்கம்; பிறரைக் காப்பவர், அனைவருக்கும் உதவுபவர், வசதியான முதுமை.";
"yoga_formation_nabhasa_chhatra" = "7-1 வீடுகளில் உள்ள அனைத்து கிரகங்களும் (7வது முதல் 1வது இடைவெளி).";

// [+] Damini Yoga
"yoga_name_nabhasa_damini" = "தாமினி யோகம்";
"yoga_outcome_nabhasa_damini" = "மின்னல் உருவாக்கம்; தாராள மனப்பான்மை, உதவி, செல்வம் மற்றும் பரோபகார இயல்பு.";
"yoga_formation_nabhasa_damini" = "ஆறு அடுத்தடுத்த வீடுகளில் அனைத்து கிரகங்களும்.";

// [+] Danda Yoga
"yoga_name_nabhasa_danda" = "தண்ட யோகா";
"yoga_outcome_nabhasa_danda" = "பணியாளர் உருவாக்கம்; குடும்ப இழப்பு அல்லது தனிமைப்படுத்தல்; சேவை சார்ந்த வாழ்க்கை.";
"yoga_formation_nabhasa_danda" = "10ம் தேதி முதல் தொடர்ந்து நான்கு வீடுகளில் கிரகங்கள்.";

// [+] Gada Yoga
"yoga_name_nabhasa_gada" = "கட யோகம்";
"yoga_outcome_nabhasa_gada" = "தந்திரம் போன்ற வலிமை; சடங்குகள், மத நடவடிக்கைகள் அல்லது பாரம்பரிய நோக்கங்கள் மூலம் செல்வம்.";
"yoga_formation_nabhasa_gada" = "அடுத்தடுத்து இரண்டு கேந்திர வீடுகளில் கிரகங்கள்.";

// [+] Gola Yoga (Nabhasa)
"yoga_name_nabhasa_gola" = "கோல யோகா (நபசா)";
"yoga_outcome_nabhasa_gola" = "கோள உருவாக்கம்; ஏழை, அழுக்கு, அறியாமை, ஆனால் வலிமையான மற்றும் அலையும் இயல்பு.";
"yoga_formation_nabhasa_gola" = "அனைத்து கிரகங்களும் ஒரே வீட்டில்.";

// [+] Hala Yoga
"yoga_name_nabhasa_hala" = "ஹல யோகா";
"yoga_outcome_nabhasa_hala" = "விவசாய செழிப்பு; நடுத்தர வர்க்க வசதிகளுடன் கடினமாக உழைக்கும் இயல்பு.";
"yoga_formation_nabhasa_hala" = "கேந்திரங்களைத் தவிர மற்ற வீடுகளில் உள்ள கிரகங்கள், கலப்பை வடிவத்தை உருவாக்குகின்றன.";

// [+] Ishu Yoga
"yoga_name_nabhasa_ishu" = "ஈஷு யோகம்";
"yoga_outcome_nabhasa_ishu" = "அம்பு உருவாக்கம்; இராணுவம், பொலிஸ் அல்லது சிறை நிர்வாகத்துடன் இணைக்கப்பட்டுள்ளது.";
"yoga_formation_nabhasa_ishu" = "4ம் தேதி முதல் தொடர்ந்து நான்கு வீடுகளில் கிரகங்கள்.";

// [+] Kamala Yoga
"yoga_name_nabhasa_kamala" = "கமலா யோகம்";
"yoga_outcome_nabhasa_kamala" = "தாமரை உருவாக்கம்; நீடித்த புகழ், நல்லொழுக்க வாழ்வு, நூறு ஆண்டுகள் செழிப்பு.";
"yoga_formation_nabhasa_kamala" = "நான்கு கேந்திர வீடுகளில் உள்ள அனைத்து கிரகங்களும் (1/4/7/10).";

// [+] Kedara Yoga
"yoga_name_nabhasa_kedara" = "கேதார யோகம்";
"yoga_outcome_nabhasa_kedara" = "புல உருவாக்கம்; விவசாயச் செல்வம், பலருக்கு உதவும், உண்மைப் பண்பு.";
"yoga_formation_nabhasa_kedara" = "ஐந்து அடுத்தடுத்த வீடுகளில் அனைத்து கிரகங்களும்.";

// [+] Kuta Yoga
"yoga_name_nabhasa_kuta" = "குட யோகா";
"yoga_outcome_nabhasa_kuta" = "கோட்டை உருவாக்கம்; பொய்யர் அல்லது இராஜதந்திரி, சிறைகள் அல்லது சிறைப் பாத்திரங்களுடன் இணைக்கப்பட்டவர்.";
"yoga_formation_nabhasa_kuta" = "4-10 வீடுகளில் உள்ள அனைத்து கிரகங்களும்.";

// [+] Mala Yoga
"yoga_name_nabhasa_mala" = "மாலா யோகா";
"yoga_outcome_nabhasa_mala" = "மாலை உருவாக்கம்; வாகனங்கள், சொத்துக்கள் மற்றும் நிலையான மகிழ்ச்சியுடன் வசதியான வாழ்க்கை.";
"yoga_formation_nabhasa_mala" = "மூன்று தொடர்ச்சியான திரிகோணங்களில் உள்ள கிரகங்கள் (1-5-9, 2-6-10, அல்லது 3-7-11).";

// [+] Musala Yoga
"yoga_name_nabhasa_musala" = "முசல யோகம்";
"yoga_outcome_nabhasa_musala" = "உறுதியான உறுதி, புகழ் மற்றும் செல்வம்; நிலையான, உறுதியான தன்மை.";
"yoga_formation_nabhasa_musala" = "நிலையான அறிகுறிகளில் உள்ள அனைத்து கிரகங்களும் (டாரஸ், ​​சிம்மம், விருச்சிகம், கும்பம்).";

// [+] Nala Yoga
"yoga_name_nabhasa_nala" = "நள யோகம்";
"yoga_outcome_nabhasa_nala" = "பல்துறை, பல துறைகளில் கைதேர்ந்தவர்; ஏற்ற இறக்கத்துடன் கூடிய அழகான தோற்றம்.";
"yoga_formation_nabhasa_nala" = "இரட்டை ராசிகளில் உள்ள அனைத்து கிரகங்களும் (மிதுனம், கன்னி, தனுசு, மீனம்).";

// [+] Nauka Yoga
"yoga_name_nabhasa_nauka" = "நௌக யோகம்";
"yoga_outcome_nabhasa_nauka" = "படகு உருவாக்கம்; நீர் தொடர்பான முயற்சிகள் மூலம் செல்வம், கடல் மீது புகழ்.";
"yoga_formation_nabhasa_nauka" = "1-7 வீடுகளில் உள்ள அனைத்து கிரகங்களும் (ராசியின் ஒரு பாதி).";

// [−] Pasa Yoga
"yoga_name_nabhasa_pasa" = "பாச யோகம்";
"yoga_outcome_nabhasa_pasa" = "கயிறு உருவாக்கம்; சிரமங்களில் சிக்கி, சிறையில் அடைக்கப்பட்ட, அல்லது வேலைக்காரன் போன்ற இருப்பு.";
"yoga_formation_nabhasa_pasa" = "குறிப்பிட்ட பிணைப்பு வடிவங்களில் மட்டுமே கிரகங்கள்.";

// [+] Rajju Yoga
"yoga_name_nabhasa_rajju" = "ரஜ்ஜு யோகா";
"yoga_outcome_nabhasa_rajju" = "பயண காதல், அலையும் இயல்பு; இயக்கம் மற்றும் தகவமைப்பு மூலம் வெற்றி.";
"yoga_formation_nabhasa_rajju" = "அசையும் ராசிகளில் உள்ள அனைத்து கிரகங்களும் (மேஷம், கடகம், துலாம், மகரம்).";

// [+] Samudra Yoga
"yoga_name_nabhasa_samudra" = "சமுத்திர யோகம்";
"yoga_outcome_nabhasa_samudra" = "பெருங்கடல் உருவாக்கம்; செல்வம், பல இன்பங்கள், இன்பத்தில் அரசனுக்குச் சமம்.";
"yoga_formation_nabhasa_samudra" = "அனைத்து கேந்திரா குழுக்களிலும் கிரகங்கள் சமமாக விநியோகிக்கப்படுகின்றன.";

// [−] Sarpa Yoga
"yoga_name_nabhasa_sarpa" = "சர்ப்ப யோகம்";
"yoga_outcome_nabhasa_sarpa" = "துன்பம், வறுமை, பாம்பு போன்ற துன்பம்; பிறரைச் சார்ந்து வாழ்வாதாரம்.";
"yoga_formation_nabhasa_sarpa" = "கார்டினல் வீடுகளில் உள்ள அனைத்து கிரகங்களும் (லக்னத்திலிருந்து 4/8/12).";

// [−] Shakata Yoga
"yoga_name_nabhasa_shakata" = "ஷகத யோகம்";
"yoga_outcome_nabhasa_shakata" = "வண்டி போன்ற வாழ்க்கை - ஏற்ற தாழ்வுகள்; செல்வம், வறுமையைத் தொடர்ந்து சுழற்சி முறையில்.";
"yoga_formation_nabhasa_shakata" = "1 மற்றும் 7 ஆம் வீடுகளில் மட்டுமே கிரகங்கள்.";

// [+] Shakti Yoga
"yoga_name_nabhasa_shakti" = "சக்தி யோகா";
"yoga_outcome_nabhasa_shakti" = "ஈட்டி உருவாக்கம்; சோம்பேறித்தனமான சுபாவம் ஆனால் விடாமுயற்சியின் மூலம் செல்வத்தைப் பெறுகிறது.";
"yoga_formation_nabhasa_shakti" = "7ம் தேதி முதல் தொடர்ந்து நான்கு வீடுகளில் கிரகங்கள்.";

// [+] Shringataka Yoga
"yoga_name_nabhasa_shringataka" = "சிருங்காடக யோகம்";
"yoga_outcome_nabhasa_shringataka" = "உச்சநிலை உருவாக்கம்; மனநிறைவு, பரோபகாரம் மற்றும் இணக்கமான மனநிலை.";
"yoga_formation_nabhasa_shringataka" = "திரிகோண வீடுகளில் உள்ள கிரகங்கள் (1, 5, 9).";

// [−] Shula Yoga
"yoga_name_nabhasa_shula" = "ஷூல யோகம்";
"yoga_outcome_nabhasa_shula" = "திரிசூலம் உருவாக்கம்; கூர்மையான, வீரம், ஆனால் ஏழை; நோய்வாய்ப்பட்ட மற்றும் மோதல்.";
"yoga_formation_nabhasa_shula" = "அடுத்தடுத்து மூன்று வீடுகளில் கிரகங்கள்.";

// [+] Vajra Yoga
"yoga_name_nabhasa_vajra" = "வஜ்ர யோகம்";
"yoga_outcome_nabhasa_vajra" = "வைரம் போன்ற பிரகாசம்; அழகானவர், இளமையிலும் முதுமையிலும் மகிழ்ச்சி, தற்காப்பு வீரம்.";
"yoga_formation_nabhasa_vajra" = "1/7ல் பலன்கள், 4வது/10வது இடங்கள்.";

// [+] Vapi Yoga
"yoga_name_nabhasa_vapi" = "வாபி யோகம்";
"yoga_outcome_nabhasa_vapi" = "கிணறு உருவாக்கம்; செல்வக் குவிப்பு, பதுக்கல் போக்கு, நீடித்த அதிர்ஷ்டம்.";
"yoga_formation_nabhasa_vapi" = "கேந்திரம் அல்லாத வீடுகளில் உள்ள அனைத்து கிரகங்களும் (பனபரா/அபோக்லிமா).";

// [+] Veena Yoga
"yoga_name_nabhasa_veena" = "வினா யோகம்";
"yoga_outcome_nabhasa_veena" = "வீணை உருவாக்கம்; இசை, நடனம் மற்றும் கலைகளை விரும்புபவர்; திறமையான மற்றும் மகிழ்ச்சியான மனநிலை.";
"yoga_formation_nabhasa_veena" = "ஏழு கிரகங்களும் அடுத்தடுத்த ஏழு வீடுகளில்.";

// [+] Vihaga Yoga
"yoga_name_nabhasa_vihaga" = "விஹாக யோகம்";
"yoga_outcome_nabhasa_vihaga" = "பறவை போன்ற சுதந்திரம்; தூதர் இயல்பு, அலைந்து திரிதல் மற்றும் செய்திகளை சுமக்கும் பாத்திரங்கள்.";
"yoga_formation_nabhasa_vihaga" = "4 மற்றும் 10 ஆம் வீடுகளில் மட்டுமே கிரகங்கள்.";

// [+] Yava Yoga
"yoga_name_nabhasa_yava" = "யவ யோகம்";
"yoga_outcome_nabhasa_yava" = "பார்லி-தானிய முறை; தொண்டு இயல்பு, நடுத்தர வயதில் மகிழ்ச்சி.";
"yoga_formation_nabhasa_yava" = "4/10ல் உள்ள பலன்கள், 1வது/7வது இடங்கள்.";

// [+] Yuga Yoga
"yoga_name_nabhasa_yuga" = "யுக யோகம்";
"yoga_outcome_nabhasa_yuga" = "நுகத்தடி உருவாக்கம்; மதவெறி, மோசமான, புறக்கணிக்கப்பட்ட போக்குகள்; வழக்கத்திற்கு மாறான பாதை.";
"yoga_formation_nabhasa_yuga" = "இரண்டு அடுத்தடுத்த வீடுகளில் அனைத்து கிரகங்களும்.";

// [+] Yupa Yoga
"yoga_name_nabhasa_yupa" = "யூப யோகம்";
"yoga_outcome_nabhasa_yupa" = "தியாக பதவி; தாராளமான, கற்றறிந்த, மத, மற்றும் கவனம் செலுத்தும் தன்மை.";
"yoga_formation_nabhasa_yupa" = "லக்னத்தில் இருந்து தொடங்கி தொடர்ந்து நான்கு வீடுகளில் கிரகங்கள்.";

// [−] Netranasa Yoga
"yoga_name_netranasa_yoga" = "நேத்ரநாச யோகம்";
"yoga_outcome_netranasa_yoga" = "கண் பிரச்சினைகள் அல்லது பார்வைக் குறைபாட்டிற்கு எளிதில் பாதிக்கப்படுதல்; வழக்கமான கண் பராமரிப்பு அவசியம்.";
"yoga_formation_netranasa_yoga" = "2ம்/12ம் அதிபதிகள் தோஷத்தால் பாதிக்கப்பட்டவர்கள், சூரியன்/சந்திரன் பலவீனம்.";

// [+] Nishkapata Yoga (205)
"yoga_name_nishkapata_yoga_205" = "நிஷ்கபட யோகா (205)";
"yoga_outcome_nishkapata_yoga_205" = "வெளிப்படையான, வஞ்சகமற்ற தன்மையை வழங்குகிறது; இயற்கையாகவே நேர்மையானவர் மற்றும் நேர்மை மூலம் மரியாதை பெறுகிறார்.";
"yoga_formation_nishkapata_yoga_205" = "நேர்மையைக் குறிக்கும் பலன் கிரக சேர்க்கைகள் (வர். 1).";

// [+] Nishkapata Yoga (206)
"yoga_name_nishkapata_yoga_206" = "நிஷ்கபட யோகா (206)";
"yoga_outcome_nishkapata_yoga_206" = "நேரடியான தன்மை மற்றும் தார்மீக தூய்மையை அளிக்கிறது; நேர்மையான பரிவர்த்தனைகள் மூலம் வளர்கிறது.";
"yoga_formation_nishkapata_yoga_206" = "நேர்மையைக் குறிக்கும் பலன் கிரக சேர்க்கைகள் (வர். 2).";

// [−] Nishturabhashi Yoga
"yoga_name_nishturabhashi_yoga" = "நிஷ்டுரபாஷி யோகம்";
"yoga_outcome_nishturabhashi_yoga" = "கடுமையான பேச்சுக்கான போக்கைக் குறிக்கிறது; கவனத்துடன் தொடர்பு கொள்ள அறிவுறுத்தப்படுகிறது.";
"yoga_formation_nishturabhashi_yoga" = "பாதகங்கள் புதன் மற்றும் 2 வது வீட்டை பாதிக்கின்றன.";

// [+] Obhayachari Yoga
"yoga_name_obhayachari_yoga" = "ஒபயாச்சாரி யோகம்";
"yoga_outcome_obhayachari_yoga" = "பேச்சாற்றல், அழகான தோற்றம், அரசமரம், வாழ்வில் தனித்துவம் ஆகியவற்றைக் கொடுக்கிறது.";
"yoga_formation_obhayachari_yoga" = "சூரியனில் இருந்து 2வது மற்றும் 12வது இடத்தில் உள்ள கிரகங்கள் (சந்திரன்/ராகு/கேது தவிர).";

// [+] Parakrama Yoga
"yoga_name_parakrama_yoga" = "பராக்கிரம யோகம்";
"yoga_outcome_parakrama_yoga" = "தைரியம் தேவைப்படும் முயற்சிகளில் விதிவிலக்கான தைரியம், உடல் வலிமை மற்றும் சாகச மனப்பான்மை ஆகியவற்றை வழங்குகிறது.";
"yoga_formation_parakrama_yoga" = "நன்மை தரும் நவாம்சத்தில் 3ம் அதிபதி நன்மை தாக்கங்களுடன்; செவ்வாய் சாதகமான கண்ணியத்தில்.";

// [−] Parannabhojana Yoga
"yoga_name_parannabhojana_yoga" = "பரன்னபோஜன யோகம்";
"yoga_outcome_parannabhojana_yoga" = "உணவுக்காக மற்றவர்களைச் சார்ந்திருக்கிறது; நிதிக் கட்டுப்பாடுகள் தொண்டு அல்லது ஆதரவின் மீது நம்பிக்கை வைக்கும்.";
"yoga_formation_parannabhojana_yoga" = "2ம் அதிபதி பலவீனம், 6ம் அதிபதி உணவு வீடுகளில் செல்வாக்கு செலுத்துகிறார்.";

// [+] Parihasaka Yoga
"yoga_name_parihasaka_yoga" = "பரிஹாசக யோகம்";
"yoga_outcome_parihasaka_yoga" = "இயல்பான அறிவு, நகைச்சுவை மற்றும் பொழுதுபோக்கு ஆளுமை; சமூகக் கூட்டங்களில் மகிழ்ச்சியைத் தருகிறது.";
"yoga_formation_parihasaka_yoga" = "குறிப்பிட்ட வீடுகளில் உள்ள நன்மைகள் நகைச்சுவையான மனநிலையை உருவாக்குகின்றன.";

// [+] Parijatha Yoga
"yoga_name_parijatha_yoga" = "பாரிஜாத யோகம்";
"yoga_outcome_parijatha_yoga" = "தகுதி மற்றும் விடாமுயற்சி மூலம் அதிகாரத்திற்கு படிப்படியாக ஆனால் தடுக்க முடியாத உயர்வு.";
"yoga_formation_parijatha_yoga" = "லக்னா அதிபதியின் டிஸ்போசிட்டர் சங்கிலி சொந்த கிரகத்திற்கு வழிவகுக்கிறது / கேந்திரம் / திரிகோணத்தில் உயர்ந்தது.";

// [+] Parvata Yoga
"yoga_name_parvata_yoga" = "பர்வத யோகம்";
"yoga_outcome_parvata_yoga" = "மலை போன்ற தொழில் நிலைத்தன்மை, செல்வம், புகழ் மற்றும் பெருந்தன்மை.";
"yoga_formation_parvata_yoga" = "கேந்திரங்களில் உள்ள பலன்கள்; 6வது மற்றும் 8வது வீடுகள் காலி/பாதிக்கப்படாதவை.";

// [−] Peenasaroga Yoga
"yoga_name_peenasaroga_yoga" = "பினாசரோக யோகம்";
"yoga_outcome_peenasaroga_yoga" = "நாள்பட்ட சைனசிடிஸ், நாசி கோளாறுகள் அல்லது சுவாச ஒவ்வாமை.";
"yoga_formation_peenasaroga_yoga" = "சந்திரன் மற்றும் 4 ஆம் அதிபதி சனி மற்றும் ராகுவால் பாதிக்கப்படுகின்றனர்.";

// [−] Pisacha Grastha Yoga
"yoga_name_pisacha_grastha_yoga" = "பிசாசா கிராஸ்த யோகா";
"yoga_outcome_pisacha_grastha_yoga" = "உளவியல் தொந்தரவுகள் அல்லது பகுத்தறிவற்ற அச்சங்கள்; மன ஆரோக்கிய நடைமுறைகள் நிவாரணம் அளிக்கின்றன.";
"yoga_formation_pisacha_grastha_yoga" = "ராகு/கேது இணைந்த சந்திரன் அல்லது லக்ன அதிபதி எந்த நன்மையும் இல்லாமல்.";

// [−] Pitrusapa Sutakshaya Yoga
"yoga_name_pitrusapa_sutakshaya_yoga" = "பித்ருசப சுதக்ஷய யோகம்";
"yoga_outcome_pitrusapa_sutakshaya_yoga" = "சந்ததியை பாதிக்கும் தந்தையின் சாபம்; தீர்க்கப்படாத தந்தைவழி கர்மா குழந்தைகளை பாதிக்கிறது.";
"yoga_formation_pitrusapa_sutakshaya_yoga" = "தோஷ சேர்க்கைகளில் 5 ஆம் அதிபதியுடன் சூரியன் பாதிக்கப்பட்டுள்ளார்.";

// [−] Pittaroga Yoga
"yoga_name_pittaroga_yoga" = "பித்தரோக யோகம்";
"yoga_outcome_pittaroga_yoga" = "பிட்டா தொடர்பான நோய்களுக்கு (அழற்சி, அமிலத்தன்மை, கல்லீரல் பிரச்சினைகள்) எளிதில் பாதிக்கப்படுகிறது.";
"yoga_formation_pittaroga_yoga" = "சூரியனும் செவ்வாயும் லக்னத்தை/6ல் நெருப்பு உறுப்பு ஏற்றத்தாழ்வுடன் பாதிக்கின்றனர்.";

// [−] Pretasapa Yoga
"yoga_name_pretasapa_yoga" = "பிரேதசப யோகம்";
"yoga_outcome_pretasapa_yoga" = "குடும்பத்தை பாதிக்கும் மூதாதையரின் ஆவி துன்பம்; ஆன்மீக சுத்திகரிப்பு பரிந்துரைக்கப்படுகிறது.";
"yoga_formation_pretasapa_yoga" = "சனியும் ராகுவும் 5-ல் எந்த நன்மையும் இல்லாமல் பாதிக்கப்படுகின்றனர்.";

// [+] Pushkala Yoga
"yoga_name_pushkala_yoga" = "புஷ்கல யோகம்";
"yoga_outcome_pushkala_yoga" = "ஏராளமான செழிப்பு, இனிமையான பேச்சு, புகழ் மற்றும் அரச மரியாதை ஆகியவற்றை வழங்குகிறது.";
"yoga_formation_pushkala_yoga" = "லக்னா அதிபதி சந்திரன் இணைந்த சந்திரன், வலுவான லக்னத்தை செலுத்துபவர்.";

// [+] Putra Sukha Yoga
"yoga_name_putra_sukha_yoga" = "புத்திர சுக யோகம்";
"yoga_outcome_putra_sukha_yoga" = "குழந்தைகள் மூலம் ஆழ்ந்த மகிழ்ச்சி மற்றும் திருப்தி; வலுவான பெற்றோர்-குழந்தை பிணைப்பு.";
"yoga_formation_putra_sukha_yoga" = "5 ஆம் அதிபதியும் வியாழனும் பரஸ்பர கேந்திரத்தில் நன்மையான அம்சங்களுடன்.";

// [−] Putrakalatraheena Yoga
"yoga_name_putrakalatraheena_yoga" = "புத்ரகலாத்ராஹிண யோகம்";
"yoga_outcome_putrakalatraheena_yoga" = "குழந்தைகளைப் பெறுவதிலும் திருமணத்தை பராமரிப்பதிலும் உள்ள சவால்கள்; உறவுகளில் கூடுதல் முயற்சி தேவை.";
"yoga_formation_putrakalatraheena_yoga" = "5 மற்றும் 7 ஆம் அதிபதிகள் துஸ்தானத்தில் கடுமையாக பாதிக்கப்பட்டுள்ளனர்.";

// [+] Putramooladhana Yoga
"yoga_name_putramooladhana_yoga" = "புத்ரமுலாதன யோகம்";
"yoga_outcome_putramooladhana_yoga" = "குழந்தைகள் மூலம் செல்வம், ஆக்கப்பூர்வமான முயற்சிகள் அல்லது ஊக ஆதாயங்கள்.";
"yoga_formation_putramooladhana_yoga" = "5ம் அதிபதி 2வது மற்றும் 11வது வீடுகளுடன் இணைக்கப்பட்டுள்ளார்.";

// [+] Raja Yoga (245)
"yoga_name_raja_yoga_245" = "ராஜயோகம் (245)";
"yoga_outcome_raja_yoga_245" = "அரச அந்தஸ்து, அதிகாரம் மற்றும் பெரும் அதிகார பதவி உயர்வு ஆகியவற்றை வழங்குகிறது.";
"yoga_formation_raja_yoga_245" = "கேந்திரங்கள்/திரிகோணங்களில் 3+ கிரகங்கள் உயர்ந்த/சொந்த வீடு.";

// [+] Raja Yoga (246)
"yoga_name_raja_yoga_246" = "ராஜயோகம் (246)";
"yoga_outcome_raja_yoga_246" = "உளவுத்துறை மூலம் அரசியல் வெற்றி மற்றும் நிர்வாக அதிகாரம்.";
"yoga_formation_raja_yoga_246" = "பரஸ்பர கேந்திரத்தில் லக்னாதிபதியும் 5ஆம் அதிபதியும் நன்மை தரும் அம்சங்களுடன்.";

// [+] Raja Yoga (247)
"yoga_name_raja_yoga_247" = "ராஜயோகம் (247)";
"yoga_outcome_raja_yoga_247" = "கண்கவர் தொழில்முறை வெற்றிக்காக பார்ச்சூன் தொழில் வாழ்க்கையுடன் இணைகிறது.";
"yoga_formation_raja_yoga_247" = "9 மற்றும் 10 ஆம் அதிபதிகள் இணைந்த அல்லது பரஸ்பர அம்சத்தில் (தர்ம-கர்ம அதிபதி).";

// [+] Raja Yoga (248)
"yoga_name_raja_yoga_248" = "ராஜயோகம் (248)";
"yoga_outcome_raja_yoga_248" = "கட்டமைப்பு நன்மைகள் மற்றும் முறையான ஆதரவு மூலம் அதிகாரத்திற்கு எழுச்சி.";
"yoga_formation_raja_yoga_248" = "கேந்திர மற்றும் திரிகோண அதிபதிகள் பரஸ்பர பரிமாற்றத்தில் (பரிவர்த்தனம்).";

// [+] Raja Yoga (249)
"yoga_name_raja_yoga_249" = "ராஜயோகம் (249)";
"yoga_outcome_raja_yoga_249" = "விரிவான அதிகாரம் - ஞானம், நெறிமுறைகள் மற்றும் மக்கள் ஆதரவுடன் வழிநடத்துகிறது.";
"yoga_formation_raja_yoga_249" = "1, 5, 9 ஆம் அதிபதிகள் கேந்திர ஆதரவுடன் ஒன்றோடொன்று இணைந்துள்ளனர்.";

// [+] Raja Yoga (250)
"yoga_name_raja_yoga_250" = "ராஜயோகம் (250)";
"yoga_outcome_raja_yoga_250" = "தொழில் மேன்மை மற்றும் உயர்ந்த தொழில்முறை வேறுபாடுகள்.";
"yoga_formation_raja_yoga_250" = "10ம் அதிபதி 9ம் அதிபதி வலுவுடன் உயர்ந்தவர்.";

// [+] Raja Yoga (251)
"yoga_name_raja_yoga_251" = "ராஜயோகம் (251)";
"yoga_outcome_raja_yoga_251" = "வாழ்நாள் முழுவதும் நீடித்த அதிகாரம் மற்றும் முற்போக்கான தொழில் வளர்ச்சி.";
"yoga_formation_raja_yoga_251" = "திரிகோணங்களில் பல கேந்திர அதிபதிகள் அல்லது நேர்மாறாக.";

// [+] Raja Yoga (252)
"yoga_name_raja_yoga_252" = "ராஜயோகம் (252)";
"yoga_outcome_raja_yoga_252" = "ஆற்றல் மிக்க சுயமாகத் தலைவன்; சாதனைகளிலிருந்து பிரிக்க முடியாத அடையாளம்.";
"yoga_formation_raja_yoga_252" = "லக்னத்தில் லக்னாதிபதி 10ல், 10ம் அதிபதி லக்னத்தில் (பரிமாற்றம்).";

// [+] Raja Yoga (253)
"yoga_name_raja_yoga_253" = "ராஜயோகம் (253)";
"yoga_outcome_raja_yoga_253" = "தெய்வீக தயவு, கடந்தகால வாழ்க்கை தகுதி மற்றும் அறிவுசார் மேன்மை ஆகியவற்றின் மூலம் அதிகாரம்.";
"yoga_formation_raja_yoga_253" = "5ம் அதிபதி 9ல் அல்லது 9ம் அதிபதி 5ல் இருப்பது நன்மை தரும் அம்சங்களுடன்.";

// [+] Raja Yoga (254)
"yoga_name_raja_yoga_254" = "ராஜயோகம் (254)";
"yoga_outcome_raja_yoga_254" = "நல்ல தலைமை, இராஜதந்திர வெற்றி மற்றும் கலாச்சார அதிகாரம்.";
"yoga_formation_raja_yoga_254" = "வலுவான லக்னாதிபதியுடன் கேந்திரங்களில் வியாழன் மற்றும் சுக்கிரன்.";

// [+] Raja Yoga (255)
"yoga_name_raja_yoga_255" = "ராஜயோகம் (255)";
"yoga_outcome_raja_yoga_255" = "மக்கள் ஆதரவு, சொத்து மற்றும் நிறுவன அதிகாரத்தில் வேரூன்றிய அதிகாரம்.";
"yoga_formation_raja_yoga_255" = "4 மற்றும் 10 ஆம் அதிபதிகள் பரஸ்பர ஆதரவில் வலுவான கண்ணியத்துடன் உள்ளனர்.";

// [+] Raja Yoga (256)
"yoga_name_raja_yoga_256" = "ராஜயோகம் (256)";
"yoga_outcome_raja_yoga_256" = "அரசாங்க அதிகாரம், நிர்வாக வெற்றி மற்றும் பொது தலைமை.";
"yoga_formation_raja_yoga_256" = "வியாழனின் அம்சத்துடன் சூரியன் 10ல் வலுவாக இருக்கிறார்.";

// [+] Raja Yoga (257)
"yoga_name_raja_yoga_257" = "ராஜயோகம் (257)";
"yoga_outcome_raja_yoga_257" = "பிரபலமான தலைமை - மக்களால் விரும்பப்படுகிறது மற்றும் பொது ஆதரவின் மூலம் உயர்கிறது.";
"yoga_formation_raja_yoga_257" = "சந்திரன் வலுவாக, பல கேந்திர/திரிகோண அதிபதிகளுடன் இணைக்கப்பட்டுள்ளது.";

// [+] Raja Yoga (258)
"yoga_name_raja_yoga_258" = "ராஜயோகம் (258)";
"yoga_outcome_raja_yoga_258" = "இராணுவ/நிர்வாக அதிகாரம்; பெரிய நிறுவனங்களுக்கு கட்டளையிடுகிறது.";
"yoga_formation_raja_yoga_258" = "10ம் அதிபதியுடன் கேந்திரத்தில் சொந்த/உயர்ந்த ராசியில் செவ்வாய்.";

// [+] Raja Yoga (259)
"yoga_name_raja_yoga_259" = "ராஜயோகம் (259)";
"yoga_outcome_raja_yoga_259" = "அறிவுசார், வணிக அல்லது தகவல் தொடர்பு துறைகளில் அதிகாரம்.";
"yoga_formation_raja_yoga_259" = "2 மற்றும் 11 ஆம் அதிபதிகளுடன் 10 ஆம் இடத்தில் புதன் வலுவாக உள்ளது.";

// [+] Raja Yoga (260)
"yoga_name_raja_yoga_260" = "ராஜயோகம் (260)";
"yoga_outcome_raja_yoga_260" = "ஒழுக்கமான நிர்வாகம் மற்றும் நிறுவன தலைமை மூலம் நீடித்த அதிகாரம்.";
"yoga_formation_raja_yoga_260" = "நன்மையான அம்சங்களுடன் 10ல் சொந்த/உயர்ந்த சனி.";

// [+] Raja Yoga (261)
"yoga_name_raja_yoga_261" = "ராஜயோகம் (261)";
"yoga_outcome_raja_yoga_261" = "இராஜதந்திரம், கலை அல்லது ஆடம்பரத் தொழில்களில் அதிகாரத்துடன் வெற்றி.";
"yoga_formation_raja_yoga_261" = "10ல் சுக்கிரன் 9ம் மற்றும் லக்ன அதிபதிகளுடன் இணைந்துள்ளார்.";

// [+] Raja Yoga (262)
"yoga_name_raja_yoga_262" = "ராஜயோகம் (262)";
"yoga_outcome_raja_yoga_262" = "அதிகாரம், செல்வம் மற்றும் அங்கீகாரம் ஆகியவற்றுடன் தொழில்முறை வெற்றி.";
"yoga_formation_raja_yoga_262" = "கண்ணியமான 10ம் அதிபதியுடன் கேந்திரங்களில் பல பலன்கள்.";

// [+] Raja Yoga (263)
"yoga_name_raja_yoga_263" = "ராஜயோகம் (263)";
"yoga_outcome_raja_yoga_263" = "உச்ச ராஜ யோகம் - அசாதாரண சக்தி மற்றும் நீடித்த மரபு.";
"yoga_formation_raja_yoga_263" = "அனைத்து திரிகோண மற்றும் கேந்திர அதிபதிகளும் பரஸ்பர ஆதரவு (அரிதாக).";

// [−] Raja Yoga Bhanga (298)
"yoga_name_raja_yoga_bhanga_298" = "ராஜயோக பங்கா (298)";
"yoga_outcome_raja_yoga_bhanga_298" = "ராஜயோக பலன்களை ரத்து செய்கிறது; மறைந்திருக்கும் எதிரிகளால் வெற்றி சிதைக்கப்பட்டது.";
"yoga_formation_raja_yoga_bhanga_298" = "ராஜ யோக கிரகங்கள் வலுவான தோஷங்களால் பாதிக்கப்பட்டன (வர். 1).";

// [−] Raja Yoga Bhanga (299)
"yoga_name_raja_yoga_bhanga_299" = "ராஜயோக பங்கா (299)";
"yoga_outcome_raja_yoga_bhanga_299" = "தொழில் முன்னேற்றத்தை அழிக்கிறது; வெளிப்புற சக்திகள் தொழில்முறை முன்னேற்றத்தைத் தடுக்கின்றன.";
"yoga_formation_raja_yoga_bhanga_299" = "ராஜயோக கிரகங்கள் வலுவிழந்து அல்லது எரியும் (வர். 2).";

// [−] Rajabhrashta Yoga
"yoga_name_rajabhrashta_yoga" = "ராஜபிரஷ்ட யோகம்";
"yoga_outcome_rajabhrashta_yoga" = "உயர் நிலையில் இருந்து வீழ்ச்சி; திடீர் அதிகார இழப்பு அல்லது பொது அவமானம்.";
"yoga_formation_rajabhrashta_yoga" = "ஆரோத லக்ன அதிபதியும் ஆரோக்ய 12ம் அதிபதியும் இணைந்து.";

// [+] Rajalakshana Yoga
"yoga_name_rajalakshana_yoga" = "ராஜலக்ஷண யோகம்";
"yoga_outcome_rajalakshana_yoga" = "உன்னதமான தாங்குதல், பிரபுத்துவ நடத்தை மற்றும் இயல்பான தலைமைத்துவ பண்புகளை வழங்குகிறது.";
"yoga_formation_rajalakshana_yoga" = "குறிப்பிட்ட கண்ணிய நிலைகளுடன் கூடிய வலுவான கிரகங்கள் உச்சம் அல்லது கேந்திரங்கள்.";

// [+] Ravi Yoga
"yoga_name_ravi_yoga" = "ரவி யோகம்";
"yoga_outcome_ravi_yoga" = "சூரிய அதிகாரம் - நம்பிக்கையுடன் பொது வாழ்க்கையிலும் அரசாங்கத்திலும் பிரகாசிக்கிறது.";
"yoga_formation_ravi_yoga" = "சூரியன் 10ல் சொந்த/உயர்ந்த, 9ம் அதிபதி பலம்.";

// [−] Rogagrastha Yoga
"yoga_name_rogagrastha_yoga" = "ரோகாகிரஸ்த யோகம்";
"yoga_outcome_rogagrastha_yoga" = "நாள்பட்ட நோய் பாதிப்பு; தனிப்பட்ட உடல்நலப் பிரச்சினைகளுக்கு ஆளாக நேரிடும்.";
"yoga_formation_rogagrastha_yoga" = "6ம் அதிபதி பலம், லக்னாதிபதி பலவீனம், லக்னாதிபதி பலவீனம்.";

// [+] Ruchaka Yoga
"yoga_name_ruchaka_yoga" = "ருச்சக யோகம்";
"yoga_outcome_ruchaka_yoga" = "தைரியம், உடல் சுறுசுறுப்பு, கட்டளையிடும் இருப்பு மற்றும் போட்டி அல்லது இராணுவத் துறைகளில் வெற்றியை வழங்குகிறது.";
"yoga_formation_ruchaka_yoga" = "செவ்வாய் ஒரு கேந்திரத்தில் (1/4/7/10) சொந்த ராசியில் (மேஷம்/விருச்சிகம்) அல்லது உச்சம் (மகரம்).";

// [+] Sada Sanchara Yoga
"yoga_name_sada_sanchara_yoga" = "சதா சஞ்சார யோகம்";
"yoga_outcome_sada_sanchara_yoga" = "நிலையான பயணத்தை உள்ளடக்கிய தொழில் - இராஜதந்திரம், ஆலோசனை அல்லது சர்வதேச வணிகம்.";
"yoga_formation_sada_sanchara_yoga" = "3/7/12 வீடுகளுடன் இணைக்கப்பட்ட அசையும் ராசியில் 10ஆம் அதிபதி.";

// [−] Sahodareesangama Yoga
"yoga_name_sahodareesangama_yoga" = "சஹோதரிசங்கம யோகம்";
"yoga_outcome_sahodareesangama_yoga" = "நனவான எல்லைகள் தேவைப்படும் உடன்பிறப்பு உறவுகளில் பொருத்தமற்ற இயக்கவியல்.";
"yoga_formation_sahodareesangama_yoga" = "3ம் அதிபதியும் சுக்கிரனும் பாதிக்கப்பட்ட சேர்க்கைகளில்.";

// [−] Sakata Yoga
"yoga_name_sakata_yoga" = "சகட யோகம்";
"yoga_outcome_sakata_yoga" = "ஏற்ற இறக்கமான அதிர்ஷ்டம் - செழிப்பு பின்னடைவுகளுடன் மாறி மாறி வருகிறது; நிலைத்தன்மைக்கு முயற்சி தேவை.";
"yoga_formation_sakata_yoga" = "வியாழனிலிருந்து 6/8/12ல் சந்திரன்.";

// [−] Sanghataka Marana Yoga (276)
"yoga_name_sanghataka_marana_yoga_276" = "சங்கடகா மரண யோகா (276)";
"yoga_outcome_sanghataka_marana_yoga_276" = "கூட்டு சோகம் அல்லது வெகுஜன நிகழ்வு பாதிப்பு; தவறான போக்குவரத்தின் போது எச்சரிக்கை.";
"yoga_formation_sanghataka_marana_yoga_276" = "மரணத்தை உண்டாக்கும் வீடுகளில் குறிப்பிட்ட தவறான குழுக்கள் (var. 1).";

// [−] Sanghataka Marana Yoga (277)
"yoga_name_sanghataka_marana_yoga_277" = "சங்கடகா மரண யோகா (277)";
"yoga_outcome_sanghataka_marana_yoga_277" = "குழு நடவடிக்கைகள் அல்லது பயணத்தின் போது ஆபத்து; ஆபத்து காலங்களில் அதிக விழிப்புணர்வு.";
"yoga_formation_sanghataka_marana_yoga_277" = "மரணத்தை உண்டாக்கும் வீடுகளில் குறிப்பிட்ட தவறான குழுக்கள் (var. 2).";

// [+] Sankha Yoga
"yoga_name_sankha_yoga" = "சங்க யோகம்";
"yoga_outcome_sankha_yoga" = "சங்கு போன்ற அரச அதிகாரம்; செல்வம், நீண்ட ஆயுள் மற்றும் மனிதாபிமான தலைமை.";
"yoga_formation_sankha_yoga" = "வலுவான லக்னாதிபதியுடன் பரஸ்பர கேந்திரங்களில் 5 மற்றும் 6 ஆம் அதிபதிகள்.";

// [+] Sarala Yoga
"yoga_name_sarala_yoga" = "சரளா யோகம்";
"yoga_outcome_sarala_yoga" = "அச்சமின்மை மற்றும் நீண்ட ஆயுளை வழங்குகிறது; மறைந்திருக்கும் ஆபத்துக்களை மீள்தன்மை மூலம் வெல்கிறது.";
"yoga_formation_sarala_yoga" = "8வது அதிபதி 6, 8 அல்லது 12வது வீட்டில் (துஸ்தானத்தில் துஸ்தானம்).";

// [+] Saraswathi Yoga Education
"yoga_name_saraswathi_yoga_education" = "சரஸ்வதி யோகா கல்வி";
"yoga_outcome_saraswathi_yoga_education" = "முடிவு விவரங்கள் சேர்க்கப்பட வேண்டும்";
"yoga_formation_saraswathi_yoga_education" = "உருவாக்க விவரங்கள் சேர்க்கப்பட வேண்டும்";

// [+] Sareera Soukhya Yoga
"yoga_name_sareera_soukhya_yoga" = "சரிரா சௌக்கிய யோகம்";
"yoga_outcome_sareera_soukhya_yoga" = "உடல் ஆறுதல், நல்ல ஆரோக்கியம் மற்றும் வாழ்நாள் முழுவதும் வலுவான அரசியலமைப்பு.";
"yoga_formation_sareera_soukhya_yoga" = "லக்னத்தின் மீது நன்மையான அம்சங்களுடன் சொந்த/உயர்ந்த ராசியில் லக்னாதிபதி.";

// [−] Sarpaganda Yoga
"yoga_name_sarpaganda_yoga" = "சர்பகந்தா யோகம்";
"yoga_outcome_sarpaganda_yoga" = "பாம்பு கடி அல்லது ஊர்வன தொடர்பான ஆபத்துகளுக்கு எளிதில் பாதிக்கப்படுதல்; பாம்புகள் அருகில் எச்சரிக்கை.";
"yoga_formation_sarpaganda_yoga" = "லக்னத்தில் தீய அம்சங்களுடன் குறிப்பிட்ட நிலையில் ராகு.";

// [−] Sarpasapa Yoga (212)
"yoga_name_sarpasapa_yoga_212" = "சர்பசாப யோகா (212)";
"yoga_outcome_sarpasapa_yoga_212" = "சந்ததியை பாதிக்கும் சர்ப்ப சாபம்; குழந்தைப்பேறுக்கு கர்ம தடைகள்.";
"yoga_formation_sarpasapa_yoga_212" = "தீய அம்சங்களுடன் 5ல் ராகு, பலன் நிவாரணம் இல்லை (வர். 1).";

// [−] Sarpasapa Yoga (213)
"yoga_name_sarpasapa_yoga_213" = "சர்பசாப யோகா (213)";
"yoga_outcome_sarpasapa_yoga_213" = "கருவுறுதல் சவால்களாக வெளிப்படும் முன்னோர்களின் கர்மக் கடன்.";
"yoga_formation_sarpasapa_yoga_213" = "ராகு/கேது அச்சு 5-11ல் பாதிக்கப்பட்ட 5ம் அதிபதியுடன் (வர். 2).";

// [−] Sarpasapa Yoga (214)
"yoga_name_sarpasapa_yoga_214" = "சர்பசாப யோகா (214)";
"yoga_outcome_sarpasapa_yoga_214" = "குழந்தைகளைப் பெறுவதற்கு ஆழமாக வேரூன்றிய கர்மத் தடைகள்; ஆன்மீக வைத்தியம் அவசியம்.";
"yoga_formation_sarpasapa_yoga_214" = "சனியுடன் 5 இல் குறிப்பிட்ட ராகு சேர்க்கைகள் (வர். 3).";

// [−] Sarpasapa Yoga (215)
"yoga_name_sarpasapa_yoga_215" = "சர்பசாப யோகா (215)";
"yoga_outcome_sarpasapa_yoga_215" = "குடும்ப பரம்பரையில் கடுமையான பாம்பு சாபம்; சடங்கு சுத்திகரிப்பு பரிந்துரைக்கப்படுகிறது.";
"yoga_formation_sarpasapa_yoga_215" = "5ல் ராகு 5ம் அதிபதியுடன் 6/8/12ல் (வர். 4).";

// [+] Sasa Yoga
"yoga_name_sasa_yoga" = "சச யோகம்";
"yoga_outcome_sasa_yoga" = "ஒழுக்கம், ஆளுகையில் தலைமை, மற்றும் விடாமுயற்சி மற்றும் முறையான முயற்சி மூலம் வெற்றியை வழங்குகிறது.";
"yoga_formation_sasa_yoga" = "சனி ஒரு கேந்திரத்தில் (1/4/7/10) சொந்த ராசியில் (மகரம்/கும்பம்) அல்லது உயர்நிலையில் (துலாம்).";

// [+] Satkalatra Yoga
"yoga_name_satkalatra_yoga" = "சத்கலத்ர யோகம்";
"yoga_outcome_satkalatra_yoga" = "உன்னதமான, நல்லொழுக்கமுள்ள மனைவி மற்றும் இணக்கமான திருமணம்; வாழ்க்கை துணை அதிர்ஷ்டத்தையும் மகிழ்ச்சியையும் தருகிறது.";
"yoga_formation_satkalatra_yoga" = "7ம் அதிபதி சுக்கிரன் வலுவாகவும், நன்மையான அம்சங்களுடனும் நல்ல இடத்தில் இருக்கிறார்.";

// [+] Satkathadisravana Yoga
"yoga_name_satkathadisravana_yoga" = "சத்கதாதிஸ்ரவண யோகம்";
"yoga_outcome_satkathadisravana_yoga" = "புனிதமான அறிவு, தத்துவக் கற்றல் மற்றும் உயர்ந்த ஞானத்திற்கான ஆழ்ந்த அன்பை வழங்குகிறது.";
"yoga_formation_satkathadisravana_yoga" = "3வது வீடு பலன்களால், 3ம் அதிபதி நவாம்சத்தில் இயற்கையான பலன்களுடன்.";

// [+] Satrumooladhana Yoga
"yoga_name_satrumooladhana_yoga" = "சதுர்மூலதன யோகம்";
"yoga_outcome_satrumooladhana_yoga" = "போட்டி, சட்ட வெற்றிகள் அல்லது சேவை வருமானம் ஆகியவற்றை தோற்கடிப்பதன் மூலம் செல்வம்.";
"yoga_formation_satrumooladhana_yoga" = "6 ஆம் அதிபதி 2 மற்றும் 11 ஆம் வீடுகளுடன் இணைக்கப்பட்டுள்ளார்.";

// [−] Sirachcheda Yoga
"yoga_name_sirachcheda_yoga" = "சிராச்சேத யோகம்";
"yoga_outcome_sirachcheda_yoga" = "தலையில் காயங்கள் அல்லது கடுமையான அதிர்ச்சி ஆபத்து; பாதுகாப்பு நடவடிக்கைகள் மற்றும் எச்சரிக்கையுடன் அறிவுறுத்தப்படுகிறது.";
"yoga_formation_sirachcheda_yoga" = "செவ்வாய் மற்றும் கேது லக்னத்தை எந்த நன்மையும் இல்லாமல் பாதிக்கிறார்கள்.";

// [−] Sisnavyadhi Yoga
"yoga_name_sisnavyadhi_yoga" = "சிஷ்ணவ்யாதி யோகம்";
"yoga_outcome_sisnavyadhi_yoga" = "பிறப்புறுப்பு அல்லது இனப்பெருக்க சுகாதார சீர்குலைவுகள்; சிறப்பு மருத்துவ கவனிப்பு பரிந்துரைக்கப்படுகிறது.";
"yoga_formation_sisnavyadhi_yoga" = "சுக்கிரனும் 7ம் அதிபதியும் 8வது வீட்டில் தோஷத்தால் பாதிக்கப்பட்டுள்ளனர்.";

// [+] Siva Yoga
"yoga_name_siva_yoga" = "சிவயோகம்";
"yoga_outcome_siva_yoga" = "சிவபெருமான் அருள்; ஆழ்ந்த தியான திறன்கள், துறவு ஞானம் மற்றும் மாற்றும் ஆன்மீக சக்தி.";
"yoga_formation_siva_yoga" = "9ல் 5ம் அதிபதி, 10ல் 9ம் அதிபதி, 5ல் 10ம் அதிபதி.";

// [−] Sraddhannabhuktha Yoga
"yoga_name_sraddhannabhuktha_yoga" = "ஸ்ரத்தன்னபுக்த யோகம்";
"yoga_outcome_sraddhannabhuktha_yoga" = "சடங்குகள் அல்லது சடங்குகளுக்காக உண்ணும் உணவை உண்பது; இறுதிச் சடங்கு/சடங்கு வழிபாடுகளைச் சார்ந்தது.";
"yoga_formation_sraddhannabhuktha_yoga" = "அசுத்தமான உணவு ஆதாரங்களைக் குறிக்கும் 2வது வீட்டிற்கு குறிப்பிட்ட துன்பங்கள்.";

// [+] Sreenatha Yoga
"yoga_name_sreenatha_yoga" = "ஸ்ரீநாத யோகம்";
"yoga_outcome_sreenatha_yoga" = "தெய்வீக தயவையும், திருமணத்திற்குப் பிறகு செழிப்பையும், கூட்டாண்மை மூலம் அதிர்ஷ்டத்தையும் தருகிறது.";
"yoga_formation_sreenatha_yoga" = "7ஆம் அதிபதி 10ஆம், 9ஆம், 10ஆம் அதிபதிகளுடன் இணைந்து உச்சம் பெற்றுள்ளார்.";

// [+] Sumukha Yoga (166)
"yoga_name_sumukha_yoga_166" = "சுமுக யோகா (166)";
"yoga_outcome_sumukha_yoga_166" = "கவர்ச்சியான முகம் மற்றும் இனிமையான தோற்றம்; காந்த ஆளுமை மற்றும் வசீகரமான நடத்தை.";
"yoga_formation_sumukha_yoga_166" = "லக்னத்தில் இருந்து 2ல் உள்ள பலன்கள், லக்னாதிபதி வலுவாக (வர். 1).";

// [+] Sumukha Yoga (167)
"yoga_name_sumukha_yoga_167" = "சுமுக யோகா (167)";
"yoga_outcome_sumukha_yoga_167" = "அழகான அம்சங்கள் மற்றும் அழகான தாங்கி; இயல்பாகவே ஈர்க்கும் மற்றும் சமூக ரீதியாக போற்றப்படும்.";
"yoga_formation_sumukha_yoga_167" = "வீனஸ் மற்றும் வியாழன் லக்னம் அல்லது 2வது வீடு (வர். 2).";

// [+] Sunapha Yoga
"yoga_name_sunapha_yoga" = "சுனபா யோகா";
"yoga_outcome_sunapha_yoga" = "தனிப்பட்ட தகுதி மூலம் சுயமாக சம்பாதித்த செல்வம், புத்திசாலித்தனம் மற்றும் செழிப்பு ஆகியவற்றை வழங்குகிறது.";
"yoga_formation_sunapha_yoga" = "சந்திரனில் இருந்து 2வது வீட்டில் கிரகம் (சூரியன்/ராகு/கேது தவிர).";

// [+] Suputra Yoga
"yoga_name_suputra_yoga" = "சுபுத்ர யோகம்";
"yoga_outcome_suputra_yoga" = "பெரும் பெருமையையும் குடும்ப கௌரவத்தையும் கொண்டு வரும் தகுதியான, நல்லொழுக்கமுள்ள குழந்தை பாக்கியம்.";
"yoga_formation_suputra_yoga" = "வியாழன் வலுவாக 5ஆம் வீட்டில், 5ஆம் அதிபதி கண்ணியமானவர்.";

// [+] Swaveeryadhana Yoga
"yoga_name_swaveeryadhana_yoga" = "ஸ்வவிர்யாதன யோகம்";
"yoga_outcome_swaveeryadhana_yoga" = "சுயமுயற்சியின் மூலம் செல்வத்தை முழுவதுமாக வழங்குகிறது; தனிநபர் ஒரு சுயமாக உருவாக்கிய சாதனையாளர்.";
"yoga_formation_swaveeryadhana_yoga" = "லக்னாதிபதியும், 2ம் அதிபதியும் வெளி வீடு சார்பு இல்லாமல் வலுவாக உள்ளனர்.";

// [−] Swetakushta Yoga
"yoga_name_swetakushta_yoga" = "ஸ்வேதகுஷ்ட யோகம்";
"yoga_outcome_swetakushta_yoga" = "நாள்பட்ட தோல் நிலைகளுக்கு உணர்திறன்; முழுமையான சுகாதார நடைமுறைகள் பரிந்துரைக்கப்படுகின்றன.";
"yoga_formation_swetakushta_yoga" = "தோல் மற்றும் உயிர்ச்சக்தி வீடுகளை பாதிக்கும் குறிப்பிட்ட சேர்க்கைகள்.";

// [+] Theevrabuddhi Yoga
"yoga_name_theevrabuddhi_yoga" = "திவிரபுத்தி யோகம்";
"yoga_outcome_theevrabuddhi_yoga" = "ரேஸர்-கூர்மையான நுண்ணறிவு மற்றும் விரைவான புரிதல்; தர்க்கம் மற்றும் பகுப்பாய்வுகளில் சிறந்து விளங்குகிறது.";
"yoga_formation_theevrabuddhi_yoga" = "வியாழனின் அம்சத்துடன் கேந்திரத்தில் புதன் உயர்ந்த/சொந்த ராசி.";

// [+] Thrikalagnana Yoga
"yoga_name_thrikalagnana_yoga" = "திரிகாலஞான யோகம்";
"yoga_outcome_thrikalagnana_yoga" = "தீர்க்கதரிசன உள்ளுணர்வு மற்றும் அசாதாரண தொலைநோக்கு; விசித்திரமான முன்கணிப்பு திறன்கள்.";
"yoga_formation_thrikalagnana_yoga" = "குறிப்பிட்ட லக்ன இணைப்புகளுடன் நவாம்சத்தில் வியாழன் வலுவாக உள்ளது.";

// [+] Thrilochana Yoga
"yoga_name_thrilochana_yoga" = "திரிலோச்சன யோகம்";
"yoga_outcome_thrilochana_yoga" = "மகத்தான செல்வத்தையும், அச்சமின்மையையும், கட்டளையிடும், செழிப்பான இருப்பையும் வழங்குகிறது.";
"yoga_formation_thrilochana_yoga" = "சூரியன், சந்திரன் மற்றும் செவ்வாய் பரஸ்பர திரிகோணங்களில் (1-5-9 முக்கோணம்).";

// [+] Uttama Griha Yoga
"yoga_name_uttama_griha_yoga" = "உத்தம கிரஹ யோகம்";
"yoga_outcome_uttama_griha_yoga" = "சிறந்த வீடுகளின் உரிமையை வழங்குகிறது; தனிமனித வாழ்வு நல்ல குடியிருப்புகளுடன் வசதியாக இருக்கிறது.";
"yoga_formation_uttama_griha_yoga" = "4ஆம் அதிபதி கேந்திரம்/திரிகோணத்தில் பலன் பலன்களுடன்.";

// [+] Vahana Yoga (209)
"yoga_name_vahana_yoga_209" = "வாகன யோகா (209)";
"yoga_outcome_vahana_yoga_209" = "சிறந்த வாகனங்கள், போக்குவரத்து மற்றும் சொகுசு போக்குவரத்து ஆகியவற்றை வழங்குகிறது.";
"yoga_formation_vahana_yoga_209" = "4 ஆம் அதிபதி பலன்களுடன் இணைக்கப்பட்டவர் மற்றும் சுக்கிரன் வலுவாக (வர். 1).";

// [+] Vahana Yoga (210)
"yoga_name_vahana_yoga_210" = "வாகன யோகா (210)";
"yoga_outcome_vahana_yoga_210" = "பிரீமியம் வாகனங்கள் மற்றும் வாழ்நாள் முழுவதும் வசதியான பயணத்தை உறுதி செய்கிறது.";
"yoga_formation_vahana_yoga_210" = "சுக்கிரன் நல்ல இடத்தில் இருக்கும் நான்காம் வீட்டில் உள்ள பலன்கள் (வர். 2).";

// [−] Vakchalana Yoga
"yoga_name_vakchalana_yoga" = "வக்சலன யோகம்";
"yoga_outcome_vakchalana_yoga" = "பேச்சு குறைபாடுகள், திணறல் அல்லது மொழி தடைகள்; பேச்சு சிகிச்சை பயனுள்ளதாக இருக்கும்.";
"yoga_formation_vakchalana_yoga" = "புதன் தோஷம், 2ம் அதிபதி பலவீனம்.";

// [−] Vamsacheda Yoga
"yoga_name_vamsacheda_yoga" = "வம்சசேத யோகம்";
"yoga_outcome_vamsacheda_yoga" = "குடும்பப் பரம்பரை தொடர்வதில் உள்ள சவால்கள்; மாற்று குடும்பக் கட்டிடம் பரிசீலிக்கப்படலாம்.";
"yoga_formation_vamsacheda_yoga" = "5ம் அதிபதியும் வியாழனும் கடுமையாக பாதிக்கப்பட்டுள்ளனர்.";

// [−] Vanchanachorabheethi Yoga
"yoga_name_vanchanachorabheethi_yoga" = "வஞ்சனசோரபித்தி யோகம்";
"yoga_outcome_vanchanachorabheethi_yoga" = "ஏமாற்று அல்லது திருட்டுக்கு பாதிப்பை பரிந்துரைக்கிறது; அறிவுறுத்தப்படும் பிறரை நம்புவதில் எச்சரிக்கையாக இருங்கள்.";
"yoga_formation_vanchanachorabheethi_yoga" = "ராகு/கேது ஈடுபாட்டுடன் லக்ன அதிபதியின் மீது தீய தாக்கங்கள்.";

// [+] Vasi Yoga
"yoga_name_vasi_yoga" = "வாசி யோகம்";
"yoga_outcome_vasi_yoga" = "தொண்டு மனப்பான்மை, செல்வாக்கு, நல்ல அதிர்ஷ்டம் மற்றும் சமூக அந்தஸ்தை வழங்குகிறது.";
"yoga_formation_vasi_yoga" = "சூரியனிலிருந்து 12வது வீட்டில் உள்ள கிரகம் (சந்திரன்/ராகு/கேது தவிர).";

// [+] Vasumathi Yoga
"yoga_name_vasumathi_yoga" = "வசுமதி யோகம்";
"yoga_outcome_vasumathi_yoga" = "நிலையான முயற்சியின் மூலம் நிலையான செல்வக் குவிப்பு மற்றும் நிதி ஸ்திரத்தன்மையை உறுதி செய்கிறது.";
"yoga_formation_vasumathi_yoga" = "சந்திரன் அல்லது லக்னத்தில் இருந்து உபச்சாய வீடுகளில் (3/6/10/11) பலன்கள்.";

// [−] Vatharoga Yoga
"yoga_name_vatharoga_yoga" = "வதரோக யோகம்";
"yoga_outcome_vatharoga_yoga" = "வட்டா தொடர்பான நோய்களுக்கு (மூட்டு வலி, நரம்பு கோளாறுகள், வாயு) எளிதில் பாதிக்கப்படுகிறது.";
"yoga_formation_vatharoga_yoga" = "சனி லக்னத்தை பாதிக்கிறது / காற்று உறுப்பு ஏற்றத்தாழ்வுடன் 6 ஆம் வீட்டில்.";

// [+] Vesi Yoga
"yoga_name_vesi_yoga" = "வேசி யோகம்";
"yoga_outcome_vesi_yoga" = "நேர்மையான முயற்சியின் மூலம் உண்மைத்தன்மை, உழைப்புத் தன்மை மற்றும் நம்பகத்தன்மை ஆகியவற்றை மேம்படுத்துகிறது.";
"yoga_formation_vesi_yoga" = "சூரியனில் இருந்து 2வது வீட்டில் உள்ள கிரகம் (சந்திரன்/ராகு/கேது தவிர).";

// [+] Vichitra Saudha Prakara Yoga
"yoga_name_vichitra_saudha_prakara_yoga" = "விசித்ர சௌத பிராகார யோகம்";
"yoga_outcome_vichitra_saudha_prakara_yoga" = "அரண்மனை குடியிருப்புகள் மற்றும் குறிப்பிடத்தக்க சொத்துக்களின் உரிமையை வழங்குகிறது.";
"yoga_formation_vichitra_saudha_prakara_yoga" = "கண்ணியமான நிலைகளுடன் 4 வது வீட்டை ஆதரிக்கும் பல கிரகங்கள்.";

// [+] Vidyut Yoga
"yoga_name_vidyut_yoga" = "வித்யுத் யோகா";
"yoga_outcome_vidyut_yoga" = "மின்னல் போன்ற பிரகாசம்; திடீர், கண்கவர் தொழில்முறை வெற்றி.";
"yoga_formation_vidyut_yoga" = "11ம் அதிபதியாக சுக்கிரன் லக்னாதிபதியுடன் இணைந்து உயர்ந்த நவாம்சத்தில் இருக்கிறார்.";

// [−] Vikalangapatni Yoga
"yoga_name_vikalangapatni_yoga" = "விகலங்கபத்னி யோகம்";
"yoga_outcome_vikalangapatni_yoga" = "வாழ்க்கைத் துணை சுகாதார சவால்கள் அல்லது உடல் குறைபாடுகளை சந்திக்க நேரிடும்.";
"yoga_formation_vikalangapatni_yoga" = "7ம் அதிபதியும் சுக்கிரனும் துஸ்தானத்தில் தோஷத்தால் பாதிக்கப்பட்டுள்ளனர்.";

// [+] Vimala Yoga
"yoga_name_vimala_yoga" = "விமல யோகம்";
"yoga_outcome_vimala_yoga" = "இழப்புகள் மற்றும் கழிவுகளை குறைக்கிறது; பற்றின்மை மூலம் தனிநபர் சுதந்திரத்தை அடைகிறார்.";
"yoga_formation_vimala_yoga" = "6, 8 அல்லது 12வது வீட்டில் 12வது அதிபதி (துஸ்தானத்தில் துஸ்தானம்).";

// [−] Vishaprayoga Yoga
"yoga_name_vishaprayoga_yoga" = "விஷப்ரயோக யோகம்";
"yoga_outcome_vishaprayoga_yoga" = "விஷம் அல்லது நச்சு தொடர்பான சுகாதார பிரச்சினைகள் ஆபத்து; உணவுக் கட்டுப்பாடு தேவை.";
"yoga_formation_vishaprayoga_yoga" = "ராகு மற்றும் 2வது வீடு சம்பந்தப்பட்ட குறிப்பிட்ட தீங்கான சேர்க்கைகள்.";

// [+] Vishnu Yoga
"yoga_name_vishnu_yoga" = "விஷ்ணு யோகம்";
"yoga_outcome_vishnu_yoga" = "விஷ்ணுவின் அருள்; தெய்வீக பாதுகாப்பு, செழிப்பு மற்றும் ஆன்மீக தகுதி மூலம் நீதியான உலக வெற்றி.";
"yoga_formation_vishnu_yoga" = "10ல் 9ம் அதிபதி, 9ல் 10ம் அதிபதி (பரிமாற்றம்).";

// [−] Vrana Yoga
"yoga_name_vrana_yoga" = "வராண யோகம்";
"yoga_outcome_vrana_yoga" = "காயங்கள், கொதிப்புகள் அல்லது அறுவை சிகிச்சை நிலைமைகளுக்கு எளிதில் பாதிக்கப்படுதல்; காயம் ஏற்படக்கூடிய அரசியலமைப்பு.";
"yoga_formation_vrana_yoga" = "செவ்வாய் மற்றும் கேது லக்னா அல்லது 6 ஆம் வீட்டை பாதிக்கிறது.";

// [−] Yuddha Marana Yoga
"yoga_name_yuddha_marana_yoga" = "யுத்த மரண யோகம்";
"yoga_outcome_yuddha_marana_yoga" = "மோதல்கள், விபத்துக்கள் அல்லது வன்முறைச் சூழ்நிலைகளால் மரணம் ஏற்படும் அபாயம்.";
"yoga_formation_yuddha_marana_yoga" = "6/8ல் உள்ள செவ்வாய் லக்னத்தை கேது ஈடுபாட்டுடன் பாதிக்கிறது.";

// [+] Yuddha Praveena Yoga
"yoga_name_yuddha_praveena_yoga" = "யுத்த பிரவின யோகம்";
"yoga_outcome_yuddha_praveena_yoga" = "போர், விவாதம் அல்லது போட்டித் தொழில்களில் மூலோபாய வலிமையை அளிக்கிறது.";
"yoga_formation_yuddha_praveena_yoga" = "3 ஆம் அதிபதியின் நவாம்ச அதிபதி சங்கிலியின் மூலம் சொந்த வர்காஸில் உள்ள கிரகத்தில் முடிவடைகிறது.";

// [+] Yuddhatpaschaddrudha Yoga
