"yoga_formation_khalawata_yoga" = "ലഗ്നാധിപൻ ശനിയുടെ ഭാവം അല്ലെങ്കിൽ സംയുക്തം കൊണ്ട് പ്രവർത്തനപരമായി ദോഷകരമാണ്.";

// [−] Krisanga Yoga
"yoga_name_krisanga_yoga" = "കൃസംഗ യോഗ";
