// [+] Matrudeerghayur Yoga (196)
"yoga_name_matrudeerghayur_yoga_196" = "മാതൃദീർഘായൂർ യോഗ (196)";
"yoga_outcome_matrudeerghayur_yoga_196" = "അമ്മയ്ക്ക് ദീർഘായുസ്സ്; ഒരു വ്യക്തിക്ക് വിപുലമായ മാതൃ സാന്നിദ്ധ്യവും പിന്തുണയും ലഭിക്കുന്നു.";
"yoga_formation_matrudeerghayur_yoga_196" = "4-ാം അധിപൻ ഗുണകരമായ ഭാവങ്ങളുള്ള ശക്തനാണ്, ചന്ദ്രൻ നന്നായി സ്ഥിതി ചെയ്യുന്നു (var. 1).";

// [+] Matrudeerghayur Yoga (197)
"yoga_name_matrudeerghayur_yoga_197" = "മാതൃദീർഘായൂർ യോഗ (197)";
"yoga_outcome_matrudeerghayur_yoga_197" = "അമ്മയുടെ ദീർഘായുസ്സും പരിപോഷിപ്പിക്കുന്ന കുടുംബ അന്തരീക്ഷവും സ്ഥിരീകരിച്ചു.";
"yoga_formation_matrudeerghayur_yoga_197" = "ശുക്രനും ചന്ദ്രനും പിന്തുണയ്ക്കുന്നു, നാലാമത്തെ വീട് സംരക്ഷിക്കപ്പെടുന്നു (var. 2).";

// [−] Matrugami Yoga
"yoga_name_matrugami_yoga" = "മാതൃഗാമി യോഗ";
"yoga_outcome_matrugami_yoga" = "മാതൃ ബന്ധങ്ങളിലെ അനാരോഗ്യകരമായ അല്ലെങ്കിൽ അനുചിതമായ അറ്റാച്ച്‌മെൻ്റ് പാറ്റേണുകൾ.";
"yoga_formation_matrugami_yoga" = "ശുക്രനും 4-ാം അധിപനും പ്രത്യേക നിഷിദ്ധ കോമ്പിനേഷനുകളിൽ.";

// [+] Matrumooladhana Yoga
"yoga_name_matrumooladhana_yoga" = "മാതൃമൂലധന യോഗ";
"yoga_outcome_matrumooladhana_yoga" = "മാതൃ അനന്തരാവകാശം, റിയൽ എസ്റ്റേറ്റ് അല്ലെങ്കിൽ മാതൃരാജ്യ ബന്ധങ്ങൾ എന്നിവയിലൂടെയുള്ള സമ്പത്ത്.";
"yoga_formation_matrumooladhana_yoga" = "നാലാമത്തെ അധിപൻ ഗുണപരമായ പിന്തുണയോടെ 2, 11 എന്നിവയുമായി ബന്ധപ്പെട്ടിരിക്കുന്നു.";

// [−] Matrunasa Yoga (198)
"yoga_name_matrunasa_yoga_198" = "മാതൃനാസ യോഗ (198)";
"yoga_outcome_matrunasa_yoga_198" = "അമ്മയുടെ ആദ്യകാല നഷ്ടം അല്ലെങ്കിൽ ഗുരുതരമായ മാതൃ ആരോഗ്യ പ്രതിസന്ധി.";
"yoga_formation_matrunasa_yoga_198" = "4-ാം അധിപനും ചന്ദ്രനും ദോഷങ്ങളാൽ കഠിനമായി പീഡിപ്പിക്കപ്പെടുന്നു (var. 1).";

// [−] Matrunasa Yoga (199)
"yoga_name_matrunasa_yoga_199" = "മാതൃനാസ യോഗ (199)";
"yoga_outcome_matrunasa_yoga_199" = "അമ്മ ജീവന് ഭീഷണിയായ സാഹചര്യങ്ങളെ അഭിമുഖീകരിക്കുന്നു; മാതൃ ക്ഷേമം അപകടത്തിലാണ്.";
"yoga_formation_matrunasa_yoga_199" = "ചൊവ്വയും ശനിയും നാലാം ഭാവത്തെയും ചന്ദ്രനെയും ബാധിക്കുന്നു (var. 2).";

// [−] Matrusapa Sutakshaya Yoga
"yoga_name_matrusapa_sutakshaya_yoga" = "മാതൃസപ സുതക്ഷയ യോഗ";
"yoga_outcome_matrusapa_sutakshaya_yoga" = "സന്തതികളെ ബാധിക്കുന്ന അമ്മയുടെ ശാപം; പരിഹരിക്കപ്പെടാത്ത മാതൃ കർമ്മം കുട്ടികളെ ബാധിക്കുന്നു.";
"yoga_formation_matrusapa_sutakshaya_yoga" = "ദോഷകരമായ കോമ്പിനേഷനുകളിൽ ചന്ദ്രൻ 5-ാം അധിപനെ ബാധിച്ചിരിക്കുന്നു.";

// [+] Matsya Yoga
"yoga_name_matsya_yoga" = "മത്സ്യ യോഗ";
"yoga_outcome_matsya_yoga" = "ആഴത്തിലുള്ള, സമുദ്രം പോലെയുള്ള ജ്ഞാനവും ആത്മീയ അറിവും; പഠിച്ചു, അനുകമ്പയുള്ള, പരക്കെ യാത്രചെയ്തു.";
"yoga_formation_matsya_yoga" = "ലഗ്നത്തിൽ/9-ൽ ദോഷങ്ങൾ, ഗുണഭോക്താക്കൾ 5-ൽ, മിശ്രിതം 4/8-ൽ.";

// [−] Mooka Yoga
"yoga_name_mooka_yoga" = "മുക യോഗ";
"yoga_outcome_mooka_yoga" = "സംഭാഷണ വൈകല്യങ്ങൾ അല്ലെങ്കിൽ ആശയവിനിമയ ബുദ്ധിമുട്ടുകൾ; തെറാപ്പിയും പ്രതിവിധികളും സഹായിച്ചേക്കാം.";
"yoga_formation_mooka_yoga" = "ബുധൻ കഠിനമായി ബാധിച്ചു, 2-ാം അധിപൻ ദോഷങ്ങളാൽ തളർന്നു.";

// [+] Mridanga Yoga
"yoga_name_mridanga_yoga" = "മൃദംഗ യോഗ";
"yoga_outcome_mridanga_yoga" = "ഒരു ആചാരപരമായ ഡ്രം പോലെ പരമോന്നത രാജകീയ പദവി; പ്രശസ്തി ദേശത്തുടനീളം മുഴങ്ങുന്നു.";
"yoga_formation_mridanga_yoga" = "ലഗ്നാധിപൻ ശക്തൻ, എല്ലാ ഗ്രഹങ്ങളും കേന്ദ്രങ്ങളിൽ/ത്രികോണങ്ങളിൽ.";

// [+] Ardha Chandra Yoga
"yoga_name_nabhasa_ardha_chandra" = "അർദ്ധ ചന്ദ്രയോഗം";
"yoga_outcome_nabhasa_ardha_chandra" = "അർദ്ധ ചന്ദ്ര രൂപീകരണം; സൈന്യാധിപൻ, ശാരീരികമായി ശക്തൻ, ആകർഷകൻ, ധനികൻ.";
"yoga_formation_nabhasa_ardha_chandra" = "ഒരു കേന്ദ്രത്തിൽ നിന്ന് തുടർച്ചയായി ഏഴ് വീടുകളിലെ എല്ലാ ഗ്രഹങ്ങളും.";

// [+] Chandra Yoga (Nabhasa)
"yoga_name_nabhasa_chandra" = "ചന്ദ്രയോഗം (നഭാസ)";
"yoga_outcome_nabhasa_chandra" = "ചന്ദ്ര രൂപീകരണം; പ്രസന്നമായ രൂപം, ആജ്ഞാപിക്കുന്ന പൊക്കം, രാജകീയ ഉപദേഷ്ടാക്കൾ.";
"yoga_formation_nabhasa_chandra" = "രാശിചക്രത്തിൻ്റെ മുകൾ പകുതിയിലെ എല്ലാ ഗ്രഹങ്ങളും (7-12 വീടുകൾ).";

// [+] Chapa Yoga (Nabhasa)
"yoga_name_nabhasa_chapa" = "ചാപ യോഗ (നഭാസ)";
"yoga_outcome_nabhasa_chapa" = "വില്ലു രൂപീകരണം; സത്യസന്ധൻ, കാവൽ നിധി, ആദ്യകാല ജീവിതത്തിലും അവസാനത്തിലും സന്തോഷം.";
"yoga_formation_nabhasa_chapa" = "10-4 വീടുകളിലെ എല്ലാ ഗ്രഹങ്ങളും (10 മുതൽ 4 വരെ സ്പാൻ).";

// [+] Chhatra Yoga
"yoga_name_nabhasa_chhatra" = "ഛത്രയോഗം";
"yoga_outcome_nabhasa_chhatra" = "കുട രൂപീകരണം; മറ്റുള്ളവരുടെ സംരക്ഷകൻ, എല്ലാവർക്കും സഹായകൻ, സുഖപ്രദമായ വാർദ്ധക്യം.";
"yoga_formation_nabhasa_chhatra" = "7-1 വീടുകളിലെ എല്ലാ ഗ്രഹങ്ങളും (7 മുതൽ 1 വരെ സ്പാൻ).";

// [+] Damini Yoga
"yoga_name_nabhasa_damini" = "ദാമിനി യോഗ";
"yoga_outcome_nabhasa_damini" = "മിന്നൽ രൂപീകരണം; ഉദാരമനസ്കൻ, സഹായകൻ, ധനികൻ, പരോപകാരി സ്വഭാവം.";
"yoga_formation_nabhasa_damini" = "തുടർച്ചയായ ആറ് വീടുകളിലെ എല്ലാ ഗ്രഹങ്ങളും.";

// [+] Danda Yoga
"yoga_name_nabhasa_danda" = "ദണ്ഡ യോഗ";
"yoga_outcome_nabhasa_danda" = "സ്റ്റാഫ് രൂപീകരണം; കുടുംബത്തിൻ്റെ നഷ്ടം അല്ലെങ്കിൽ ഒറ്റപ്പെടൽ; സേവനാധിഷ്ഠിത ജീവിതം.";
"yoga_formation_nabhasa_danda" = "10 മുതൽ തുടർച്ചയായി നാല് വീടുകളിൽ ഗ്രഹങ്ങൾ.";

// [+] Gada Yoga
"yoga_name_nabhasa_gada" = "ഗദാ യോഗ";
"yoga_outcome_nabhasa_gada" = "ഗദ പോലുള്ള ശക്തി; ആചാരങ്ങൾ, മതപരമായ പ്രവർത്തനങ്ങൾ, അല്ലെങ്കിൽ പരമ്പരാഗത പ്രവർത്തനങ്ങൾ എന്നിവയിലൂടെയുള്ള സമ്പത്ത്.";
"yoga_formation_nabhasa_gada" = "തുടർച്ചയായി രണ്ട് കേന്ദ്ര ഭവനങ്ങളിലെ ഗ്രഹങ്ങൾ.";

// [+] Gola Yoga (Nabhasa)
"yoga_name_nabhasa_gola" = "ഗോല യോഗ (നഭാസ)";
"yoga_outcome_nabhasa_gola" = "ഗോള രൂപീകരണം; ദരിദ്രൻ, വൃത്തികെട്ട, അറിവില്ലാത്ത, എന്നാൽ ശക്തവും അലഞ്ഞുതിരിയുന്നതുമായ സ്വഭാവം.";
"yoga_formation_nabhasa_gola" = "എല്ലാ ഗ്രഹങ്ങളും ഒരൊറ്റ വീട്ടിൽ.";

// [+] Hala Yoga
"yoga_name_nabhasa_hala" = "ഹല യോഗ";
"yoga_outcome_nabhasa_hala" = "കാർഷിക സമൃദ്ധി; ഇടത്തരം സുഖസൗകര്യങ്ങളുള്ള കഠിനാധ്വാനിയായ പ്രകൃതം.";
"yoga_formation_nabhasa_hala" = "കേന്ദ്രങ്ങൾ ഒഴികെയുള്ള വീടുകളിലെ ഗ്രഹങ്ങൾ, കലപ്പയുടെ ആകൃതി ഉണ്ടാക്കുന്നു.";

// [+] Ishu Yoga
"yoga_name_nabhasa_ishu" = "ഈഷു യോഗ";
"yoga_outcome_nabhasa_ishu" = "അമ്പ് രൂപീകരണം; സൈനിക, പോലീസ് അല്ലെങ്കിൽ ജയിൽ ഭരണവുമായി ബന്ധപ്പെട്ടിരിക്കുന്നു.";
"yoga_formation_nabhasa_ishu" = "4 മുതൽ തുടർച്ചയായി നാല് വീടുകളിൽ ഗ്രഹങ്ങൾ.";

// [+] Kamala Yoga
"yoga_name_nabhasa_kamala" = "കമല യോഗ";
"yoga_outcome_nabhasa_kamala" = "താമര രൂപീകരണം; സുസ്ഥിരമായ പ്രശസ്തി, സദ്ഗുണമുള്ള ജീവിതം, സമൃദ്ധിയുടെ നൂറുവർഷങ്ങൾ.";
"yoga_formation_nabhasa_kamala" = "നാല് കേന്ദ്ര വീടുകളിലെ എല്ലാ ഗ്രഹങ്ങളും (1/4/7/10).";

// [+] Kedara Yoga
"yoga_name_nabhasa_kedara" = "കേദാരയോഗം";
"yoga_outcome_nabhasa_kedara" = "ഫീൽഡ് രൂപീകരണം; കാർഷിക സമ്പത്ത്, പലർക്കും സഹായകമായ, സത്യസന്ധനായ സ്വഭാവം.";
"yoga_formation_nabhasa_kedara" = "തുടർച്ചയായി അഞ്ച് വീടുകളിൽ എല്ലാ ഗ്രഹങ്ങളും.";

// [+] Kuta Yoga
"yoga_name_nabhasa_kuta" = "കുട യോഗ";
"yoga_outcome_nabhasa_kuta" = "കോട്ട രൂപീകരണം; നുണയൻ അല്ലെങ്കിൽ നയതന്ത്രജ്ഞൻ, ജയിലുകളുമായോ തടവുകാരുമായോ ബന്ധപ്പെട്ടിരിക്കുന്നു.";
"yoga_formation_nabhasa_kuta" = "4-10 വീടുകളിലെ എല്ലാ ഗ്രഹങ്ങളും.";

// [+] Mala Yoga
"yoga_name_nabhasa_mala" = "മാല യോഗ";
"yoga_outcome_nabhasa_mala" = "മാല രൂപീകരണം; വാഹനങ്ങൾ, സ്വത്ത്, ശാശ്വതമായ സന്തോഷം എന്നിവയുള്ള സുഖജീവിതം.";
"yoga_formation_nabhasa_mala" = "തുടർച്ചയായ മൂന്ന് ത്രികോണങ്ങളിലെ ഗ്രഹങ്ങൾ (1-5-9, 2-6-10, അല്ലെങ്കിൽ 3-7-11).";

// [+] Musala Yoga
"yoga_name_nabhasa_musala" = "മുസാല യോഗ";
"yoga_outcome_nabhasa_musala" = "ഉറച്ച തീരുമാനവും പ്രശസ്തിയും സമ്പത്തും; സ്ഥിരമായ, നിശ്ചയദാർഢ്യമുള്ള സ്വഭാവം.";
"yoga_formation_nabhasa_musala" = "എല്ലാ ഗ്രഹങ്ങളും നിശ്ചിത ചിഹ്നങ്ങളിൽ (ടാരസ്, ലിയോ, സ്കോർപിയോ, അക്വേറിയസ്).";

// [+] Nala Yoga
"yoga_name_nabhasa_nala" = "നളയോഗം";
"yoga_outcome_nabhasa_nala" = "ബഹുമുഖ, പല മേഖലകളിലും പ്രാവീണ്യം; ചാഞ്ചാടുന്ന ഭാഗ്യത്തോടുകൂടിയ സുന്ദര രൂപം.";
"yoga_formation_nabhasa_nala" = "എല്ലാ ഗ്രഹങ്ങളും ഇരട്ട രാശികളിൽ (ജെമിനി, കന്നി, ധനു, മീനം).";

// [+] Nauka Yoga
"yoga_name_nabhasa_nauka" = "നൗക യോഗ";
"yoga_outcome_nabhasa_nauka" = "ബോട്ട് രൂപീകരണം; ജലവുമായി ബന്ധപ്പെട്ട ജോലികളിലൂടെയുള്ള സമ്പത്ത്, കടലിലെ പ്രശസ്തി.";
"yoga_formation_nabhasa_nauka" = "1-7 വരെയുള്ള വീടുകളിലെ എല്ലാ ഗ്രഹങ്ങളും (രാശിചക്രത്തിൻ്റെ പകുതി).";

// [−] Pasa Yoga
"yoga_name_nabhasa_pasa" = "പാസ യോഗ";
"yoga_outcome_nabhasa_pasa" = "നൂസ് രൂപീകരണം; ബുദ്ധിമുട്ടുകളിൽ കുടുങ്ങി, തടവിലാക്കപ്പെട്ട, അല്ലെങ്കിൽ ദാസനെപ്പോലെയുള്ള അസ്തിത്വം.";
"yoga_formation_nabhasa_pasa" = "ഗ്രഹങ്ങൾ പ്രത്യേക ബന്ധിത പാറ്റേണുകളിൽ മാത്രം.";

// [+] Rajju Yoga
"yoga_name_nabhasa_rajju" = "രജു യോഗ";
"yoga_outcome_nabhasa_rajju" = "യാത്രയോടുള്ള ഇഷ്ടം, അലഞ്ഞുതിരിയുന്ന പ്രകൃതി; ചലനാത്മകതയിലൂടെയും പൊരുത്തപ്പെടുത്തലിലൂടെയും വിജയം.";
"yoga_formation_nabhasa_rajju" = "ചലിക്കുന്ന രാശികളിലെ എല്ലാ ഗ്രഹങ്ങളും (ഏരീസ്, കാൻസർ, തുലാം, മകരം).";

// [+] Samudra Yoga
"yoga_name_nabhasa_samudra" = "സമുദ്രയോഗം";
"yoga_outcome_nabhasa_samudra" = "സമുദ്ര രൂപീകരണം; സമ്പന്നൻ, അനേകം സുഖങ്ങൾ, ആസ്വാദനത്തിൽ രാജാവിനു തുല്യം.";
"yoga_formation_nabhasa_samudra" = "എല്ലാ കേന്ദ്ര ഗ്രൂപ്പുകളിലും ഗ്രഹങ്ങൾ തുല്യമായി വിതരണം ചെയ്യപ്പെടുന്നു.";

// [−] Sarpa Yoga
"yoga_name_nabhasa_sarpa" = "സർപ്പ യോഗ";
"yoga_outcome_nabhasa_sarpa" = "ദുരിതം, ദാരിദ്ര്യം, സർപ്പം പോലെയുള്ള കഷ്ടപ്പാടുകൾ; ഉപജീവനത്തിനായി മറ്റുള്ളവരെ ആശ്രയിക്കുന്നു.";
"yoga_formation_nabhasa_sarpa" = "കർദിനാൾ ഗൃഹങ്ങളിലെ എല്ലാ ഗ്രഹങ്ങളും (ലഗ്നത്തിൽ നിന്ന് 4/8/12).";

// [−] Shakata Yoga
"yoga_name_nabhasa_shakata" = "ശകട യോഗ";
"yoga_outcome_nabhasa_shakata" = "വണ്ടി പോലെയുള്ള ജീവിതം - ഉയർച്ച താഴ്ചകൾ; സമ്പത്തിനെ തുടർന്ന് ദാരിദ്ര്യം.";
"yoga_formation_nabhasa_shakata" = "1, 7 വീടുകളിൽ മാത്രം ഗ്രഹങ്ങൾ.";

// [+] Shakti Yoga
"yoga_name_nabhasa_shakti" = "ശക്തി യോഗ";
"yoga_outcome_nabhasa_shakti" = "കുന്തം രൂപീകരണം; അലസമായ സ്വഭാവം എന്നാൽ സ്ഥിരോത്സാഹത്തിലൂടെ സമ്പത്ത് നേടുന്നു.";
"yoga_formation_nabhasa_shakti" = "7 മുതൽ തുടർച്ചയായി നാല് വീടുകളിൽ ഗ്രഹങ്ങൾ.";

// [+] Shringataka Yoga
"yoga_name_nabhasa_shringataka" = "ശൃംഗടക യോഗ";
"yoga_outcome_nabhasa_shringataka" = "പീക്ക് രൂപീകരണം; സംതൃപ്തി, മനുഷ്യസ്‌നേഹം, സൗഹാർദ്ദപരമായ മനോഭാവം.";
"yoga_formation_nabhasa_shringataka" = "ത്രികോണ വീടുകളിലെ ഗ്രഹങ്ങൾ (1, 5, 9).";

// [−] Shula Yoga
"yoga_name_nabhasa_shula" = "ശൂലയോഗം";
"yoga_outcome_nabhasa_shula" = "ട്രൈഡൻ്റ് രൂപീകരണം; മൂർച്ചയുള്ള, ധീരമായ, എന്നാൽ പാവപ്പെട്ട; രോഗസാധ്യതയും ഏറ്റുമുട്ടലും.";
"yoga_formation_nabhasa_shula" = "തുടർച്ചയായി മൂന്ന് വീടുകളിൽ ഗ്രഹങ്ങൾ.";

// [+] Vajra Yoga
"yoga_name_nabhasa_vajra" = "വജ്രയോഗം";
"yoga_outcome_nabhasa_vajra" = "വജ്രം പോലെയുള്ള തിളക്കം; സുന്ദരൻ, യൗവനത്തിലും വാർദ്ധക്യത്തിലും സന്തുഷ്ടൻ, ആയോധന വീര്യം.";
"yoga_formation_nabhasa_vajra" = "ബെനിഫിക്‌സ് 1/7, മെലിഫിക്‌സ് 4/10-ൽ.";

// [+] Vapi Yoga
"yoga_name_nabhasa_vapi" = "വാപി യോഗ";
"yoga_outcome_nabhasa_vapi" = "കിണർ രൂപീകരണം; സമ്പത്ത് ശേഖരണം, പൂഴ്ത്തിവെക്കൽ പ്രവണത, നിലനിൽക്കുന്ന ഭാഗ്യം.";
"yoga_formation_nabhasa_vapi" = "കേന്ദ്രേതര ഭവനങ്ങളിലെ എല്ലാ ഗ്രഹങ്ങളും (പാനപര/അപ്പോക്ലിമ).";

// [+] Veena Yoga
"yoga_name_nabhasa_veena" = "വിന യോഗ";
"yoga_outcome_nabhasa_veena" = "ലൂട്ട് രൂപീകരണം; സംഗീതം, നൃത്തം, കലകൾ എന്നിവയുടെ സ്നേഹി; നൈപുണ്യവും സന്തുഷ്ടവുമായ സ്വഭാവം.";
"yoga_formation_nabhasa_veena" = "ഏഴ് ഗ്രഹങ്ങളും തുടർച്ചയായി ഏഴ് വീടുകളിൽ.";

// [+] Vihaga Yoga
"yoga_name_nabhasa_vihaga" = "വിഹാഗ യോഗ";
"yoga_outcome_nabhasa_vihaga" = "പക്ഷിയെപ്പോലെയുള്ള സ്വാതന്ത്ര്യം; അംബാസഡർ സ്വഭാവം, അലഞ്ഞുതിരിയൽ, സന്ദേശം വഹിക്കുന്ന റോളുകൾ.";
"yoga_formation_nabhasa_vihaga" = "4, 10 വീടുകളിൽ മാത്രം ഗ്രഹങ്ങൾ.";

// [+] Yava Yoga
"yoga_name_nabhasa_yava" = "യവ യോഗ";
"yoga_outcome_nabhasa_yava" = "ബാർലി-ധാന്യ പാറ്റേൺ; ജീവകാരുണ്യ സ്വഭാവം, മധ്യവയസ്സിലെ സന്തോഷം.";
"yoga_formation_nabhasa_yava" = "ബെനഫിക്‌സ് 4/10-ൽ, മെലെഫിക്‌സ് 1/7-ൽ.";

// [+] Yuga Yoga
"yoga_name_nabhasa_yuga" = "യുഗ യോഗ";
"yoga_outcome_nabhasa_yuga" = "നുകം രൂപീകരണം; പാഷണ്ഡത, ദരിദ്രം, പുറംതള്ളപ്പെട്ട പ്രവണതകൾ; പാരമ്പര്യേതര പാത.";
"yoga_formation_nabhasa_yuga" = "തുടർച്ചയായി രണ്ട് വീടുകളിൽ എല്ലാ ഗ്രഹങ്ങളും.";

// [+] Yupa Yoga
"yoga_name_nabhasa_yupa" = "യൂപ യോഗ";
"yoga_outcome_nabhasa_yupa" = "ത്യാഗപരമായ പോസ്റ്റ്; ഉദാരമനസ്കത, പണ്ഡിതൻ, മതപരവും കേന്ദ്രീകൃതവുമായ സ്വഭാവം.";
"yoga_formation_nabhasa_yupa" = "ലഗ്നത്തിൽ തുടങ്ങി തുടർച്ചയായി നാല് വീടുകളിലെ ഗ്രഹങ്ങൾ.";

// [−] Netranasa Yoga
"yoga_name_netranasa_yoga" = "നേത്രനാശ യോഗ";
"yoga_outcome_netranasa_yoga" = "നേത്ര പ്രശ്നങ്ങൾ അല്ലെങ്കിൽ കാഴ്ച വൈകല്യങ്ങൾക്കുള്ള സാധ്യത; പതിവ് നേത്ര പരിചരണം അത്യാവശ്യമാണ്.";
"yoga_formation_netranasa_yoga" = "2/12-ാം ഭാവാധിപന്മാർ ദോഷങ്ങളാൽ പീഡിപ്പിക്കപ്പെടുന്നു, സൂര്യൻ/ചന്ദ്രൻ ബലഹീനനായി.";

// [+] Nishkapata Yoga (205)
"yoga_name_nishkapata_yoga_205" = "നിഷ്കപത യോഗ (205)";
"yoga_outcome_nishkapata_yoga_205" = "സുതാര്യവും വഞ്ചനയില്ലാത്തതുമായ സ്വഭാവം നൽകുന്നു; സ്വാഭാവികമായും സത്യസന്ധത പുലർത്തുകയും സമഗ്രതയിലൂടെ ബഹുമാനം നേടുകയും ചെയ്യുന്നു.";
"yoga_formation_nishkapata_yoga_205" = "ആത്മാർത്ഥതയെ സൂചിപ്പിക്കുന്ന ഗുണകരമായ ഗ്രഹ സംയോജനങ്ങൾ (var. 1).";

// [+] Nishkapata Yoga (206)
"yoga_name_nishkapata_yoga_206" = "നിഷ്കപത യോഗ (206)";
"yoga_outcome_nishkapata_yoga_206" = "നേരായ സ്വഭാവവും ധാർമ്മിക വിശുദ്ധിയും നൽകുന്നു; സത്യസന്ധമായ ഇടപാടുകളിലൂടെ അഭിവൃദ്ധിപ്പെടുന്നു.";
"yoga_formation_nishkapata_yoga_206" = "ആത്മാർത്ഥതയെ സൂചിപ്പിക്കുന്ന ഗുണപരമായ ഗ്രഹ സംയോജനങ്ങൾ (var. 2).";

// [−] Nishturabhashi Yoga
"yoga_name_nishturabhashi_yoga" = "നിഷ്തുരഭാഷി യോഗ";
"yoga_outcome_nishturabhashi_yoga" = "പരുഷമായ സംസാരത്തോടുള്ള പ്രവണതയെ സൂചിപ്പിക്കുന്നു; ശ്രദ്ധാപൂർവമായ ആശയവിനിമയം ഉപദേശിച്ചു.";
"yoga_formation_nishturabhashi_yoga" = "ദോഷഫലങ്ങൾ ബുധനെയും രണ്ടാം ഭാവത്തെയും സ്വാധീനിക്കുന്നു.";

// [+] Obhayachari Yoga
"yoga_name_obhayachari_yoga" = "ഒഭയാചാരി യോഗ";
"yoga_outcome_obhayachari_yoga" = "വാക്ചാതുര്യം, സുന്ദരമായ രൂപം, രാജകീയ സ്വഭാവം, ജീവിതത്തിൽ വ്യതിരിക്തത എന്നിവ നൽകുന്നു.";
"yoga_formation_obhayachari_yoga" = "സൂര്യനിൽ നിന്ന് 2-ലും 12-ലും ഉള്ള ഗ്രഹങ്ങൾ (ചന്ദ്രൻ/രാഹു/കേതു ഒഴികെ).";

// [+] Parakrama Yoga
"yoga_name_parakrama_yoga" = "പരാക്രമ യോഗ";
"yoga_outcome_parakrama_yoga" = "ധീരത ആവശ്യമുള്ള പരിശ്രമങ്ങളിൽ അസാധാരണമായ ധൈര്യവും ശാരീരിക ശക്തിയും സാഹസിക മനോഭാവവും നൽകുന്നു.";
"yoga_formation_parakrama_yoga" = "ഗുണകരമായ നവാംശത്തിലെ മൂന്നാം അധിപൻ ഗുണപരമായ സ്വാധീനങ്ങളോടെ; അനുകൂലമായ അന്തസ്സിൽ ചൊവ്വ.";

// [−] Parannabhojana Yoga
"yoga_name_parannabhojana_yoga" = "പരന്നഭോജന യോഗ";
"yoga_outcome_parannabhojana_yoga" = "ഭക്ഷണത്തിനായി മറ്റുള്ളവരെ ആശ്രയിക്കുന്നു; സാമ്പത്തിക പരിമിതികൾ ജീവകാരുണ്യത്തിലോ രക്ഷാകർതൃത്വത്തിലോ ആശ്രയിക്കാൻ നിർബന്ധിതരാകുന്നു.";
"yoga_formation_parannabhojana_yoga" = "2-ാം അധിപൻ ബലഹീനൻ, ആറാം അധിപൻ ഭക്ഷണ ഗൃഹങ്ങളെ സ്വാധീനിക്കുന്നു.";

// [+] Parihasaka Yoga
"yoga_name_parihasaka_yoga" = "പരിഹാസക യോഗ";
"yoga_outcome_parihasaka_yoga" = "സ്വാഭാവിക ബുദ്ധി, നർമ്മം, രസകരമായ വ്യക്തിത്വം; സാമൂഹിക സമ്മേളനങ്ങളിൽ സന്തോഷം നൽകുന്നു.";
"yoga_formation_parihasaka_yoga" = "നർമ്മ സ്വഭാവം സൃഷ്ടിക്കുന്ന പ്രത്യേക വീടുകളിലെ ഗുണങ്ങൾ.";

// [+] Parijatha Yoga
"yoga_name_parijatha_yoga" = "പാരിജാത യോഗ";
"yoga_outcome_parijatha_yoga" = "മെറിറ്റിലൂടെയും സ്ഥിരോത്സാഹത്തിലൂടെയും പടിപടിയായി, എന്നാൽ തടയാൻ കഴിയാത്ത അധികാരത്തിലേക്കുള്ള ഉയർച്ച.";
"yoga_formation_parijatha_yoga" = "ലഗ്നാധിപൻ്റെ ഡിസ്‌പോസിറ്റർ ശൃംഖല സ്വന്തം ഗ്രഹത്തിലേക്ക് നയിക്കുന്നു/കേന്ദ്ര/ത്രികോണത്തിൽ ഉന്നതസ്ഥാനത്ത്.";

// [+] Parvata Yoga
"yoga_name_parvata_yoga" = "പർവ്വത യോഗ";
"yoga_outcome_parvata_yoga" = "പർവ്വതം പോലെയുള്ള തൊഴിൽ സ്ഥിരത, സമ്പത്ത്, പ്രശസ്തി, ഔദാര്യം.";
"yoga_formation_parvata_yoga" = "കേന്ദ്രങ്ങളിലെ ഗുണഫലങ്ങൾ; 6-ഉം 8-ഉം വീടുകൾ ശൂന്യം/അനുഭവപ്പെടാത്തവ.";

// [−] Peenasaroga Yoga
"yoga_name_peenasaroga_yoga" = "പിനസരോഗ യോഗ";
"yoga_outcome_peenasaroga_yoga" = "വിട്ടുമാറാത്ത സൈനസൈറ്റിസ്, മൂക്കിലെ തകരാറുകൾ അല്ലെങ്കിൽ ശ്വസന അലർജികൾ.";
"yoga_formation_peenasaroga_yoga" = "ചന്ദ്രനും നാലാം ഭാവാധിപനും ശനിയും രാഹുവും ബാധിച്ചിരിക്കുന്നു.";

// [−] Pisacha Grastha Yoga
"yoga_name_pisacha_grastha_yoga" = "പിശാച ഗ്രസ്ത യോഗ";
"yoga_outcome_pisacha_grastha_yoga" = "മാനസിക അസ്വസ്ഥതകൾ അല്ലെങ്കിൽ യുക്തിരഹിതമായ ഭയം; മാനസികാരോഗ്യ സമ്പ്രദായങ്ങൾ ആശ്വാസം നൽകുന്നു.";
"yoga_formation_pisacha_grastha_yoga" = "രാഹു/കേതു കൂടിച്ചേരുന്ന ചന്ദ്രനോ ലഗ്നാധിപനോ ഗുണദോഷമില്ല.";

// [−] Pitrusapa Sutakshaya Yoga
"yoga_name_pitrusapa_sutakshaya_yoga" = "പിതൃസപ സുതക്ഷയയോഗം";
"yoga_outcome_pitrusapa_sutakshaya_yoga" = "സന്തതികളെ ബാധിക്കുന്ന പിതാവിൻ്റെ ശാപം; പരിഹരിക്കപ്പെടാത്ത പിതൃ കർമ്മം കുട്ടികളെ ബാധിക്കുന്നു.";
"yoga_formation_pitrusapa_sutakshaya_yoga" = "ദോഷകരമായ കോമ്പിനേഷനുകളിൽ സൂര്യൻ 5-ാം അധിപനെ ബാധിച്ചിരിക്കുന്നു.";

// [−] Pittaroga Yoga
"yoga_name_pittaroga_yoga" = "പിത്തരോഗ യോഗ";
"yoga_outcome_pittaroga_yoga" = "പിത്ത സംബന്ധമായ അസുഖങ്ങൾക്കുള്ള സാധ്യത (വീക്കം, അസിഡിറ്റി, കരൾ പ്രശ്നങ്ങൾ).";
"yoga_formation_pittaroga_yoga" = "സൂര്യനും ചൊവ്വയും ലഗ്നത്തെ/6-ൽ അഗ്നി-ഘടക അസന്തുലിതാവസ്ഥയെ ബാധിക്കുന്നു.";

// [−] Pretasapa Yoga
"yoga_name_pretasapa_yoga" = "പ്രേതസപ യോഗ";
"yoga_outcome_pretasapa_yoga" = "കുടുംബത്തെ ബാധിക്കുന്ന പൂർവ്വികരുടെ ആത്മാഭിമാനം; ആത്മീയ ശുദ്ധീകരണം ശുപാർശ ചെയ്യുന്നു.";
"yoga_formation_pretasapa_yoga" = "ശനിയും രാഹുവും 5-ൽ ഗുണകരമായ ഭാവങ്ങളില്ലാതെ ബാധിക്കുന്നു.";

// [+] Pushkala Yoga
"yoga_name_pushkala_yoga" = "പുഷ്കലയോഗം";
"yoga_outcome_pushkala_yoga" = "സമൃദ്ധമായ ഐശ്വര്യം, മധുരഭാഷണം, പ്രശസ്തി, രാജകീയ ബഹുമതി എന്നിവ നൽകുന്നു.";
"yoga_formation_pushkala_yoga" = "ലഗ്നാധിപൻ ചന്ദ്രൻ കൂടിച്ചേരുന്നു, ശക്തനായ ലഗ്നാധിപൻ്റെ ഭാവം.";

// [+] Putra Sukha Yoga
"yoga_name_putra_sukha_yoga" = "പുത്ര സുഖ യോഗ";
"yoga_outcome_putra_sukha_yoga" = "കുട്ടികളിലൂടെ അഗാധമായ സന്തോഷവും സംതൃപ്തിയും; ശക്തമായ മാതാപിതാക്കളും കുട്ടികളും തമ്മിലുള്ള ബന്ധം.";
"yoga_formation_putra_sukha_yoga" = "5-ാം അധിപനും വ്യാഴവും പരസ്പര കേന്ദ്രത്തിൽ ഗുണകരമായ വശങ്ങൾ.";

// [−] Putrakalatraheena Yoga
"yoga_name_putrakalatraheena_yoga" = "പുത്രകലത്രഹീന യോഗ";
"yoga_outcome_putrakalatraheena_yoga" = "കുട്ടികളുണ്ടാകുന്നതിനും വിവാഹം നിലനിർത്തുന്നതിനും ഉള്ള വെല്ലുവിളികൾ; ബന്ധങ്ങളിൽ അധിക പരിശ്രമം ആവശ്യമാണ്.";
"yoga_formation_putrakalatraheena_yoga" = "5-ഉം 7-ഉം അധിപന്മാർ ദുസ്ഥാനത്തിൽ കഠിനമായി പീഡിപ്പിക്കപ്പെടുന്നു.";

// [+] Putramooladhana Yoga
"yoga_name_putramooladhana_yoga" = "പുത്രമൂലധനയോഗം";
"yoga_outcome_putramooladhana_yoga" = "കുട്ടികളിലൂടെയുള്ള സമ്പത്ത്, സൃഷ്ടിപരമായ ശ്രമങ്ങൾ, അല്ലെങ്കിൽ ഊഹക്കച്ചവട നേട്ടങ്ങൾ.";
"yoga_formation_putramooladhana_yoga" = "അഞ്ചാം അധിപൻ 2, 11 വീടുകളുമായി ബന്ധിപ്പിച്ചിരിക്കുന്നു.";

// [+] Raja Yoga (245)
"yoga_name_raja_yoga_245" = "രാജയോഗ (245)";
"yoga_outcome_raja_yoga_245" = "രാജപദവി, അധികാരം, വലിയ അധികാര സ്ഥാനങ്ങളിലേക്കുള്ള ഉയർച്ച എന്നിവ നൽകുന്നു.";
"yoga_formation_raja_yoga_245" = "കേന്ദ്രങ്ങൾ/ത്രികോണങ്ങളിൽ 3+ ഗ്രഹങ്ങൾ ഉയർന്നിരിക്കുന്നു/സ്വന്തം വീട്.";

// [+] Raja Yoga (246)
"yoga_name_raja_yoga_246" = "രാജയോഗ (246)";
"yoga_outcome_raja_yoga_246" = "ഇൻ്റലിജൻസ് വഴിയുള്ള രാഷ്ട്രീയ വിജയവും ഭരണപരമായ അധികാരവും.";
"yoga_formation_raja_yoga_246" = "ലഗ്നാധിപനും അഞ്ചാം ഭാവാധിപനും ഗുണകരമായ ഭാവങ്ങളുള്ള പരസ്പര കേന്ദ്രത്തിൽ.";

// [+] Raja Yoga (247)
"yoga_name_raja_yoga_247" = "രാജയോഗ (247)";
"yoga_outcome_raja_yoga_247" = "അതിശയകരമായ പ്രൊഫഷണൽ വിജയത്തിനായി ഫോർച്യൂൺ കരിയറുമായി യോജിക്കുന്നു.";
"yoga_formation_raja_yoga_247" = "9-ഉം 10-ഉം അധിപന്മാർ സംയോജനത്തിലോ പരസ്പര ഭാവത്തിലോ (ധർമ്മ-കർമ അധിപതി).";

// [+] Raja Yoga (248)
"yoga_name_raja_yoga_248" = "രാജയോഗ (248)";
"yoga_outcome_raja_yoga_248" = "ഘടനാപരമായ നേട്ടങ്ങളിലൂടെയും വ്യവസ്ഥാപരമായ പിന്തുണയിലൂടെയും അധികാരത്തിലേക്ക് ഉയരുക.";
"yoga_formation_raja_yoga_248" = "പരസ്പര വിനിമയത്തിൽ (പരിവർത്തനം) കേന്ദ്ര, ത്രികോണ പ്രഭുക്കന്മാർ.";

// [+] Raja Yoga (249)
"yoga_name_raja_yoga_249" = "രാജയോഗ (249)";
"yoga_outcome_raja_yoga_249" = "സമഗ്രമായ അധികാരം - ജ്ഞാനം, ധാർമ്മികത, ജനകീയ പിന്തുണ എന്നിവയോടെ നയിക്കുന്നു.";
"yoga_formation_raja_yoga_249" = "1, 5, 9 ഭാവാധിപന്മാർ കേന്ദ്ര പിന്തുണയോടെ പരസ്പരം ബന്ധപ്പെട്ടിരിക്കുന്നു.";

// [+] Raja Yoga (250)
"yoga_name_raja_yoga_250" = "രാജയോഗ (250)";
"yoga_outcome_raja_yoga_250" = "കരിയർ മികവും ഉയർന്ന പ്രൊഫഷണൽ വ്യത്യാസങ്ങളും.";
"yoga_formation_raja_yoga_250" = "10-ാം അധിപൻ 9-ാം അധിപൻ ശക്തനുമായി ഉയർന്നു.";

// [+] Raja Yoga (251)
"yoga_name_raja_yoga_251" = "രാജയോഗം (251)";
"yoga_outcome_raja_yoga_251" = "ജീവിതത്തിലുടനീളം സുസ്ഥിരമായ അധികാരവും പുരോഗമനപരമായ കരിയർ വളർച്ചയും.";
"yoga_formation_raja_yoga_251" = "ത്രികോണങ്ങളിൽ ഒന്നിലധികം കേന്ദ്ര പ്രഭുക്കൾ അല്ലെങ്കിൽ തിരിച്ചും.";

// [+] Raja Yoga (252)
"yoga_name_raja_yoga_252" = "രാജയോഗ (252)";
"yoga_outcome_raja_yoga_252" = "ശക്തനായ സ്വയം നിർമ്മിത നേതാവ്; നേട്ടങ്ങളിൽ നിന്ന് വേർതിരിക്കാനാവാത്ത സ്വത്വം.";
"yoga_formation_raja_yoga_252" = "ലഗ്നാധിപൻ 10-ൽ, 10-ാം അധിപൻ ലഗ്നത്തിൽ (വിനിമയം).";

// [+] Raja Yoga (253)
"yoga_name_raja_yoga_253" = "രാജയോഗ (253)";
"yoga_outcome_raja_yoga_253" = "ദൈവിക പ്രീതി, ഭൂതകാല യോഗ്യത, ബൗദ്ധിക ശ്രേഷ്ഠത എന്നിവയിലൂടെയുള്ള അധികാരം.";
"yoga_formation_raja_yoga_253" = "5-ാം അധിപൻ 9-ൽ അല്ലെങ്കിൽ 9-ാം അധിപൻ 5-ൽ ഗുണകരമായ ഭാവങ്ങൾ.";

// [+] Raja Yoga (254)
"yoga_name_raja_yoga_254" = "രാജയോഗ (254)";
"yoga_outcome_raja_yoga_254" = "ദയയുള്ള നേതൃത്വം, നയതന്ത്ര വിജയം, സാംസ്കാരിക അധികാരം.";
"yoga_formation_raja_yoga_254" = "വ്യാഴവും ശുക്രനും ശക്തമായ ലഗ്നാധിപനുമായി കേന്ദ്രങ്ങളിൽ.";

// [+] Raja Yoga (255)
"yoga_name_raja_yoga_255" = "രാജയോഗ (255)";
"yoga_outcome_raja_yoga_255" = "ജനപിന്തുണ, സ്വത്ത്, സ്ഥാപനപരമായ അധികാരം എന്നിവയിൽ വേരൂന്നിയ അധികാരം.";
"yoga_formation_raja_yoga_255" = "4-ഉം 10-ഉം അധിപന്മാർ ശക്തമായ അന്തസ്സോടെ പരസ്പര പിന്തുണയിൽ.";

// [+] Raja Yoga (256)
"yoga_name_raja_yoga_256" = "രാജയോഗ (256)";
"yoga_outcome_raja_yoga_256" = "സർക്കാർ അധികാരം, ഭരണ വിജയം, പൊതു നേതൃത്വം.";
"yoga_formation_raja_yoga_256" = "വ്യാഴത്തിൻ്റെ ഭാവത്തിൽ സൂര്യൻ 10-ൽ ശക്തനാണ്.";

// [+] Raja Yoga (257)
"yoga_name_raja_yoga_257" = "രാജയോഗ (257)";
"yoga_outcome_raja_yoga_257" = "ജനകീയ നേതൃത്വം - ജനങ്ങളാൽ സ്നേഹിക്കപ്പെടുകയും പൊതു പിന്തുണയിലൂടെ ഉയരുകയും ചെയ്യുന്നു.";
"yoga_formation_raja_yoga_257" = "ചന്ദ്രൻ ശക്തനാണ്, ഒന്നിലധികം കേന്ദ്ര/ത്രികോണ പ്രഭുക്കളുമായി ബന്ധപ്പെട്ടിരിക്കുന്നു.";

// [+] Raja Yoga (258)
"yoga_name_raja_yoga_258" = "രാജയോഗ (258)";
"yoga_outcome_raja_yoga_258" = "സൈനിക/എക്‌സിക്യൂട്ടീവ് അതോറിറ്റി; വലിയ സംഘടനകളെ ആജ്ഞാപിക്കുന്നു.";
"yoga_formation_raja_yoga_258" = "10-ാം അധിപൻ ഉള്ള കേന്ദ്രത്തിൽ സ്വന്തം/ഉന്നതമായ രാശിയിൽ ചൊവ്വ.";

// [+] Raja Yoga (259)
"yoga_name_raja_yoga_259" = "രാജയോഗം (259)";
"yoga_outcome_raja_yoga_259" = "ബൗദ്ധിക, വാണിജ്യ അല്ലെങ്കിൽ ആശയവിനിമയ മേഖലകളിലെ അധികാരം.";
"yoga_formation_raja_yoga_259" = "2, 11 എന്നീ രാശികളുമായി 10-ൽ ബലവാനായ ബുധൻ ബന്ധപ്പെട്ടിരിക്കുന്നു.";

// [+] Raja Yoga (260)
"yoga_name_raja_yoga_260" = "രാജയോഗ (260)";
"yoga_outcome_raja_yoga_260" = "അച്ചടക്കമുള്ള ഭരണത്തിലൂടെയും സ്ഥാപന നേതൃത്വത്തിലൂടെയും നിലനിൽക്കുന്ന അധികാരം.";
"yoga_formation_raja_yoga_260" = "ഗുണകരമായ ഭാവങ്ങളോടെ 10-ൽ സ്വന്തം/ഉയർന്ന ശനി.";

// [+] Raja Yoga (261)
"yoga_name_raja_yoga_261" = "രാജയോഗ (261)";
"yoga_outcome_raja_yoga_261" = "അധികാരത്തോടെ നയതന്ത്രം, കല, അല്ലെങ്കിൽ ആഡംബര വ്യവസായം എന്നിവയിൽ വിജയം.";
"yoga_formation_raja_yoga_261" = "10-ലെ ശുക്രൻ 9-ലെ ലഗ്നാധിപന്മാരുമായി ബന്ധപ്പെട്ടിരിക്കുന്നു.";

// [+] Raja Yoga (262)
"yoga_name_raja_yoga_262" = "രാജയോഗം (262)";
"yoga_outcome_raja_yoga_262" = "അധികാരം, സമ്പത്ത്, അംഗീകാരം എന്നിവയോടുകൂടിയ പ്രൊഫഷണൽ വിജയം.";
"yoga_formation_raja_yoga_262" = "അന്തസ്സുള്ള 10-ാം നാഥനുള്ള കേന്ദ്രങ്ങളിൽ ഒന്നിലധികം ഗുണങ്ങൾ.";

// [+] Raja Yoga (263)
"yoga_name_raja_yoga_263" = "രാജയോഗ (263)";
"yoga_outcome_raja_yoga_263" = "പരമോന്നത രാജയോഗം - അസാധാരണമായ ശക്തിയും ശാശ്വതമായ പൈതൃകവും.";
"yoga_formation_raja_yoga_263" = "എല്ലാ ത്രികോണ, കേന്ദ്ര പ്രഭുക്കന്മാരും പരസ്പരം പിന്തുണയ്ക്കുന്നു (അപൂർവ്വം).";

// [−] Raja Yoga Bhanga (298)
"yoga_name_raja_yoga_bhanga_298" = "രാജയോഗ ഭംഗ (298)";
"yoga_outcome_raja_yoga_bhanga_298" = "രാജയോഗ ഫലങ്ങൾ റദ്ദാക്കുന്നു; മറഞ്ഞിരിക്കുന്ന എതിരാളികൾ തുരങ്കം വയ്ക്കുന്ന വിജയം.";
"yoga_formation_raja_yoga_bhanga_298" = "രാജയോഗ ഗ്രഹങ്ങൾ ശക്തമായ ദോഷങ്ങളാൽ ബാധിക്കപ്പെടുന്നു (var. 1).";

// [−] Raja Yoga Bhanga (299)
"yoga_name_raja_yoga_bhanga_299" = "രാജയോഗ ഭംഗ (299)";
"yoga_outcome_raja_yoga_bhanga_299" = "കരിയർ പുരോഗതി നശിപ്പിക്കുന്നു; ബാഹ്യശക്തികൾ പ്രൊഫഷണൽ പുരോഗതിയെ തടസ്സപ്പെടുത്തുന്നു.";
"yoga_formation_raja_yoga_bhanga_299" = "രാജയോഗ ഗ്രഹങ്ങൾ ദുർബലപ്പെടുത്തുകയോ ജ്വലിക്കുകയോ ചെയ്യുക (var. 2).";

// [−] Rajabhrashta Yoga
"yoga_name_rajabhrashta_yoga" = "രാജഭ്രഷ്ട യോഗ";
"yoga_outcome_rajabhrashta_yoga" = "ഉയർന്ന സ്ഥാനത്ത് നിന്ന് വീഴുക; പെട്ടെന്നുള്ള അധികാര നഷ്ടം അല്ലെങ്കിൽ പൊതു അപമാനം.";
"yoga_formation_rajabhrashta_yoga" = "ആരൂഢ ലഗ്നാധിപനും ആരൂഢ 12-ാം ഭാവാധിപനും കൂടിച്ചേരുന്നു.";

// [+] Rajalakshana Yoga
"yoga_name_rajalakshana_yoga" = "രാജലക്ഷണയോഗം";
"yoga_outcome_rajalakshana_yoga" = "കുലീനമായ പെരുമാറ്റം, കുലീനമായ പെരുമാറ്റം, സ്വാഭാവിക നേതൃത്വ ഗുണങ്ങൾ എന്നിവ നൽകുന്നു.";
"yoga_formation_rajalakshana_yoga" = "ലഗ്നത്തിലോ കേന്ദ്രങ്ങളിലോ പ്രത്യേക അന്തസ്സുള്ള അവസ്ഥകളുള്ള ശക്തമായ ഗ്രഹങ്ങൾ.";

// [+] Ravi Yoga
"yoga_name_ravi_yoga" = "രവിയോഗം";
"yoga_outcome_ravi_yoga" = "സോളാർ അതോറിറ്റി - പൊതുജീവിതത്തിലും സർക്കാരിലും ആത്മവിശ്വാസത്തോടെ തിളങ്ങുന്നു.";
"yoga_formation_ravi_yoga" = "സൂര്യൻ 10-ൽ സ്വന്തം/ഉയർന്ന, 9-ാം അധിപൻ ബലവാനാണ്.";

// [−] Rogagrastha Yoga
"yoga_name_rogagrastha_yoga" = "രോഗഗ്രസ്ഥ യോഗ";
"yoga_outcome_rogagrastha_yoga" = "വിട്ടുമാറാത്ത രോഗങ്ങളുടെ സംവേദനക്ഷമത; ആവർത്തിച്ചുള്ള ആരോഗ്യപ്രശ്നങ്ങൾക്കുള്ള സാധ്യതയുള്ള വ്യക്തി.";
"yoga_formation_rogagrastha_yoga" = "ആറാം ഭാവാധിപൻ ബലവാൻ, ലഗ്നാധിപൻ ബലഹീനൻ, ലഗ്നത്തിൻ്റെ ദൃഷ്ടിയിൽ ദോഷം.";

// [+] Ruchaka Yoga
"yoga_name_ruchaka_yoga" = "രുചക യോഗ";
"yoga_outcome_ruchaka_yoga" = "ധൈര്യം, ശാരീരിക ചൈതന്യം, കമാൻഡിംഗ് സാന്നിധ്യം, മത്സര അല്ലെങ്കിൽ സൈനിക മേഖലകളിൽ വിജയം എന്നിവ നൽകുന്നു.";
"yoga_formation_ruchaka_yoga" = "സ്വന്തം രാശിയിൽ (ഏരീസ്/വൃശ്ചികം) അല്ലെങ്കിൽ ഉയർച്ചയിൽ (മകരം) ഒരു കേന്ദ്രത്തിൽ (1/4/7/10) ചൊവ്വ.";

// [+] Sada Sanchara Yoga
"yoga_name_sada_sanchara_yoga" = "സദാ സഞ്ചാര യോഗ";
"yoga_outcome_sada_sanchara_yoga" = "നിരന്തരമായ യാത്രകൾ ഉൾപ്പെടുന്ന കരിയർ - നയതന്ത്രം, കൺസൾട്ടിംഗ് അല്ലെങ്കിൽ അന്താരാഷ്ട്ര ബിസിനസ്സ്.";
"yoga_formation_sada_sanchara_yoga" = "3/7/12 വീടുകളുമായി ബന്ധിപ്പിച്ചിരിക്കുന്ന ചലിക്കുന്ന രാശിയിൽ പത്താം അധിപൻ.";

// [−] Sahodareesangama Yoga
"yoga_name_sahodareesangama_yoga" = "സഹോദരസംഗമ യോഗ";
"yoga_outcome_sahodareesangama_yoga" = "ബോധപൂർവമായ അതിരുകൾ ആവശ്യമുള്ള സഹോദര ബന്ധങ്ങളിലെ അനുചിതമായ ചലനാത്മകത.";
"yoga_formation_sahodareesangama_yoga" = "3-ാം അധിപനും ശുക്രനും പീഡിത കോമ്പിനേഷനിൽ.";

// [−] Sakata Yoga
"yoga_name_sakata_yoga" = "ശകട യോഗ";
"yoga_outcome_sakata_yoga" = "ചാഞ്ചാടുന്ന ഭാഗ്യം - തിരിച്ചടികൾക്കൊപ്പം സമൃദ്ധി മാറിമാറി വരുന്നു; സ്ഥിരതയ്ക്ക് പരിശ്രമം ആവശ്യമാണ്.";
"yoga_formation_sakata_yoga" = "വ്യാഴത്തിൽ നിന്ന് 6/8/12-ൽ ചന്ദ്രൻ.";

// [−] Sanghataka Marana Yoga (276)
"yoga_name_sanghataka_marana_yoga_276" = "സംഘടക മരണ യോഗ (276)";
"yoga_outcome_sanghataka_marana_yoga_276" = "കൂട്ടായ ദുരന്തം അല്ലെങ്കിൽ കൂട്ട-സംഭവ ദുർബലത; അപകടകരമായ ഗതാഗത സമയത്ത് ജാഗ്രത.";
"yoga_formation_sanghataka_marana_yoga_276" = "മരണത്തിന് കാരണമാകുന്ന വീടുകളിലെ പ്രത്യേക മോശം ഗ്രൂപ്പിംഗുകൾ (var. 1).";

// [−] Sanghataka Marana Yoga (277)
"yoga_name_sanghataka_marana_yoga_277" = "സംഘടക മരണ യോഗ (277)";
"yoga_outcome_sanghataka_marana_yoga_277" = "ഗ്രൂപ്പ് പ്രവർത്തനങ്ങളിലോ യാത്രയിലോ ഉള്ള അപകടസാധ്യത; അപകടസമയത്ത് ഉയർന്ന അവബോധം.";
"yoga_formation_sanghataka_marana_yoga_277" = "മരണകാരണമാകുന്ന വീടുകളിലെ പ്രത്യേക മോശം ഗ്രൂപ്പിംഗുകൾ (var. 2).";

// [+] Sankha Yoga
"yoga_name_sankha_yoga" = "ശംഖ യോഗ";
"yoga_outcome_sankha_yoga" = "ശംഖ് പോലെയുള്ള രാജകീയ അധികാരം; സമ്പത്ത്, ദീർഘായുസ്സ്, മാനുഷിക നേതൃത്വം.";
"yoga_formation_sankha_yoga" = "ശക്തമായ ലഗ്നാധിപനുമായി പരസ്പര കേന്ദ്രങ്ങളിൽ 5, 6 ഭാവാധിപന്മാർ.";

// [+] Sarala Yoga
"yoga_name_sarala_yoga" = "സരള യോഗ";
"yoga_outcome_sarala_yoga" = "നിർഭയത്വവും ദീർഘായുസ്സും നൽകുന്നു; മറഞ്ഞിരിക്കുന്ന അപകടങ്ങളെ പ്രതിരോധത്തിലൂടെ കീഴടക്കുന്നു.";
"yoga_formation_sarala_yoga" = "6, 8, അല്ലെങ്കിൽ 12 ആം ഭാവങ്ങളിൽ 8-ആം അധിപൻ (ദുസ്ഥാനത്തിലെ ദുസ്ഥാനം).";

// [+] Saraswathi Yoga Education
"yoga_name_saraswathi_yoga_education" = "സരസ്വതി യോഗ വിദ്യാഭ്യാസം";
"yoga_outcome_saraswathi_yoga_education" = "ഫലത്തിൻ്റെ വിശദാംശങ്ങൾ ചേർക്കേണ്ടതാണ്";
"yoga_formation_saraswathi_yoga_education" = "രൂപീകരണ വിശദാംശങ്ങൾ ചേർക്കേണ്ടതാണ്";

// [+] Sareera Soukhya Yoga
"yoga_name_sareera_soukhya_yoga" = "ശരീര സൗഖ്യ യോഗ";
"yoga_outcome_sareera_soukhya_yoga" = "ശാരീരിക സുഖം, നല്ല ആരോഗ്യം, ജീവിതത്തിലുടനീളം കരുത്തുറ്റ ഭരണഘടന.";
"yoga_formation_sareera_soukhya_yoga" = "ലഗ്നത്തിലെ ഗുണപരമായ വശങ്ങളുള്ള സ്വന്തം/ഉന്നതമായ രാശിയിൽ ലഗ്നാധിപൻ.";

// [−] Sarpaganda Yoga
"yoga_name_sarpaganda_yoga" = "സർപ്പഗണ്ഡ യോഗ";
"yoga_outcome_sarpaganda_yoga" = "പാമ്പുകടിയോ ഉരഗങ്ങളുമായി ബന്ധപ്പെട്ട അപകടങ്ങളോ ഉണ്ടാകാനുള്ള സാധ്യത; സർപ്പങ്ങളുടെ അടുത്ത് ജാഗ്രത.";
"yoga_formation_sarpaganda_yoga" = "ലഗ്നത്തിൽ ദോഷകരമായ വശങ്ങൾ ഉള്ള പ്രത്യേക സ്ഥാനങ്ങളിൽ രാഹു.";

// [−] Sarpasapa Yoga (212)
"yoga_name_sarpasapa_yoga_212" = "സർപ്പശാപ യോഗ (212)";
"yoga_outcome_sarpasapa_yoga_212" = "സന്തതിയെ ബാധിക്കുന്ന സർപ്പശാപം; പ്രസവിക്കുന്നതിനുള്ള കർമ്മ തടസ്സങ്ങൾ.";
"yoga_formation_sarpasapa_yoga_212" = "ദോഷകരമായ ഭാവങ്ങളുള്ള 5-ൽ രാഹു, ഗുണാശ്വാസമില്ല (var. 1).";

// [−] Sarpasapa Yoga (213)
"yoga_name_sarpasapa_yoga_213" = "സർപ്പശാപ യോഗ (213)";
"yoga_outcome_sarpasapa_yoga_213" = "പൂർവ്വികരുടെ കർമ്മ കടം പ്രത്യുൽപാദന വെല്ലുവിളികളായി പ്രകടമാകുന്നു.";
"yoga_formation_sarpasapa_yoga_213" = "രാഹു/കേതു അക്ഷം 5-11-ൽ പീഡിതനായ 5-ആം അധിപൻ (വാർ. 2).";

// [−] Sarpasapa Yoga (214)
"yoga_name_sarpasapa_yoga_214" = "സർപ്പശാപ യോഗ (214)";
"yoga_outcome_sarpasapa_yoga_214" = "കുട്ടികളുണ്ടാകുന്നതിന് ആഴത്തിൽ വേരൂന്നിയ കർമ്മ തടസ്സങ്ങൾ; ആത്മീയ പരിഹാരങ്ങൾ അത്യാവശ്യമാണ്.";
"yoga_formation_sarpasapa_yoga_214" = "ശനിയുടെ (വാർ. 3) 5-ൽ പ്രത്യേക രാഹു കോമ്പിനേഷനുകൾ.";

// [−] Sarpasapa Yoga (215)
"yoga_name_sarpasapa_yoga_215" = "സർപ്പശാപ യോഗ (215)";
"yoga_outcome_sarpasapa_yoga_215" = "കുടുംബപരമ്പരയിൽ കടുത്ത സർപ്പശാപം; ആചാരപരമായ ശുദ്ധീകരണം ശുപാർശ ചെയ്യുന്നു.";
"yoga_formation_sarpasapa_yoga_215" = "5-ൽ രാഹു 5-ൽ 6/8/12-ൽ 5-ാം അധിപൻ (var. 4).";

// [+] Sasa Yoga
"yoga_name_sasa_yoga" = "സാസ യോഗ";
"yoga_outcome_sasa_yoga" = "അച്ചടക്കം, ഭരണത്തിൽ നേതൃത്വം, സ്ഥിരോത്സാഹത്തിലൂടെയും രീതിപരമായ പരിശ്രമത്തിലൂടെയും വിജയം നൽകുന്നു.";
"yoga_formation_sasa_yoga" = "ശനി ഒരു കേന്ദ്രത്തിൽ (1/4/7/10) സ്വന്തം രാശിയിൽ (മകരം/കുംബം) അല്ലെങ്കിൽ ഉയർച്ചയിൽ (തുലാം).";

// [+] Satkalatra Yoga
"yoga_name_satkalatra_yoga" = "സത്കലത്ര യോഗ";
"yoga_outcome_satkalatra_yoga" = "കുലീനവും സദ്‌ഗുണമുള്ള ഇണയും യോജിപ്പുള്ള ദാമ്പത്യവും; ജീവിത പങ്കാളി ഭാഗ്യവും സന്തോഷവും നൽകുന്നു.";
"yoga_formation_satkalatra_yoga" = "ഏഴാം അധിപൻ ശുക്രൻ ശക്തവും ഗുണകരവുമായ ഭാവങ്ങളാൽ നന്നായി സ്ഥിതിചെയ്യുന്നു.";

// [+] Satkathadisravana Yoga
"yoga_name_satkathadisravana_yoga" = "സത്കഥാദിശ്രവണയോഗം";
"yoga_outcome_satkathadisravana_yoga" = "പവിത്രമായ അറിവ്, ദാർശനിക പഠനം, ഉയർന്ന ജ്ഞാനം എന്നിവയോടുള്ള ആഴത്തിലുള്ള സ്നേഹം നൽകുന്നു.";
"yoga_formation_satkathadisravana_yoga" = "ഗുണഭോക്താക്കൾ മുഖേനയുള്ള മൂന്നാം ഭാവം, സ്വാഭാവിക ഗുണകരമായ ഭാവങ്ങളുള്ള ഗുണകരമായ നവാംശത്തിലെ മൂന്നാം അധിപൻ.";

// [+] Satrumooladhana Yoga
"yoga_name_satrumooladhana_yoga" = "ശത്രുമൂലധനയോഗം";
"yoga_outcome_satrumooladhana_yoga" = "മത്സരത്തെ പരാജയപ്പെടുത്തുന്നതിലൂടെയോ നിയമപരമായ വിജയങ്ങളിലൂടെയോ സേവന വരുമാനത്തിലൂടെയോ സമ്പത്ത്.";
"yoga_formation_satrumooladhana_yoga" = "ആറാം അധിപൻ 2-ഉം 11-ഉം വീടുകളുമായി ബന്ധപ്പെട്ടിരിക്കുന്നു.";

// [−] Sirachcheda Yoga
"yoga_name_sirachcheda_yoga" = "സിരച്ഛേദ യോഗ";
"yoga_outcome_sirachcheda_yoga" = "തലയ്ക്ക് പരിക്കേൽക്കുകയോ കഠിനമായ ആഘാതമോ ഉണ്ടാകാനുള്ള സാധ്യത; സംരക്ഷണ നടപടികളും മുൻകരുതലുകളും നിർദ്ദേശിച്ചു.";
"yoga_formation_sirachcheda_yoga" = "ചൊവ്വയും കേതുവും ലഗ്നത്തെ പ്രതികൂലമായി ബാധിക്കുന്നു.";

// [−] Sisnavyadhi Yoga
"yoga_name_sisnavyadhi_yoga" = "സിസ്‌നവ്യാധി യോഗ";
"yoga_outcome_sisnavyadhi_yoga" = "ജനനേന്ദ്രിയ അല്ലെങ്കിൽ പ്രത്യുൽപാദന ആരോഗ്യ തകരാറുകൾ; പ്രത്യേക വൈദ്യസഹായം ഉചിതം.";
"yoga_formation_sisnavyadhi_yoga" = "ശുക്രനും ഏഴാം അധിപനും എട്ടാം ഭവനത്തിലെ ദോഷങ്ങളാൽ പീഡിപ്പിക്കപ്പെടുന്നു.";

// [+] Siva Yoga
"yoga_name_siva_yoga" = "ശിവയോഗം";
"yoga_outcome_siva_yoga" = "ശിവൻ്റെ അനുഗ്രഹം; അഗാധമായ ധ്യാന കഴിവുകൾ, സന്യാസ ജ്ഞാനം, രൂപാന്തരപ്പെടുത്തുന്ന ആത്മീയ ശക്തി.";
"yoga_formation_siva_yoga" = "9-ൽ 5-ാം അധിപൻ, 10-ൽ 9-ാം അധിപൻ, 5-ൽ 10-ാം അധിപൻ.";

// [−] Sraddhannabhuktha Yoga
"yoga_name_sraddhannabhuktha_yoga" = "ശ്രദ്ധാന്നഭുക്തയോഗം";
"yoga_outcome_sraddhannabhuktha_yoga" = "ആചാരങ്ങൾക്കോ ​​ചടങ്ങുകൾക്കോ ​​വേണ്ടിയുള്ള ഭക്ഷണം കഴിക്കുന്നു; ശവസംസ്കാര / ആചാരപരമായ വഴിപാടുകളെ ആശ്രയിച്ചിരിക്കുന്നു.";
"yoga_formation_sraddhannabhuktha_yoga" = "അശുദ്ധമായ ഭക്ഷണ സ്രോതസ്സുകളെ സൂചിപ്പിക്കുന്ന 2-ാം വീട്ടിലേക്കുള്ള പ്രത്യേക കഷ്ടതകൾ.";

// [+] Sreenatha Yoga
"yoga_name_sreenatha_yoga" = "ശ്രീനാഥ യോഗ";
"yoga_outcome_sreenatha_yoga" = "ദൈവിക പ്രീതിയും വിവാഹാനന്തര സമൃദ്ധിയും പങ്കാളിത്തത്തിലൂടെ ഭാഗ്യവും നൽകുന്നു.";
"yoga_formation_sreenatha_yoga" = "ഏഴാം അധിപൻ 10, 9, 10 എന്നീ രാശികളിൽ ശ്രേഷ്ഠനായി.";

// [+] Sumukha Yoga (166)
"yoga_name_sumukha_yoga_166" = "സുമുഖ യോഗ (166)";
"yoga_outcome_sumukha_yoga_166" = "ആകർഷകമായ മുഖവും പ്രസന്നമായ രൂപവും; കാന്തിക വ്യക്തിത്വവും ആകർഷകമായ പെരുമാറ്റവും.";
"yoga_formation_sumukha_yoga_166" = "ലഗ്നത്തിൽ നിന്ന് 2-ൽ ഗുണഫലങ്ങൾ, ലഗ്നാധിപൻ ബലവാനായ (var. 1).";

// [+] Sumukha Yoga (167)
"yoga_name_sumukha_yoga_167" = "സുമുഖ യോഗ (167)";
"yoga_outcome_sumukha_yoga_167" = "സുന്ദരമായ സവിശേഷതകളും മനോഹരമായ ബെയറിംഗും; സ്വാഭാവികമായും ആകർഷകവും സാമൂഹികമായി പ്രശംസനീയവുമാണ്.";
"yoga_formation_sumukha_yoga_167" = "ശുക്രനും വ്യാഴവും ലഗ്നത്തെയോ രണ്ടാം ഭാവത്തെയോ നോക്കുന്നു (var. 2).";

// [+] Sunapha Yoga
"yoga_name_sunapha_yoga" = "സുനാഫ യോഗ";
"yoga_outcome_sunapha_yoga" = "വ്യക്തിഗത യോഗ്യതയിലൂടെ സ്വയം സമ്പാദിച്ച സമ്പത്തും ബുദ്ധിയും സമൃദ്ധിയും നൽകുന്നു.";
"yoga_formation_sunapha_yoga" = "ഗ്രഹം (സൂര്യൻ/രാഹു/കേതു ഒഴികെ) ചന്ദ്രനിൽ നിന്ന് രണ്ടാം ഭാവത്തിൽ.";

// [+] Suputra Yoga
"yoga_name_suputra_yoga" = "സുപുത്ര യോഗ";
"yoga_outcome_suputra_yoga" = "മഹത്തായ അഭിമാനവും കുടുംബ മഹത്വവും കൊണ്ടുവരുന്ന യോഗ്യനും സദ്‌ഗുണസമ്പന്നനുമായ ഒരു കുട്ടിയാൽ അനുഗ്രഹിക്കപ്പെട്ടു.";
"yoga_formation_suputra_yoga" = "അഞ്ചാം ഭാവത്തിൽ വ്യാഴം ശക്തൻ, അഞ്ചാം ഭാവാധിപൻ മാന്യൻ.";

// [+] Swaveeryadhana Yoga
"yoga_name_swaveeryadhana_yoga" = "സ്വവീര്യധന യോഗ";
"yoga_outcome_swaveeryadhana_yoga" = "സ്വപ്രയത്നത്തിലൂടെ സമ്പത്ത് പൂർണ്ണമായും നൽകുന്നു; വ്യക്തി ഒരു സ്വയം നിർമ്മിത നേട്ടക്കാരനാണ്.";
"yoga_formation_swaveeryadhana_yoga" = "ലഗ്നാധിപനും രണ്ടാം ഭാവാധിപനും ബാഹ്യമായ ഗൃഹാശ്രിതത്വമില്ലാതെ ബലവാനാണ്.";

// [−] Swetakushta Yoga
"yoga_name_swetakushta_yoga" = "ശ്വേതകുഷ്ട യോഗ";
"yoga_outcome_swetakushta_yoga" = "വിട്ടുമാറാത്ത ചർമ്മരോഗങ്ങൾക്കുള്ള സാധ്യത; സമഗ്രമായ ആരോഗ്യ സമ്പ്രദായങ്ങൾ ശുപാർശ ചെയ്യുന്നു.";
"yoga_formation_swetakushta_yoga" = "ചർമ്മത്തെയും ചൈതന്യത്തെയും ബാധിക്കുന്ന പ്രത്യേക കോമ്പിനേഷനുകൾ.";

// [+] Theevrabuddhi Yoga
"yoga_name_theevrabuddhi_yoga" = "തിവ്രബുദ്ധി യോഗ";
"yoga_outcome_theevrabuddhi_yoga" = "റേസർ മൂർച്ചയുള്ള ബുദ്ധിയും പെട്ടെന്നുള്ള ഗ്രഹണശക്തിയും; യുക്തിയിലും വിശകലനത്തിലും മികവ് പുലർത്തുന്നു.";
"yoga_formation_theevrabuddhi_yoga" = "വ്യാഴത്തിൻ്റെ ഭാവമുള്ള കേന്ദ്രത്തിൽ ബുധൻ ഉയർന്ന/സ്വന്തം രാശി.";

// [+] Thrikalagnana Yoga
"yoga_name_thrikalagnana_yoga" = "തൃകാലജ്ഞാനയോഗം";
"yoga_outcome_thrikalagnana_yoga" = "പ്രാവചനിക അവബോധവും അസാധാരണമായ ദീർഘവീക്ഷണവും; അസാധാരണമായ പ്രവചന കഴിവുകൾ.";
"yoga_formation_thrikalagnana_yoga" = "പ്രത്യേക ലഗ്ന ബന്ധങ്ങളുള്ള നവാംശത്തിൽ വ്യാഴം ശക്തമാണ്.";

// [+] Thrilochana Yoga
"yoga_name_thrilochana_yoga" = "ത്രിലോചന യോഗ";
"yoga_outcome_thrilochana_yoga" = "അപാരമായ സമ്പത്തും നിർഭയത്വവും ആജ്ഞാപിക്കുന്ന, സമൃദ്ധമായ സാന്നിധ്യവും നൽകുന്നു.";
"yoga_formation_thrilochana_yoga" = "സൂര്യൻ, ചന്ദ്രൻ, ചൊവ്വ എന്നിവ പരസ്പര ത്രികോണങ്ങളിൽ (1-5-9 ത്രികോണം).";

// [+] Uttama Griha Yoga
"yoga_name_uttama_griha_yoga" = "ഉത്തമ ഗൃഹയോഗം";
"yoga_outcome_uttama_griha_yoga" = "മികച്ച വീടുകളുടെ ഉടമസ്ഥാവകാശം നൽകുന്നു; നല്ല പാർപ്പിടങ്ങളാൽ സുഖപ്രദമായ വ്യക്തിഗത ജീവിതം.";
"yoga_formation_uttama_griha_yoga" = "നാലാമത്തെ അധിപൻ കേന്ദ്ര/ത്രികോണത്തിൽ ഗുണപരമായ സ്വാധീനങ്ങളോടെ ശക്തനാണ്.";

// [+] Vahana Yoga (209)
"yoga_name_vahana_yoga_209" = "വാഹന യോഗ (209)";
"yoga_outcome_vahana_yoga_209" = "മികച്ച വാഹനങ്ങൾ, ഗതാഗതം, ആഡംബര ഗതാഗതം എന്നിവ നൽകുന്നു.";
"yoga_formation_vahana_yoga_209" = "നാലാമത്തെ അധിപൻ ഗുണഭോക്താക്കളുമായി ബന്ധപ്പെട്ടിരിക്കുന്നു, ശുക്രൻ ശക്തനാണ് (var. 1).";

// [+] Vahana Yoga (210)
"yoga_name_vahana_yoga_210" = "വാഹന യോഗ (210)";
"yoga_outcome_vahana_yoga_210" = "പ്രീമിയം വാഹനങ്ങളും ജീവിതത്തിലുടനീളം സുഖകരമായ യാത്രയും ഉറപ്പാക്കുന്നു.";
"yoga_formation_vahana_yoga_210" = "ശുക്രൻ നല്ല സ്ഥാനമുള്ള നാലാം ഭാവത്തിലെ ഗുണഫലങ്ങൾ (var. 2).";

// [−] Vakchalana Yoga
"yoga_name_vakchalana_yoga" = "വക്ചലന യോഗ";
"yoga_outcome_vakchalana_yoga" = "സംസാര വൈകല്യങ്ങൾ, സ്തംഭനം അല്ലെങ്കിൽ ഭാഷാ തടസ്സങ്ങൾ; സ്പീച്ച് തെറാപ്പി പ്രയോജനകരമാണ്.";
"yoga_formation_vakchalana_yoga" = "ബുധൻ ദോഷങ്ങളാൽ കഠിനമായി പീഡിപ്പിക്കപ്പെടുന്നു, രണ്ടാം അധിപൻ ബലഹീനനാണ്.";

// [−] Vamsacheda Yoga
"yoga_name_vamsacheda_yoga" = "വംശചേദ യോഗ";
"yoga_outcome_vamsacheda_yoga" = "കുടുംബ പരമ്പര തുടരുന്നതിലെ വെല്ലുവിളികൾ; ഇതര കുടുംബ നിർമ്മാണം പരിഗണിക്കാം.";
"yoga_formation_vamsacheda_yoga" = "5-ാം അധിപനും വ്യാഴവും കഠിനമായി ബാധിച്ചു.";

// [−] Vanchanachorabheethi Yoga
"yoga_name_vanchanachorabheethi_yoga" = "വഞ്ചനചോരഭീതി യോഗ";
"yoga_outcome_vanchanachorabheethi_yoga" = "വഞ്ചനയ്‌ക്കോ മോഷണത്തിനോ ഉള്ള സാധ്യത സൂചിപ്പിക്കുന്നു; ഉപദേശിച്ച മറ്റുള്ളവരെ വിശ്വസിക്കുന്നതിൽ ജാഗ്രത പുലർത്തുക.";
