"yoga_formation_bahudravyarjana_yoga" = "ശക്തമായ പരസ്പര സ്ഥാനങ്ങളിൽ ഒന്നിലധികം സമ്പത്ത്-സൂചനകൾ.";

// [+] Bahuputra Yoga (220)
"yoga_name_bahuputra_yoga_220" = "ബഹുപുത്ര യോഗ (220)";
"yoga_outcome_bahuputra_yoga_220" = "സന്തോഷവും കുടുംബ തുടർച്ചയും നൽകുന്ന നിരവധി കുട്ടികളാൽ അനുഗ്രഹിക്കപ്പെട്ടു.";
"yoga_formation_bahuputra_yoga_220" = "അഞ്ചാം അധിപൻ വ്യാഴത്തിൻ്റെ ഭാവത്തിൽ കേന്ദ്ര/ത്രികോണത്തിൽ ബലവാനാണ് (വാർ. 1).";

// [+] Bahuputra Yoga (221)
"yoga_name_bahuputra_yoga_221" = "ബഹുപുത്ര യോഗ (221)";
"yoga_outcome_bahuputra_yoga_221" = "നല്ല ആരോഗ്യവും സ്വഭാവവുമുള്ള ഒന്നിലധികം സന്തതികൾ; കുടുംബം വളരുന്നു.";
"yoga_formation_bahuputra_yoga_221" = "വ്യാഴവും 5-ാം അധിപനും ഗുണകരമായ ബന്ധങ്ങളുള്ള പരസ്പര പിന്തുണയിലാണ് (var. 2).";

// [+] Balya Dhana Yoga
"yoga_name_balya_dhana_yoga" = "ബല്യ ധനയോഗം";
"yoga_outcome_balya_dhana_yoga" = "കുടുംബ സമ്പത്തിലൂടെയോ അനന്തരാവകാശത്തിലൂടെയോ ആദ്യകാല സാമ്പത്തിക നേട്ടം നൽകുന്നു.";
"yoga_formation_balya_dhana_yoga" = "ജനനം മുതൽ ആദ്യകാല ദശ വരെ സജീവമായ സമ്പത്ത് സൂചകങ്ങൾ.";

// [−] Bandhana Yoga
"yoga_name_bandhana_yoga" = "ബന്ധന യോഗ";
"yoga_outcome_bandhana_yoga" = "തടവ്, തടവ്, അല്ലെങ്കിൽ സ്വമേധയാ സ്വാതന്ത്ര്യം നിയന്ത്രിക്കൽ എന്നിവയുടെ അപകടസാധ്യത.";
"yoga_formation_bandhana_yoga" = "ലഗ്നാധിപനും ആറാം ഭാവാധിപനും ശനി/രാഹുവുമായി ബന്ധപ്പെട്ടിരിക്കുന്നു.";

// [+] Bandhu Pujya Yoga (193)
"yoga_name_bandhu_pujya_yoga_193" = "ബന്ധു പൂജ്യ യോഗ (193)";
"yoga_outcome_bandhu_pujya_yoga_193" = "കുടുംബത്തിൽ നിന്നും ബന്ധുക്കളിൽ നിന്നും ആദരവും വാത്സല്യവും നൽകുന്നു; വ്യക്തി ഒരു കുടുംബ അവതാരകനാണ്.";
"yoga_formation_bandhu_pujya_yoga_193" = "4-ാം അധിപൻ ഗുണകരമായ ഭാവങ്ങളോടുകൂടിയ ശുഭസ്ഥാനത്ത്, ലഗ്നത്തിൽ ബുധൻ.";

// [+] Bandhu Pujya Yoga (194)
"yoga_name_bandhu_pujya_yoga_194" = "ബന്ധു പൂജ്യ യോഗ (194)";
"yoga_outcome_bandhu_pujya_yoga_194" = "ബന്ധുത്വത്തിലൂടെയും വിശ്വസനീയമായ ഉപദേശത്തിലൂടെയും കുടുംബബന്ധങ്ങൾ ശക്തിപ്പെടുത്തുകയും ബഹുമാനം കൊണ്ടുവരുകയും ചെയ്യുന്നു.";
"yoga_formation_bandhu_pujya_yoga_194" = "വ്യാഴം നാലാം ഭാവവുമായി ബന്ധപ്പെട്ടിരിക്കുന്നു, വശം അല്ലെങ്കിൽ തൊഴിൽ വഴി.";

// [−] Bandhubhisthyaktha Yoga
"yoga_name_bandhubhisthyaktha_yoga" = "ബന്ധുഭിഷ്ടയോഗം";
"yoga_outcome_bandhubhisthyaktha_yoga" = "ബന്ധുക്കളിൽ നിന്നുള്ള അകൽച്ചയും കുടുംബ കലഹങ്ങൾ അല്ലെങ്കിൽ ഒറ്റപ്പെടലും സൂചിപ്പിക്കുന്നു.";
"yoga_formation_bandhubhisthyaktha_yoga" = "ഗുണപരമായ പിന്തുണയില്ലാത്ത നാലാം ഭാവത്തിനും നാഥനും ദോഷം.";

// [+] Bhadra Yoga
"yoga_name_bhadra_yoga" = "ഭദ്ര യോഗ";
"yoga_outcome_bhadra_yoga" = "മൂർച്ചയുള്ള ബുദ്ധി, വാചാലമായ സംസാരം, ബിസിനസ്സ് മിടുക്ക്, വിശകലന തൊഴിലുകളിൽ മികവ് എന്നിവ നൽകുന്നു.";
"yoga_formation_bhadra_yoga" = "ബുധൻ ഒരു കേന്ദ്രത്തിൽ (1/4/7/10) സ്വന്തം രാശിയിൽ (ജെമിനി/കന്നി) അല്ലെങ്കിൽ ഉന്നതി (കന്നി).";

// [+] Bhaga Chumbana Yoga
"yoga_name_bhaga_chumbana_yoga" = "ഭാഗ ചുംബന യോഗ";
"yoga_outcome_bhaga_chumbana_yoga" = "ഉയർന്ന ശാരീരിക കാന്തികതയും അടുപ്പമുള്ള പൂർത്തീകരണവും ഉള്ള തീവ്രവും ആവേശഭരിതവുമായ പ്രണയ ജീവിതം.";
"yoga_formation_bhaga_chumbana_yoga" = "ശാരീരിക ആകർഷണം സൂചിപ്പിക്കുന്ന പ്രത്യേക കോമ്പിനേഷനുകളിൽ ശുക്രനും ഏഴാം അധിപനും.";

// [+] Bhagya Yoga
"yoga_name_bhagya_yoga" = "ഭാഗ്യ യോഗ";
"yoga_outcome_bhagya_yoga" = "അസാധാരണമായ ഭാഗ്യം, ഭാഗ്യം, ദിവ്യകാരുണ്യം; സമയോചിതമായ അവസരങ്ങളാൽ അനുഗ്രഹിക്കപ്പെട്ടു.";
"yoga_formation_bhagya_yoga" = "9-ാം അധിപൻ കേന്ദ്ര/ത്രികോണത്തിൽ ഗുണപരമായ സ്വാധീനങ്ങളോടെ ശക്തനാണ്.";

// [+] Bharathi Yoga
"yoga_name_bharathi_yoga" = "ഭാരതി യോഗ";
"yoga_outcome_bharathi_yoga" = "അസാധാരണമായ സ്കോളർഷിപ്പ്, വാക്ചാതുര്യം, പഠനത്തിലെ പ്രശസ്തി, കലയിലും ശാസ്ത്രത്തിലും വൈദഗ്ദ്ധ്യം എന്നിവ നൽകുന്നു.";
"yoga_formation_bharathi_yoga" = "2/5/11-ാം ഭാവാധിപൻ്റെ നവാംശ അധിപൻ ഉന്നതനും 9-ാം അധിപനുമായി കൂടിച്ചേർന്നതുമാണ്.";

// [−] Bharyasahavyabhicharya Yoga
"yoga_name_bharyasahavyabhicharya_yoga" = "ഭാര്യാസഹവ്യഭിചാര്യ യോഗ";
"yoga_outcome_bharyasahavyabhicharya_yoga" = "വിവാഹത്തിലെ വിശ്വാസ പ്രശ്നങ്ങൾ; സുതാര്യതയ്ക്കും വൈകാരിക ബന്ധത്തിനും മുൻഗണന നൽകണം.";
"yoga_formation_bharyasahavyabhicharya_yoga" = "അവിശ്വസ്തതയെ സൂചിപ്പിക്കുന്ന ശുക്രനും ഏഴാം ഭാവവും.";

// [+] Bhaskara Yoga
"yoga_name_bhaskara_yoga" = "ഭാസ്കരയോഗം";
"yoga_outcome_bhaskara_yoga" = "പഠനത്തിൽ സോളാർ പോലെയുള്ള മിടുക്ക്; അധ്യാപനത്തിലൂടെ മറ്റുള്ളവരെ പ്രകാശിപ്പിക്കുന്നു.";
"yoga_formation_bhaskara_yoga" = "സൂര്യനിൽ നിന്ന് 2-ൽ ബുധൻ, 11-ൽ ചന്ദ്രൻ, ബുധനിൽ നിന്ന് ത്രികോണത്തിൽ വ്യാഴം.";

// [+] Bheri Yoga
"yoga_name_bheri_yoga" = "ഭേരി യോഗ";
"yoga_outcome_bheri_yoga" = "ഡ്രം പോലുള്ള പ്രശസ്തി; സമൃദ്ധി, ധൈര്യം, നിലനിൽക്കുന്ന പ്രശസ്തി, രാജകീയ പദവി.";
"yoga_formation_bheri_yoga" = "9-ാം ഭാവത്തിൽ നിന്ന് പരസ്പര കേന്ദ്രങ്ങളിൽ ശുക്രൻ, വ്യാഴം, ലഗ്നാധിപൻ.";

// [+] Bhojana Soukhya Yoga
"yoga_name_bhojana_soukhya_yoga" = "ഭോജന സൗഖ്യ യോഗ";
"yoga_outcome_bhojana_soukhya_yoga" = "നല്ല ഭക്ഷണം, പാചക ആനന്ദങ്ങൾ, സുഖപ്രദമായ ഡൈനിംഗ് ജീവിതശൈലി എന്നിവ ആസ്വദിക്കുന്നു.";
"yoga_formation_bhojana_soukhya_yoga" = "2-ആം ഭാവത്തിൽ ഗുണകരമായ ഭാവങ്ങളുള്ള ശക്തമായ 2-ആം അധിപൻ.";

// [+] Bhratrumoola Dhanaprapti (136)
"yoga_name_bhratrumoola_dhanaprapti_yoga_136" = "ഭ്തൃമൂല ധനപ്രാപ്തി (136)";
"yoga_outcome_bhratrumoola_dhanaprapti_yoga_136" = "സഹോദരങ്ങൾ, ധൈര്യം അല്ലെങ്കിൽ ആശയവിനിമയം എന്നിവയിലൂടെ സമ്പത്ത്; സഹോദരങ്ങൾ അഭിവൃദ്ധിയെ സഹായിക്കുന്നു.";
"yoga_formation_bhratrumoola_dhanaprapti_yoga_136" = "2-ഉം 11-ഉം വീടുകളുമായി (var. 1) ബന്ധിപ്പിച്ചിരിക്കുന്ന 3-ആം അധിപൻ.";

// [+] Bhratrumoola Dhanaprapti (137)
"yoga_name_bhratrumoola_dhanaprapti_yoga_137" = "ഭ്തൃമൂല ധനപ്രാപ്തി (137)";
"yoga_outcome_bhratrumoola_dhanaprapti_yoga_137" = "സഹോദര പങ്കാളിത്തം അല്ലെങ്കിൽ സഹകരണ സംരംഭങ്ങൾ വഴി സാമ്പത്തിക നേട്ടം.";
"yoga_formation_bhratrumoola_dhanaprapti_yoga_137" = "2-ഉം 11-ഉം വീടുകളുമായി (var. 2) ബന്ധിപ്പിച്ചിരിക്കുന്ന മൂന്നാമൻ.";

// [−] Bhratrusapa Sutakshaya Yoga
"yoga_name_bhratrusapa_sutakshaya_yoga" = "ഭ്രാതൃസപ സുതക്ഷയ യോഗ";
"yoga_outcome_bhratrusapa_sutakshaya_yoga" = "സന്തതിയെ ബാധിക്കുന്ന സഹോദരൻ്റെ ശാപം; പരിഹരിക്കപ്പെടാത്ത സാഹോദര്യ കർമ്മം കുട്ടികളെ ബാധിക്കുന്നു.";
"yoga_formation_bhratrusapa_sutakshaya_yoga" = "ദോഷകരമായ കോമ്പിനേഷനുകളിൽ ചൊവ്വ 5-ാം അധിപനെ ബാധിച്ചിരിക്കുന്നു.";

// [+] Brahma Yoga
"yoga_name_brahma_yoga" = "ബ്രഹ്മ യോഗ";
"yoga_outcome_brahma_yoga" = "വിജ്ഞാനാധിഷ്‌ഠിത തൊഴിലുകളിൽ അഗാധമായ ജ്ഞാനം, പണ്ഡിതോചിതമായ ഉദ്യമങ്ങൾ, ദൈവിക സംരക്ഷണം എന്നിവ നൽകുന്നു.";
"yoga_formation_brahma_yoga" = "പ്രത്യേക ആവശ്യകതകളോടെ 5, 11 എന്നീ രാശികളിൽ നിന്നുള്ള കേന്ദ്രങ്ങളിലെ ഗുണഫലങ്ങൾ.";

// [−] Buddhi Jada Yoga
"yoga_name_buddhi_jada_yoga" = "ബുദ്ധി ജഡ യോഗ";
"yoga_outcome_buddhi_jada_yoga" = "മന്ദഗതിയിലുള്ള പഠനം അല്ലെങ്കിൽ ബുദ്ധിപരമായ മന്ദത; സങ്കീർണ്ണമായ ആശയങ്ങൾ മനസ്സിലാക്കാൻ അധിക പരിശ്രമം ആവശ്യമാണ്.";
"yoga_formation_buddhi_jada_yoga" = "ബുധനെയും അഞ്ചാം ഭാവത്തെയും ശനി ബാധിക്കുന്നതിനാൽ ഗുണദോഷമില്ല.";

// [+] Buddhimaturya Yoga
"yoga_name_buddhimaturya_yoga" = "ബുദ്ധിമാതുര്യ യോഗ";
"yoga_outcome_buddhimaturya_yoga" = "പ്രായപൂർത്തിയായ ഒരു വ്യക്തിയുടെ ബുദ്ധിശക്തി; ജ്ഞാനം, വിശകലന ആഴം, പണ്ഡിത സ്വഭാവം.";
"yoga_formation_buddhimaturya_yoga" = "ബുധനും വ്യാഴവും പരസ്പര കേന്ദ്രത്തിൽ, അഞ്ചാം ഭാവാധിപൻ ബലവാൻ.";

// [+] Budha Aditya Yoga
"yoga_name_budha_aditya_yoga" = "ബുദ്ധ ആദിത്യ യോഗ";
"yoga_outcome_budha_aditya_yoga" = "ബൗദ്ധിക വൈഭവം നേതൃത്വവുമായി കൂടിച്ചേർന്നതാണ്; എക്സിക്യൂട്ടീവ് കഴിവുള്ള മികച്ച ആശയവിനിമയക്കാരൻ.";
