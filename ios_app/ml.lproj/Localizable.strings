"yoga_name_dhana_yoga_120" = "ധനയോഗ (120)";
"yoga_outcome_dhana_yoga_120" = "ഊഹക്കച്ചവടത്തിലൂടെയോ, അനന്തരാവകാശത്തിലൂടെയോ, മുൻകാല ജീവിത യോഗ്യതയിലൂടെയോ ഭാഗ്യം നൽകുന്നു.";
"yoga_formation_dhana_yoga_120" = "5-ഉം 9-ഉം അധിപന്മാർ 2-ഉം 11-ഉം അധിപന്മാരുമായി ബന്ധപ്പെട്ടിരിക്കുന്നു.";

// [+] Dhana Yoga (121)
"yoga_name_dhana_yoga_121" = "ധനയോഗ (121)";
"yoga_outcome_dhana_yoga_121" = "ജീവിതത്തിലുടനീളം ഒന്നിലധികം സ്രോതസ്സുകളിൽ നിന്ന് സ്ഥിരമായ സമ്പത്ത് പ്രവാഹം സൃഷ്ടിക്കുന്നു.";
"yoga_formation_dhana_yoga_121" = "ശക്തമായ അന്തസ്സോടെ 2-ഉം 11-ഉം വീടുകളിലെ ഗുണഫലങ്ങൾ.";

// [+] Dhana Yoga (122)
"yoga_name_dhana_yoga_122" = "ധനയോഗ (122)";
"yoga_outcome_dhana_yoga_122" = "സമ്പാദിക്കാനുള്ള സാധ്യതയും ഗണ്യമായ ആസ്തി ശേഖരണവും വർദ്ധിപ്പിക്കുന്നു.";
"yoga_formation_dhana_yoga_122" = "11-ആം ഗൃഹവുമായി ബന്ധിപ്പിച്ചിരിക്കുന്ന രണ്ടാം അധിപൻ ഉന്നതൻ അല്ലെങ്കിൽ സ്വന്തം രാശിയിൽ.";

// [+] Dhana Yoga (123)
"yoga_name_dhana_yoga_123" = "ധനയോഗ (123)";
"yoga_outcome_dhana_yoga_123" = "പ്രൊഫഷണൽ നെറ്റ്‌വർക്കുകൾ, അസോസിയേഷനുകൾ, സോഷ്യൽ കണക്ഷനുകൾ എന്നിവയിൽ നിന്നുള്ള നേട്ടങ്ങൾ ഉറപ്പാക്കുന്നു.";
"yoga_formation_dhana_yoga_123" = "ഗുണകരമായ ഭാവങ്ങളുള്ള 11-ാം അധിപൻ കേന്ദ്രത്തിലോ ത്രികോണത്തിലോ.";

// [+] Dhana Yoga (124)
"yoga_name_dhana_yoga_124" = "ധനയോഗ (124)";
"yoga_outcome_dhana_yoga_124" = "പിതൃ വംശം, ഭാഗ്യം, നീതിപൂർവമായ സമ്പാദ്യം എന്നിവയിലൂടെ സമ്പത്ത് നൽകുന്നു.";
"yoga_formation_dhana_yoga_124" = "9-ാം ഭാവാധിപനും ലഗ്നാധിപനും 2-ാം വീടിൻ്റെ പിന്തുണയുമായി പരസ്പര ബന്ധത്തിലാണ്.";

// [+] Dhana Yoga (125)
"yoga_name_dhana_yoga_125" = "ധനയോഗ (125)";
"yoga_outcome_dhana_yoga_125" = "സമ്പത്ത് ഉൽപ്പാദനത്തിനും സാമ്പത്തിക മാനേജ്മെൻ്റിനും അസാധാരണമായ ശേഷി സൃഷ്ടിക്കുന്നു.";
"yoga_formation_dhana_yoga_125" = "ദൃഢമായ 2ഉം 11ഉം ഗൃഹങ്ങൾ മാന്യമായ സ്ഥാനങ്ങളിൽ അധിപന്മാർ.";

// [+] Dhana Yoga (126)
"yoga_name_dhana_yoga_126" = "ധനയോഗ (126)";
"yoga_outcome_dhana_yoga_126" = "ബുദ്ധി, ഊഹക്കച്ചവടം, സൃഷ്ടിപരമായ സംരംഭങ്ങൾ എന്നിവയിലൂടെ സമ്പത്ത് നൽകുന്നു.";
"yoga_formation_dhana_yoga_126" = "2, 5, 11 എന്നീ രാശികൾ വശം അല്ലെങ്കിൽ സംയോജനം വഴി പരസ്പരം ബന്ധപ്പെട്ടിരിക്കുന്നു.";

// [+] Dhana Yoga (127)
"yoga_name_dhana_yoga_127" = "ധനയോഗ (127)";
"yoga_outcome_dhana_yoga_127" = "ധാർമ്മിക അടിത്തറയിൽ സമ്പത്ത് നൽകുന്നു; നീതി മാർഗങ്ങളിലൂടെ അഭിവൃദ്ധി.";
"yoga_formation_dhana_yoga_127" = "വ്യാഴം 2-ഉം 11-ഉം അധിപതികളുടെ ദൃഷ്ടി അല്ലെങ്കിൽ കൂടിച്ചേരൽ.";

// [+] Dhana Yoga (128)
"yoga_name_dhana_yoga_128" = "ധനയോഗ (128)";
"yoga_outcome_dhana_yoga_128" = "ആഡംബരങ്ങൾ, കലകൾ, വിനോദം അല്ലെങ്കിൽ സൗന്ദര്യ വ്യവസായങ്ങൾ എന്നിവയിലൂടെ സമ്പത്ത് കൊണ്ടുവരുന്നു.";
"yoga_formation_dhana_yoga_128" = "ശുക്രൻ ശക്തമായ അന്തസ്സോടെ 2, 11 എന്നീ വീടുകളുമായി ബന്ധപ്പെട്ടിരിക്കുന്നു.";

// [−] Dhatrutwa Yoga
"yoga_name_dhatrutwa_yoga" = "ധാതൃത്വ യോഗ";
"yoga_outcome_dhatrutwa_yoga" = "ബന്ധങ്ങൾ വളർത്തുന്നതിലും കുടുംബ സ്നേഹം പ്രകടിപ്പിക്കുന്നതിലും ഉള്ള വെല്ലുവിളികളെ സൂചിപ്പിക്കുന്നു.";
"yoga_formation_dhatrutwa_yoga" = "ലഗ്നാധിപനും നാലാം ഭാവത്തിനും പ്രത്യേക ഗ്രഹദോഷങ്ങൾ.";

// [+] Dhurdhura Yoga
"yoga_name_dhurdhura_yoga" = "ദുർധുര യോഗ";
"yoga_outcome_dhurdhura_yoga" = "ഉദാരമായ സ്വഭാവം, സമ്പത്ത്, കൈമാറ്റം, പരോപകാര സ്വഭാവം എന്നിവ നൽകുന്നു.";
"yoga_formation_dhurdhura_yoga" = "ചന്ദ്രനിൽ നിന്ന് 2-ലും 12-ലും ഉള്ള ഗ്രഹങ്ങൾ (സൂര്യൻ/രാഹു/കേതു ഒഴികെ).";

// [−] Dur Yoga
"yoga_name_dur_yoga" = "ദുർ യോഗ";
"yoga_outcome_dur_yoga" = "കരിയറുമായി ബന്ധപ്പെട്ട സാമ്പത്തിക ബുദ്ധിമുട്ടുകൾ; ആനുപാതിക വരുമാനത്തിലേക്ക് മാറ്റാനുള്ള ശ്രമം പരാജയപ്പെടുന്നു.";
"yoga_formation_dur_yoga" = "റദ്ദാക്കാതെ 6/8/12-ൽ 10-ാം അധിപൻ.";

// [−] Durmarana Yoga
"yoga_name_durmarana_yoga" = "ദുർമരണ യോഗ";
"yoga_outcome_durmarana_yoga" = "ജീവിതത്തിൻ്റെ അസ്വാഭാവികമോ ബുദ്ധിമുട്ടുള്ളതോ ആയ അവസാനത്തെ സൂചിപ്പിക്കുന്നു; ആത്മീയ ആചാരങ്ങൾ സംരക്ഷണം നൽകുന്നു.";
"yoga_formation_durmarana_yoga" = "പ്രയോജനപ്രദമായ ഇടപെടലുകളില്ലാതെ കേന്ദ്രങ്ങളിൽ/മാരകകളിൽ ഒന്നിലധികം ദോഷങ്ങൾ.";

// [−] Durmukha Yoga (168)
"yoga_name_durmukha_yoga_168" = "ദുർമുഖ യോഗ (168)";
"yoga_outcome_durmukha_yoga_168" = "ആകർഷകമല്ലാത്ത മുഖ സവിശേഷതകൾ അല്ലെങ്കിൽ ദന്ത പ്രശ്നങ്ങൾ; സൗന്ദര്യവർദ്ധക, ആരോഗ്യ സംരക്ഷണം ഉചിതം.";
"yoga_formation_durmukha_yoga_168" = "മുഖഭാവത്തെ ബാധിക്കുന്ന രണ്ടാമത്തെ വീട്ടിലെ ദുരുപയോഗം (var. 1).";

// [−] Durmukha Yoga (169)
"yoga_name_durmukha_yoga_169" = "ദുർമുഖ യോഗ (169)";
"yoga_outcome_durmukha_yoga_169" = "അസുഖകരമായ രൂപം അല്ലെങ്കിൽ മുഖത്തെ വിട്ടുമാറാത്ത ആരോഗ്യ പ്രശ്നങ്ങൾ.";
"yoga_formation_durmukha_yoga_169" = "ചന്ദ്രനും രണ്ടാം അധിപനും ദോഷങ്ങളാൽ പീഡിപ്പിക്കപ്പെടുന്നു (വാർ. 2).";

// [+] Ekaputra Yoga
"yoga_name_ekaputra_yoga" = "ഏകപുത്രയോഗം";
"yoga_outcome_ekaputra_yoga" = "അസാധാരണമായ അർപ്പണബോധവും വിജയവുമുള്ള ഒരു കുട്ടി; അളവിനേക്കാൾ ഗുണനിലവാരം.";
"yoga_formation_ekaputra_yoga" = "നിർദ്ദിഷ്ട പരിമിതമായ കോൺഫിഗറേഷനുകളിൽ 5-ാം നാഥൻ.";

// [+] Gaja Yoga
"yoga_name_gaja_yoga" = "ഗജയോഗം";
"yoga_outcome_gaja_yoga" = "അപാരമായ ഐശ്വര്യം, മനുഷ്യസ്നേഹം, മാന്യമായ, ആനയെപ്പോലെയുള്ള അധികാരം.";
"yoga_formation_gaja_yoga" = "ഗുണകരമായ ഭാവങ്ങളുള്ള ശക്തമായ 9, 10 ഭാവാധിപന്മാർ.";

// [+] Gajakesari Yoga
"yoga_name_gajakesari_yoga" = "ഗജകേസരി യോഗ";
"yoga_outcome_gajakesari_yoga" = "ബുദ്ധി, വാക്ചാതുര്യം, ശാശ്വതമായ പ്രശസ്തി, സദ്ഗുണസമ്പന്നമായ, സമ്പന്നമായ സ്വഭാവം എന്നിവ നൽകുന്നു.";
"yoga_formation_gajakesari_yoga" = "ചന്ദ്രനിൽ നിന്ന് ഒരു കേന്ദ്രത്തിൽ (1/4/7/10) വ്യാഴം.";

// [−] Galakarna Yoga
"yoga_name_galakarna_yoga" = "ഗലാകർണയോഗം";
"yoga_outcome_galakarna_yoga" = "ശ്രവണ വൈകല്യം അല്ലെങ്കിൽ ചെവി സംബന്ധമായ ആരോഗ്യ പ്രശ്നങ്ങൾ; ശ്രവണ പരിചരണം ആവശ്യമാണ്.";
"yoga_formation_galakarna_yoga" = "ബുധനെ ബാധിക്കുന്ന 3, 11 ഭാവങ്ങളിലെ ദോഷങ്ങൾ.";

// [+] Gandharva Yoga
"yoga_name_gandharva_yoga" = "ഗന്ധർവ്വയോഗം";
"yoga_outcome_gandharva_yoga" = "ഖഗോള കലാപരമായ കഴിവുകൾ; സംഗീതം, നൃത്തം, പെർഫോമിംഗ് ആർട്സ്, സർഗ്ഗാത്മക ആവിഷ്കാരം എന്നിവയിലെ മികവ്.";
"yoga_formation_gandharva_yoga" = "10-ാം അധിപൻ കാമ ത്രികോണത്തിൽ ശുക്രൻ ബലവാനായും ചന്ദ്രൻ ത്രികോണത്തിലുമായി.";

// [+] Garuda Yoga
"yoga_name_garuda_yoga" = "ഗരുഡയോഗം";
"yoga_outcome_garuda_yoga" = "കഴുകനെപ്പോലെയുള്ള കാഴ്ച; എതിരാളികളെ നശിപ്പിക്കുകയും മത്സരത്തിന് മുകളിൽ ഉയരുകയും ചെയ്യുന്നു.";
"yoga_formation_garuda_yoga" = "വ്യാഴത്തിൻ്റെയും 9-ാം അധിപൻ്റെയും ഗുണപരമായ ഭാവങ്ങളുള്ള ചന്ദ്രൻ ശക്തനാണ്.";

// [+] Gauri Yoga
"yoga_name_gauri_yoga" = "ഗൗരി യോഗ";
"yoga_outcome_gauri_yoga" = "സൗന്ദര്യം, സദ്‌ഗുണം, പരിഷ്‌കൃത സ്വഭാവം, മാതൃ കൃപ, ഗാർഹിക സന്തോഷം എന്നിവ നൽകുന്നു.";
"yoga_formation_gauri_yoga" = "9-ാം അധിപനും ചന്ദ്രനും സ്വന്തം/ഉയർന്ന രാശികളിൽ കേന്ദ്ര/ത്രികോണത്തിൽ; അല്ലെങ്കിൽ പത്താം ഭാവാധിപൻ്റെ നവാംശ അധിപൻ ലഗ്നാധിപനോടൊപ്പം 10-ൽ ഉയർന്നിരിക്കുന്നു.";

// [+] Go Yoga
"yoga_name_go_yoga" = "യോഗ പോകൂ";
"yoga_outcome_go_yoga" = "കൃഷി, ഭൂമി, അല്ലെങ്കിൽ പരിപോഷിപ്പിക്കുന്ന സംരംഭങ്ങൾ എന്നിവയിലൂടെ അഭിവൃദ്ധി.";
"yoga_formation_go_yoga" = "വ്യാഴം ത്രികോണത്തിൽ, ലഗ്നാധിപൻ ഗുണകരമായ നവാംശത്തിൽ.";

// [−] Gohanta Yoga
"yoga_name_gohanta_yoga" = "ഗോഹന്ത യോഗ";
"yoga_outcome_gohanta_yoga" = "മൃഗങ്ങളോടുള്ള ക്രൂരമായ പ്രവണതകൾ; ജീവികൾക്കെതിരായ അക്രമാസക്തമായ പ്രവർത്തനങ്ങളിൽ നിന്നുള്ള കർമ്മഫലങ്ങൾ.";
"yoga_formation_gohanta_yoga" = "ചൊവ്വയും രാഹുവും ഗുണകരമായ സംരക്ഷണമില്ലാതെ നിർദ്ദിഷ്ട വീടുകളെ ബാധിക്കുന്നു.";

// [+] Gola Yoga
"yoga_name_gola_yoga" = "ഗോള യോഗ";
"yoga_outcome_gola_yoga" = "ആത്മീയ സമ്പൂർണ്ണതയും പ്രപഞ്ച ധാരണയും; വ്യക്തി സാർവത്രിക സത്യങ്ങൾ മനസ്സിലാക്കുന്നു.";
"yoga_formation_gola_yoga" = "ഗോളാകൃതിയിലുള്ള പൂർണ്ണത സൃഷ്ടിക്കുന്ന പ്രത്യേക ഗ്രഹ കോൺഫിഗറേഷൻ.";

// [−] Grihanasa Yoga (191)
"yoga_name_grihanasa_yoga_191" = "ഗൃഹനാസ യോഗ (191)";
"yoga_outcome_grihanasa_yoga_191" = "നിർഭാഗ്യകരമായ സംഭവങ്ങളിലൂടെയോ നിയമപരമായ തർക്കങ്ങളിലൂടെയോ സ്വത്ത് നഷ്ടപ്പെടുന്നു.";
"yoga_formation_grihanasa_yoga_191" = "ദുസ്താനത്തിലെ ദുരാചാരങ്ങളാൽ പീഡിപ്പിക്കപ്പെട്ട നാലാമത്തെ അധിപൻ (വാർ. 1).";

// [−] Grihanasa Yoga (192)
"yoga_name_grihanasa_yoga_192" = "ഗൃഹനാസ യോഗ (192)";
"yoga_outcome_grihanasa_yoga_192" = "വസ്തുവകകളുടെ നാശം അല്ലെങ്കിൽ നിർബന്ധിത വിൽപ്പന; ഭവന അസ്ഥിരത.";
"yoga_formation_grihanasa_yoga_192" = "4-ആം ഭാവത്തിലെ ദോഷങ്ങൾ, 4-ആം അധിപൻ ദുർബലനായി (var. 2).";

// [−] Guhyaroga Yoga
"yoga_name_guhyaroga_yoga" = "ഗുഹ്യരോഗ യോഗ";
"yoga_outcome_guhyaroga_yoga" = "അടുപ്പമുള്ള ജീവിതത്തെ ബാധിക്കുന്ന സ്വകാര്യ ആരോഗ്യപ്രശ്നങ്ങൾക്കുള്ള സാധ്യത; പ്രതിരോധ പരിചരണം നിർദ്ദേശിച്ചു.";
"yoga_formation_guhyaroga_yoga" = "ശുക്രൻ, 7, 8 ഭാവങ്ങൾക്ക് ദോഷം.";

// [+] Hamsa Yoga
"yoga_name_hamsa_yoga" = "ഹംസ യോഗ";
"yoga_outcome_hamsa_yoga" = "അസാധാരണമായ ജ്ഞാനം, ധാർമ്മിക സമഗ്രത, ആത്മീയ ചായ്‌വുകൾ, സമൂഹത്തിൽ മാന്യമായ സ്ഥാനം എന്നിവ നൽകുന്നു.";
"yoga_formation_hamsa_yoga" = "വ്യാഴം ഒരു കേന്ദ്രത്തിൽ (1/4/7/10) സ്വന്തം രാശിയിൽ (ധനു/മീനം) അല്ലെങ്കിൽ ഉയർച്ചയിൽ (കർക്കടകം).";

// [+] Harihara Brahma Yoga
"yoga_name_harihara_brahma_yoga" = "ഹരിഹര ബ്രഹ്മ യോഗ";
"yoga_outcome_harihara_brahma_yoga" = "പരിശുദ്ധ ത്രിത്വത്തിൻ്റെ പരമോന്നത ദൈവിക അനുഗ്രഹം; അസാധാരണമായ ആത്മീയ അധികാരവും പ്രാപഞ്ചിക ബന്ധവും.";
"yoga_formation_harihara_brahma_yoga" = "2-ഉം 12-ഉം അധിപന്മാരിൽ നിന്നോ 7-ാം/ലഗ്നാധിപൻമാരിൽ നിന്നോ പ്രത്യേക വീടുകളിലെ ഗുണങ്ങൾ.";

// [+] Harsha Yoga
"yoga_name_harsha_yoga" = "ഹർഷ യോഗ";
"yoga_outcome_harsha_yoga" = "പ്രതികൂല സാഹചര്യങ്ങളെ നേട്ടമാക്കി മാറ്റുന്നു; ശത്രുക്കളെ കീഴടക്കുകയും ശക്തരാകുകയും ചെയ്യുന്നു.";
"yoga_formation_harsha_yoga" = "6, 8, അല്ലെങ്കിൽ 12 ആം ഭാവങ്ങളിൽ ആറാം അധിപൻ (ദുസ്ഥാനത്തിലെ ദുസ്ഥാനം).";

// [+] Indra Yoga
"yoga_name_indra_yoga" = "ഇന്ദ്രയോഗം";
"yoga_outcome_indra_yoga" = "ഇന്ദ്രനെപ്പോലെയുള്ള ശക്തി; സൈന്യങ്ങൾ, ഓർഗനൈസേഷനുകൾ അല്ലെങ്കിൽ വലിയ സംരംഭങ്ങൾ എന്നിവയ്ക്ക് കമാൻഡുകൾ നൽകുന്നു.";
"yoga_formation_indra_yoga" = "5-ഉം 11-ഉം ഭാവാധിപന്മാർ ഗുണകരമായ ചൊവ്വയുള്ള പരസ്പര കേന്ദ്രങ്ങളിൽ.";

// [−] Jada Yoga
"yoga_name_jada_yoga" = "ജഡ യോഗ";
"yoga_outcome_jada_yoga" = "മാനസിക അലസത, മന്ദത, അല്ലെങ്കിൽ വിഷാദ പ്രവണതകൾ; സജീവമായ ജീവിതശൈലിയും ഉത്തേജന സഹായവും.";
"yoga_formation_jada_yoga" = "ഗുണപരമായ സ്വാധീനമില്ലാതെ ശനിയുടെ ദൃഷ്ടിയിൽ ചന്ദ്രൻ.";

// [−] Jananatpurvam Pitru Marana Yoga
"yoga_name_jananatpurvam_pitru_marana_yoga" = "ജനനത്പൂർവം പിതൃ മരണയോഗം";
"yoga_outcome_jananatpurvam_pitru_marana_yoga" = "പിതൃ സ്വാധീനത്തിൻ്റെ ആദ്യകാല നഷ്ടം; ചെറുപ്പം മുതലേ വ്യക്തി സ്വാശ്രയത്വം വളർത്തിയെടുക്കണം.";
"yoga_formation_jananatpurvam_pitru_marana_yoga" = "നേരത്തെയുള്ള പിതൃ നഷ്ടത്തെ സൂചിപ്പിക്കുന്ന പ്രത്യേക സൂര്യാഘാതങ്ങൾ.";

// [−] Jara Yoga
"yoga_name_jara_yoga" = "ജരയോഗം";
"yoga_outcome_jara_yoga" = "അകാല വാർദ്ധക്യം, വാർദ്ധക്യ ബുദ്ധിമുട്ടുകൾ, അല്ലെങ്കിൽ പിന്നീടുള്ള വർഷങ്ങളിൽ ചൈതന്യം കുറയുന്നു.";
"yoga_formation_jara_yoga" = "ലഗ്നാധിപനും ഏഴാം ഭാവാധിപനും ശനിയുടെ സ്വാധീനത്താൽ കഷ്ടപ്പെടുന്നു.";

// [−] Jarajaputra Yoga
"yoga_name_jarajaputra_yoga" = "ജരാജപുത്രയോഗം";
"yoga_outcome_jarajaputra_yoga" = "ജീവിതത്തിൽ വളരെ വൈകി ജനിച്ച കുട്ടികൾ; ബന്ധപ്പെട്ട വെല്ലുവിളികൾക്കൊപ്പം രക്ഷാകർതൃത്വം വൈകി.";
"yoga_formation_jarajaputra_yoga" = "അഞ്ചാം അധിപൻ ശനിയുമായി ബന്ധപ്പെട്ടിരിക്കുന്നു, വൈകി സജീവമാകുന്ന ദശ.";

// [+] Jaya Yoga
"yoga_name_jaya_yoga" = "ജയ യോഗ";
"yoga_outcome_jaya_yoga" = "മത്സരാർത്ഥികൾക്കെതിരെ വിജയം; മത്സരപരവും നിയമപരവുമായ കാര്യങ്ങളിൽ വിജയിക്കും.";
"yoga_formation_jaya_yoga" = "ആറാം ഭാവാധിപൻ തളർച്ച, ലഗ്നാധിപൻ ബലവാൻ.";

// [+] Kahala Yoga
"yoga_name_kahala_yoga" = "കഹല യോഗ";
"yoga_outcome_kahala_yoga" = "തികഞ്ഞ ഇച്ഛാശക്തിയിലൂടെ ധീരമായ ദൃഢനിശ്ചയവും അധികാരവും.";
"yoga_formation_kahala_yoga" = "4-ാം അധിപനും വ്യാഴവും പരസ്പര കേന്ദ്രങ്ങളിൽ, ലഗ്നാധിപൻ ബലവാൻ.";

// [+] Kalanidhi Yoga
"yoga_name_kalanidhi_yoga" = "കലാനിധി യോഗ";
"yoga_outcome_kalanidhi_yoga" = "കലയുടെയും പഠനത്തിൻ്റെയും നിധി; ഫൈൻ ആർട്സ്, സംഗീതം, സാംസ്കാരിക നേട്ടങ്ങൾ എന്നിവയിൽ വൈദഗ്ദ്ധ്യം.";
"yoga_formation_kalanidhi_yoga" = "വ്യാഴം ബുധനും ശുക്രനും ചേർന്ന് 2 അല്ലെങ്കിൽ 5 ഭാവത്തിൽ.";

// [+] Kalanirdesat Putra Yoga (227)
"yoga_name_kalanirdesat_putra_yoga_227" = "കലാനിർദേശാത് പുത്ര യോഗ (227)";
"yoga_outcome_kalanirdesat_putra_yoga_227" = "കുട്ടികൾ ഒരു പ്രത്യേക, ജ്യോതിഷപരമായി അനുകൂലമായ കാലഘട്ടത്തിൽ എത്തിച്ചേരുന്നു.";
"yoga_formation_kalanirdesat_putra_yoga_227" = "5-ാം അധിപൻ നിർദ്ദിഷ്ട ദശാ സമയത്തിൽ സജീവമാക്കി (var. 1).";

// [+] Kalanirdesat Putra Yoga (228)
"yoga_name_kalanirdesat_putra_yoga_228" = "കലാനിർദേശാത് പുത്ര യോഗ (228)";
"yoga_outcome_kalanirdesat_putra_yoga_228" = "പ്രസവ സമയം ഗ്രഹകാലവുമായി ബന്ധപ്പെട്ടിരിക്കുന്നു; അനുകൂലമായ ദശകളിൽ കുട്ടികൾ.";
"yoga_formation_kalanirdesat_putra_yoga_228" = "5-ാം അധിപൻ നിർദ്ദിഷ്ട ദശാ സമയത്തിൽ സജീവമാക്കി (var. 2).";

// [−] Kalanirdesat Putranasa Yoga (229)
"yoga_name_kalanirdesat_putranasa_yoga_229" = "കലാനിർദേശാത് പുത്രനാശ യോഗ (229)";
"yoga_outcome_kalanirdesat_putranasa_yoga_229" = "പ്രത്യേക പ്രതികൂല ഗ്രഹ കാലഘട്ടത്തിൽ സന്താന നഷ്ടം.";
"yoga_formation_kalanirdesat_putranasa_yoga_229" = "5-ആം അധിപൻ നിർദ്ദിഷ്ട ദശയിൽ (var. 1) പീഡിപ്പിക്കപ്പെടുന്നു.";

// [−] Kalanirdesat Putranasa Yoga (230)
"yoga_name_kalanirdesat_putranasa_yoga_230" = "കലാനിർദേശാത് പുത്രനാശ യോഗ (230)";
"yoga_outcome_kalanirdesat_putranasa_yoga_230" = "കുട്ടികളുമായി ബന്ധപ്പെട്ട ദുഃഖം ദോഷകരമായ ഗ്രഹ കാലഘട്ടങ്ങളുടെ സമയവുമായി ബന്ധപ്പെട്ടിരിക്കുന്നു.";
"yoga_formation_kalanirdesat_putranasa_yoga_230" = "5-ആം അധിപൻ നിർദ്ദിഷ്ട ദശയിൽ (വാർ. 2) പീഡിപ്പിക്കപ്പെടുന്നു.";

// [+] Kalatramooladhana Yoga
"yoga_name_kalatramooladhana_yoga" = "കളത്രമൂലധനയോഗം";
"yoga_outcome_kalatramooladhana_yoga" = "വിവാഹം, ബിസിനസ് പങ്കാളിത്തം, അല്ലെങ്കിൽ ഇണയുടെ വരുമാനം എന്നിവയിലൂടെയുള്ള സമ്പത്ത്.";
"yoga_formation_kalatramooladhana_yoga" = "ഏഴാം അധിപൻ 2ഉം 11ഉം വീടുകളുമായി ബന്ധപ്പെട്ടിരിക്കുന്നു.";

// [−] Kalatrashanda Yoga
"yoga_name_kalatrashanda_yoga" = "കളത്രശണ്ഡ യോഗ";
"yoga_outcome_kalatrashanda_yoga" = "ലൈംഗിക അപര്യാപ്തത അല്ലെങ്കിൽ പ്രത്യുൽപാദന വെല്ലുവിളികൾ; മെഡിക്കൽ കൺസൾട്ടേഷൻ ശുപാർശ ചെയ്യുന്നു.";
"yoga_formation_kalatrashanda_yoga" = "ബലഹീനതയിൽ ഏഴാം അധിപനെ ശുക്രൻ കഠിനമായി ബാധിച്ചു.";

// [−] Kapata Yoga (202)
"yoga_name_kapata_yoga_202" = "കപട യോഗ (202)";
"yoga_outcome_kapata_yoga_202" = "തന്ത്രപരമായ പെരുമാറ്റത്തിലേക്കുള്ള ചായ്വ് നിർദ്ദേശിക്കുന്നു; സുതാര്യത വളർത്തിയെടുക്കാൻ നിർദ്ദേശിക്കുന്നു.";
"yoga_formation_kapata_yoga_202" = "വഞ്ചനാപരമായ പ്രവണതകളെ സൂചിപ്പിക്കുന്ന പ്രത്യേക ദോഷകരമായ കോമ്പിനേഷനുകൾ (var. 1).";

// [−] Kapata Yoga (203)
"yoga_name_kapata_yoga_203" = "കപട യോഗ (203)";
"yoga_outcome_kapata_yoga_203" = "കൃത്രിമ പെരുമാറ്റത്തിനുള്ള സാധ്യതയെ സൂചിപ്പിക്കുന്നു; ധാർമ്മിക അച്ചടക്കത്തിന് ഇത് ലഘൂകരിക്കാനാകും.";
"yoga_formation_kapata_yoga_203" = "വഞ്ചനാപരമായ പ്രവണതകളെ സൂചിപ്പിക്കുന്ന പ്രത്യേക ദോഷകരമായ കോമ്പിനേഷനുകൾ (var. 2).";

// [−] Kapata Yoga (204)
"yoga_name_kapata_yoga_204" = "കപട യോഗ (204)";
"yoga_outcome_kapata_yoga_204" = "ഇരട്ടത്താപ്പിനുള്ള പ്രവണത നിർദ്ദേശിക്കുന്നു; സമഗ്രത സമ്പ്രദായങ്ങളും സ്വയം അവബോധവും ശുപാർശ ചെയ്യുന്നു.";
"yoga_formation_kapata_yoga_204" = "വഞ്ചനാപരമായ പ്രവണതകളെ സൂചിപ്പിക്കുന്ന പ്രത്യേക ദോഷകരമായ കോമ്പിനേഷനുകൾ (var. 3).";

// [−] Karascheda Yoga
"yoga_name_karascheda_yoga" = "കരസ്ചേദ യോഗ";
