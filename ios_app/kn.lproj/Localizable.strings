// [+] Bhagya Yoga
"yoga_name_bhagya_yoga" = "ಭಾಗ್ಯ ಯೋಗ";
"yoga_outcome_bhagya_yoga" = "ಅಸಾಧಾರಣ ಅದೃಷ್ಟ, ಅದೃಷ್ಟ ಮತ್ತು ದೈವಿಕ ಅನುಗ್ರಹ; ಸಮಯೋಚಿತ ಅವಕಾಶಗಳೊಂದಿಗೆ ಆಶೀರ್ವದಿಸಿದರು.";
