"yoga_outcome_ravi_yoga" = "ಸೌರ ಅಧಿಕಾರ - ಸಾರ್ವಜನಿಕ ಜೀವನದಲ್ಲಿ ಮತ್ತು ಸರ್ಕಾರದಲ್ಲಿ ವಿಶ್ವಾಸದಿಂದ ಹೊಳೆಯುತ್ತದೆ.";
"yoga_formation_ravi_yoga" = "ಸೂರ್ಯ 10ರಲ್ಲಿ ಸ್ವಂತ/ಉನ್ನತ, 9ನೇ ಅಧಿಪತಿ ಬಲಿಷ್ಠ.";

// [−] Rogagrastha Yoga
"yoga_name_rogagrastha_yoga" = "ರೋಗಗ್ರಸ್ಥ ಯೋಗ";
"yoga_outcome_rogagrastha_yoga" = "ದೀರ್ಘಕಾಲದ ಕಾಯಿಲೆಯ ಒಳಗಾಗುವಿಕೆ; ಮರುಕಳಿಸುವ ಆರೋಗ್ಯ ಸಮಸ್ಯೆಗಳಿಗೆ ವ್ಯಕ್ತಿ ಒಲವು.";
"yoga_formation_rogagrastha_yoga" = "6ನೇ ಅಧಿಪತಿ ಬಲಶಾಲಿ, ಲಗ್ನಾಧಿಪತಿ ಬಲಹೀನ, ಲಗ್ನ ದೃಷ್ಟಿ ದೋಷ.";

// [+] Ruchaka Yoga
"yoga_name_ruchaka_yoga" = "ರುಚಕ ಯೋಗ";
"yoga_outcome_ruchaka_yoga" = "ಧೈರ್ಯ, ದೈಹಿಕ ಚೈತನ್ಯ, ಕಮಾಂಡಿಂಗ್ ಉಪಸ್ಥಿತಿ ಮತ್ತು ಸ್ಪರ್ಧಾತ್ಮಕ ಅಥವಾ ಮಿಲಿಟರಿ ಕ್ಷೇತ್ರಗಳಲ್ಲಿ ಯಶಸ್ಸನ್ನು ನೀಡುತ್ತದೆ.";
"yoga_formation_ruchaka_yoga" = "ಕೇಂದ್ರದಲ್ಲಿ ಮಂಗಳ (1/4/7/10) ಸ್ವಂತ ರಾಶಿಯಲ್ಲಿ (ಮೇಷ/ವೃಶ್ಚಿಕ) ಅಥವಾ ಉತ್ಕೃಷ್ಟತೆ (ಮಕರ ಸಂಕ್ರಾಂತಿ).";

// [+] Sada Sanchara Yoga
"yoga_name_sada_sanchara_yoga" = "ಸದಾ ಸಂಚಾರ ಯೋಗ";
"yoga_outcome_sada_sanchara_yoga" = "ನಿರಂತರ ಪ್ರಯಾಣವನ್ನು ಒಳಗೊಂಡಿರುವ ವೃತ್ತಿ - ರಾಜತಾಂತ್ರಿಕತೆ, ಸಲಹಾ ಅಥವಾ ಅಂತರಾಷ್ಟ್ರೀಯ ವ್ಯಾಪಾರ.";
"yoga_formation_sada_sanchara_yoga" = "3ನೇ/7ನೇ/12ನೇ ಮನೆಗಳಿಗೆ ಸಂಪರ್ಕಗೊಂಡಿರುವ 10ನೇ ಅಧಿಪತಿ ಚಲಿಸಬಲ್ಲ ಚಿಹ್ನೆ.";

// [−] Sahodareesangama Yoga
"yoga_name_sahodareesangama_yoga" = "ಸಹೋದರಿಸಂಗಮ ಯೋಗ";
"yoga_outcome_sahodareesangama_yoga" = "ಪ್ರಜ್ಞಾಪೂರ್ವಕ ಗಡಿಗಳ ಅಗತ್ಯವಿರುವ ಒಡಹುಟ್ಟಿದ ಸಂಬಂಧಗಳಲ್ಲಿ ಅನುಚಿತ ಡೈನಾಮಿಕ್ಸ್.";
"yoga_formation_sahodareesangama_yoga" = "3ನೇ ಅಧಿಪತಿ ಮತ್ತು ಶುಕ್ರ ಪೀಡಿತ ಸಂಯೋಜನೆಯಲ್ಲಿ.";

// [−] Sakata Yoga
"yoga_name_sakata_yoga" = "ಸಕಟ ಯೋಗ";
"yoga_outcome_sakata_yoga" = "ಏರಿಳಿತದ ಅದೃಷ್ಟ - ಹಿನ್ನಡೆಗಳೊಂದಿಗೆ ಸಮೃದ್ಧಿ ಪರ್ಯಾಯವಾಗಿ; ಸ್ಥಿರತೆಗೆ ಪ್ರಯತ್ನದ ಅಗತ್ಯವಿದೆ.";
"yoga_formation_sakata_yoga" = "ಗುರುಗ್ರಹದಿಂದ 6/8/12ರಲ್ಲಿ ಚಂದ್ರ.";

// [−] Sanghataka Marana Yoga (276)
"yoga_name_sanghataka_marana_yoga_276" = "ಸಂಘಟಕ ಮರಣ ಯೋಗ (276)";
"yoga_outcome_sanghataka_marana_yoga_276" = "ಸಾಮೂಹಿಕ ದುರಂತ ಅಥವಾ ಸಾಮೂಹಿಕ-ಘಟನೆ ದುರ್ಬಲತೆ; ದುಷ್ಕೃತ್ಯದ ಸಮಯದಲ್ಲಿ ಎಚ್ಚರಿಕೆ.";
"yoga_formation_sanghataka_marana_yoga_276" = "ಸಾವು-ಉಂಟುಮಾಡುವ ಮನೆಗಳಲ್ಲಿ ನಿರ್ದಿಷ್ಟ ದೋಷಪೂರಿತ ಗುಂಪುಗಳು (ವರ್. 1).";

// [−] Sanghataka Marana Yoga (277)
"yoga_name_sanghataka_marana_yoga_277" = "ಸಂಘಟಕ ಮರಣ ಯೋಗ (277)";
"yoga_outcome_sanghataka_marana_yoga_277" = "ಗುಂಪು ಚಟುವಟಿಕೆಗಳು ಅಥವಾ ಪ್ರಯಾಣದ ಸಮಯದಲ್ಲಿ ಅಪಾಯ; ಅಪಾಯದ ಅವಧಿಯಲ್ಲಿ ಹೆಚ್ಚಿನ ಜಾಗೃತಿ.";
"yoga_formation_sanghataka_marana_yoga_277" = "ಸಾವು-ಉಂಟುಮಾಡುವ ಮನೆಗಳಲ್ಲಿ ನಿರ್ದಿಷ್ಟ ದೋಷಪೂರಿತ ಗುಂಪುಗಳು (ವರ್. 2).";

// [+] Sankha Yoga
"yoga_name_sankha_yoga" = "ಸಂಖ ಯೋಗ";
"yoga_outcome_sankha_yoga" = "ಶಂಖದಂತಹ ರಾಜ ಅಧಿಕಾರ; ಸಂಪತ್ತು, ದೀರ್ಘಾಯುಷ್ಯ ಮತ್ತು ಮಾನವೀಯ ನಾಯಕತ್ವ.";
"yoga_formation_sankha_yoga" = "5 ಮತ್ತು 6 ನೇ ಅಧಿಪತಿಗಳು ಬಲವಾದ ಲಗ್ನಾಧಿಪತಿಯೊಂದಿಗೆ ಪರಸ್ಪರ ಕೇಂದ್ರಗಳಲ್ಲಿ.";

// [+] Sarala Yoga
"yoga_name_sarala_yoga" = "ಸರಳ ಯೋಗ";
"yoga_outcome_sarala_yoga" = "ನಿರ್ಭಯತೆ ಮತ್ತು ದೀರ್ಘಾಯುಷ್ಯವನ್ನು ನೀಡುತ್ತದೆ; ಸ್ಥಿತಿಸ್ಥಾಪಕತ್ವದ ಮೂಲಕ ಗುಪ್ತ ಅಪಾಯಗಳನ್ನು ಜಯಿಸುತ್ತದೆ.";
"yoga_formation_sarala_yoga" = "6ನೇ, 8ನೇ, ಅಥವಾ 12ನೇ ಮನೆಯಲ್ಲಿ 8ನೇ ಅಧಿಪತಿ (ದುಸ್ತಾನದಲ್ಲಿ ದುಸ್ಥಾನ).";

// [+] Saraswathi Yoga Education
"yoga_name_saraswathi_yoga_education" = "ಸರಸ್ವತಿ ಯೋಗ ಶಿಕ್ಷಣ";
"yoga_outcome_saraswathi_yoga_education" = "ಫಲಿತಾಂಶದ ವಿವರಗಳನ್ನು ಸೇರಿಸಬೇಕು";
"yoga_formation_saraswathi_yoga_education" = "ರಚನೆಯ ವಿವರಗಳನ್ನು ಸೇರಿಸಬೇಕು";

// [+] Sareera Soukhya Yoga
"yoga_name_sareera_soukhya_yoga" = "ಶರೀರ ಸೌಖ್ಯ ಯೋಗ";
"yoga_outcome_sareera_soukhya_yoga" = "ದೈಹಿಕ ಸೌಕರ್ಯ, ಉತ್ತಮ ಆರೋಗ್ಯ ಮತ್ತು ಜೀವನದುದ್ದಕ್ಕೂ ದೃಢವಾದ ಸಂವಿಧಾನ.";
"yoga_formation_sareera_soukhya_yoga" = "ಲಗ್ನದ ಮೇಲೆ ಲಾಭದಾಯಕ ಅಂಶಗಳೊಂದಿಗೆ ಸ್ವಂತ/ಉನ್ನತ ಚಿಹ್ನೆಯಲ್ಲಿ ಲಗ್ನಾಧಿಪತಿ.";

// [−] Sarpaganda Yoga
"yoga_name_sarpaganda_yoga" = "ಸರ್ಪಗಂಡ ಯೋಗ";
"yoga_outcome_sarpaganda_yoga" = "ಹಾವು ಕಡಿತ ಅಥವಾ ಸರೀಸೃಪ-ಸಂಬಂಧಿತ ಅಪಾಯಗಳಿಗೆ ಒಳಗಾಗುವಿಕೆ; ಸರ್ಪಗಳ ಬಳಿ ಎಚ್ಚರಿಕೆ.";
"yoga_formation_sarpaganda_yoga" = "ಲಗ್ನದ ಮೇಲೆ ದೋಷಪೂರಿತ ಅಂಶಗಳೊಂದಿಗೆ ನಿರ್ದಿಷ್ಟ ಸ್ಥಾನಗಳಲ್ಲಿ ರಾಹು.";

// [−] Sarpasapa Yoga (212)
"yoga_name_sarpasapa_yoga_212" = "ಸರ್ಪಸಾಪ ಯೋಗ (212)";
"yoga_outcome_sarpasapa_yoga_212" = "ಸಂತತಿಯ ಮೇಲೆ ಪರಿಣಾಮ ಬೀರುವ ಸರ್ಪ ಶಾಪ; ಮಗುವನ್ನು ಹೆರಲು ಕರ್ಮದ ಅಡೆತಡೆಗಳು.";
"yoga_formation_sarpasapa_yoga_212" = "5ನೇ ಸ್ಥಾನದಲ್ಲಿ ರಾಹು ದೋಷಪೂರಿತ ಅಂಶಗಳೊಂದಿಗೆ, ಯಾವುದೇ ಪ್ರಯೋಜನಕಾರಿ ಪರಿಹಾರವಿಲ್ಲ (ವರ್. 1).";

// [−] Sarpasapa Yoga (213)
"yoga_name_sarpasapa_yoga_213" = "ಸರ್ಪಸಾಪ ಯೋಗ (213)";
"yoga_outcome_sarpasapa_yoga_213" = "ಪೂರ್ವಜರ ಕರ್ಮದ ಸಾಲವು ಫಲವತ್ತತೆಯ ಸವಾಲುಗಳಾಗಿ ಪ್ರಕಟವಾಗುತ್ತದೆ.";
"yoga_formation_sarpasapa_yoga_213" = "5ನೇ-11ನೇ ತಾರೀಖಿನಂದು ರಾಹು/ಕೇತು ಅಕ್ಷ ಪೀಡಿತ 5ನೇ ಅಧಿಪತಿಯೊಂದಿಗೆ (ವರ್. 2).";

// [−] Sarpasapa Yoga (214)
"yoga_name_sarpasapa_yoga_214" = "ಸರ್ಪಸಾಪ ಯೋಗ (214)";
"yoga_outcome_sarpasapa_yoga_214" = "ಮಕ್ಕಳನ್ನು ಹೊಂದಲು ಆಳವಾಗಿ ಬೇರೂರಿರುವ ಕರ್ಮ ತಡೆ; ಆಧ್ಯಾತ್ಮಿಕ ಪರಿಹಾರಗಳು ಅಗತ್ಯ.";
"yoga_formation_sarpasapa_yoga_214" = "ಶನಿಯೊಂದಿಗೆ 5 ರಲ್ಲಿ ನಿರ್ದಿಷ್ಟ ರಾಹು ಸಂಯೋಜನೆಗಳು (ವರ್. 3).";

// [−] Sarpasapa Yoga (215)
"yoga_name_sarpasapa_yoga_215" = "ಸರ್ಪಸಾಪ ಯೋಗ (215)";
"yoga_outcome_sarpasapa_yoga_215" = "ಕುಟುಂಬದ ವಂಶಾವಳಿಯ ಮೇಲೆ ತೀವ್ರವಾದ ಸರ್ಪ ಶಾಪ ಪರಿಣಾಮ; ಧಾರ್ಮಿಕ ಶುದ್ಧೀಕರಣವನ್ನು ಶಿಫಾರಸು ಮಾಡಲಾಗಿದೆ.";
"yoga_formation_sarpasapa_yoga_215" = "5ನೇ ಸ್ಥಾನದಲ್ಲಿ ರಾಹು 5ನೇ ಅಧಿಪತಿಯೊಂದಿಗೆ 6ನೇ/8ನೇ/12ನೇ (ವರ್. 4).";

// [+] Sasa Yoga
"yoga_name_sasa_yoga" = "ಶಾಸ ಯೋಗ";
"yoga_outcome_sasa_yoga" = "ಶಿಸ್ತು, ಆಡಳಿತದಲ್ಲಿ ನಾಯಕತ್ವ ಮತ್ತು ಪರಿಶ್ರಮ ಮತ್ತು ಕ್ರಮಬದ್ಧ ಪ್ರಯತ್ನದ ಮೂಲಕ ಯಶಸ್ಸನ್ನು ನೀಡುತ್ತದೆ.";
"yoga_formation_sasa_yoga" = "ಶನಿಯು ಕೇಂದ್ರದಲ್ಲಿ (1/4/7/10) ಸ್ವಂತ ರಾಶಿಯಲ್ಲಿ (ಮಕರ ಸಂಕ್ರಾಂತಿ/ಕುಂಭ) ಅಥವಾ ಉನ್ನತಿಯಲ್ಲಿ (ತುಲಾ).";

// [+] Satkalatra Yoga
"yoga_name_satkalatra_yoga" = "ಸತ್ಕಲತ್ರ ಯೋಗ";
"yoga_outcome_satkalatra_yoga" = "ಉದಾತ್ತ, ಸದ್ಗುಣಶೀಲ ಸಂಗಾತಿ ಮತ್ತು ಸಾಮರಸ್ಯದ ಮದುವೆ; ಜೀವನ ಸಂಗಾತಿಯು ಅದೃಷ್ಟ ಮತ್ತು ಸಂತೋಷವನ್ನು ತರುತ್ತಾನೆ.";
"yoga_formation_satkalatra_yoga" = "7ನೇ ಅಧಿಪತಿಯು ಶುಕ್ರನ ಬಲವಾದ ಮತ್ತು ಲಾಭದಾಯಕ ಅಂಶಗಳೊಂದಿಗೆ ಉತ್ತಮ ಸ್ಥಾನವನ್ನು ಹೊಂದಿದ್ದಾನೆ.";

// [+] Satkathadisravana Yoga
"yoga_name_satkathadisravana_yoga" = "ಸತ್ಕಥಾದಿಶ್ರವಣ ಯೋಗ";
"yoga_outcome_satkathadisravana_yoga" = "ಪವಿತ್ರ ಜ್ಞಾನ, ತಾತ್ವಿಕ ಕಲಿಕೆ ಮತ್ತು ಉನ್ನತ ಬುದ್ಧಿವಂತಿಕೆಗಾಗಿ ಆಳವಾದ ಪ್ರೀತಿಯನ್ನು ನೀಡುತ್ತದೆ.";
"yoga_formation_satkathadisravana_yoga" = "3ನೇ ಮನೆಯು ಲಾಭದಾಯಕರಿಂದ, 3ನೇ ಅಧಿಪತಿಯು ಲಾಭದಾಯಕ ನವಾಂಶದಲ್ಲಿ ನೈಸರ್ಗಿಕ ಲಾಭದಾಯಕ ಅಂಶಗಳೊಂದಿಗೆ.";

// [+] Satrumooladhana Yoga
"yoga_name_satrumooladhana_yoga" = "ಶತ್ರುಮೂಲಾಧನ ಯೋಗ";
"yoga_outcome_satrumooladhana_yoga" = "ಸ್ಪರ್ಧೆ, ಕಾನೂನು ವಿಜಯಗಳು ಅಥವಾ ಸೇವಾ ಆದಾಯವನ್ನು ಸೋಲಿಸುವ ಮೂಲಕ ಸಂಪತ್ತು.";
"yoga_formation_satrumooladhana_yoga" = "6 ನೇ ಅಧಿಪತಿ 2 ನೇ ಮತ್ತು 11 ನೇ ಮನೆಗಳಿಗೆ ಸಂಪರ್ಕ ಹೊಂದಿದ್ದಾನೆ.";

// [−] Sirachcheda Yoga
"yoga_name_sirachcheda_yoga" = "ಸಿರಚ್ಛೇದ ಯೋಗ";
"yoga_outcome_sirachcheda_yoga" = "ತಲೆ ಗಾಯಗಳು ಅಥವಾ ತೀವ್ರ ಆಘಾತದ ಅಪಾಯ; ರಕ್ಷಣಾತ್ಮಕ ಕ್ರಮಗಳು ಮತ್ತು ಎಚ್ಚರಿಕೆಯನ್ನು ಸೂಚಿಸಲಾಗಿದೆ.";
"yoga_formation_sirachcheda_yoga" = "ಮಂಗಳ ಮತ್ತು ಕೇತು ಲಗ್ನವನ್ನು ಯಾವುದೇ ಪ್ರಯೋಜನಕಾರಿ ರಕ್ಷಣೆಯಿಲ್ಲದೆ ಬಾಧಿಸುತ್ತಿದೆ.";

// [−] Sisnavyadhi Yoga
"yoga_name_sisnavyadhi_yoga" = "ಸಿಸ್ನವ್ಯಾಧಿ ಯೋಗ";
"yoga_outcome_sisnavyadhi_yoga" = "ಜನನಾಂಗ ಅಥವಾ ಸಂತಾನೋತ್ಪತ್ತಿ ಆರೋಗ್ಯ ಅಸ್ವಸ್ಥತೆಗಳು; ವಿಶೇಷ ವೈದ್ಯಕೀಯ ಆರೈಕೆ ಸಲಹೆ.";
"yoga_formation_sisnavyadhi_yoga" = "ಶುಕ್ರ ಮತ್ತು 7ನೇ ಅಧಿಪತಿಗಳು 8ನೇ ಮನೆಯಲ್ಲಿ ದುಷ್ಕರ್ಮಿಗಳಿಂದ ಪೀಡಿತರಾಗಿದ್ದಾರೆ.";

// [+] Siva Yoga
"yoga_name_siva_yoga" = "ಶಿವಯೋಗ";
"yoga_outcome_siva_yoga" = "ಶಿವನ ಆಶೀರ್ವಾದ; ಆಳವಾದ ಧ್ಯಾನ ಸಾಮರ್ಥ್ಯಗಳು, ತಪಸ್ವಿ ಬುದ್ಧಿವಂತಿಕೆ ಮತ್ತು ಪರಿವರ್ತಕ ಆಧ್ಯಾತ್ಮಿಕ ಶಕ್ತಿ.";
"yoga_formation_siva_yoga" = "9ರಲ್ಲಿ 5ನೇ ಅಧಿಪತಿ, 10ರಲ್ಲಿ 9ನೇ ಅಧಿಪತಿ, 5ರಲ್ಲಿ 10ನೇ ಅಧಿಪತಿ.";

