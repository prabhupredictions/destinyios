"yoga_formation_bahuputra_yoga_220" = "ಗುರುವಿನ ಅಂಶದೊಂದಿಗೆ ಕೇಂದ್ರ/ತ್ರಿಕೋನದಲ್ಲಿ 5ನೇ ಅಧಿಪತಿ ಬಲಶಾಲಿ (ವರ್. 1).";

// [+] Bahuputra Yoga (221)
"yoga_name_bahuputra_yoga_221" = "ಬಹುಪುತ್ರ ಯೋಗ (221)";
"yoga_outcome_bahuputra_yoga_221" = "ಉತ್ತಮ ಆರೋಗ್ಯ ಮತ್ತು ಪಾತ್ರದೊಂದಿಗೆ ಬಹು ಸಂತತಿ; ಕುಟುಂಬ ಬೆಳೆಯುತ್ತದೆ.";
"yoga_formation_bahuputra_yoga_221" = "ಗುರು ಮತ್ತು 5 ನೇ ಅಧಿಪತಿಗಳು ಲಾಭದಾಯಕ ಸಂಪರ್ಕಗಳೊಂದಿಗೆ ಪರಸ್ಪರ ಬೆಂಬಲದಲ್ಲಿದ್ದಾರೆ (ವರ್. 2).";

// [+] Balya Dhana Yoga
"yoga_name_balya_dhana_yoga" = "ಬಲ್ಯ ಧನ ಯೋಗ";
