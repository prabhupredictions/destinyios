// [+] Bhaga Chumbana Yoga
"yoga_name_bhaga_chumbana_yoga" = "ಭಗ ಚುಂಬನ ಯೋಗ";
"yoga_outcome_bhaga_chumbana_yoga" = "ಉತ್ತುಂಗಕ್ಕೇರಿದ ದೈಹಿಕ ಕಾಂತೀಯತೆ ಮತ್ತು ನಿಕಟ ನೆರವೇರಿಕೆಯೊಂದಿಗೆ ತೀವ್ರವಾದ, ಭಾವೋದ್ರಿಕ್ತ ಪ್ರಣಯ ಜೀವನ.";
