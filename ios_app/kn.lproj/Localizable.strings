// [−] Guhyaroga Yoga
"yoga_name_guhyaroga_yoga" = "ಗುಹ್ಯರೋಗ ಯೋಗ";
"yoga_outcome_guhyaroga_yoga" = "ನಿಕಟ ಜೀವನದ ಮೇಲೆ ಪರಿಣಾಮ ಬೀರುವ ಖಾಸಗಿ ಆರೋಗ್ಯ ಸಮಸ್ಯೆಗಳಿಗೆ ಒಳಗಾಗುವಿಕೆ; ತಡೆಗಟ್ಟುವ ಆರೈಕೆಯನ್ನು ಸೂಚಿಸಲಾಗುತ್ತದೆ.";
"yoga_formation_guhyaroga_yoga" = "ಶುಕ್ರ, 7 ಮತ್ತು 8 ನೇ ಮನೆಗಳಿಗೆ ದುಷ್ಟ ಬಾಧೆ.";

// [+] Hamsa Yoga
"yoga_name_hamsa_yoga" = "ಹಂಸ ಯೋಗ";
"yoga_outcome_hamsa_yoga" = "ಅಸಾಧಾರಣ ಬುದ್ಧಿವಂತಿಕೆ, ನೈತಿಕ ಸಮಗ್ರತೆ, ಆಧ್ಯಾತ್ಮಿಕ ಒಲವು ಮತ್ತು ಸಮಾಜದಲ್ಲಿ ಗೌರವಾನ್ವಿತ ಸ್ಥಾನವನ್ನು ನೀಡುತ್ತದೆ.";
"yoga_formation_hamsa_yoga" = "ಕೇಂದ್ರದಲ್ಲಿ ಗುರು (1/4/7/10) ಸ್ವಂತ ರಾಶಿಯಲ್ಲಿ (ಧನು/ಮೀನ) ಅಥವಾ ಉತ್ಕೃಷ್ಟತೆ (ಕರ್ಕಾಟಕ).";

// [+] Harihara Brahma Yoga
"yoga_name_harihara_brahma_yoga" = "ಹರಿಹರ ಬ್ರಹ್ಮ ಯೋಗ";
"yoga_outcome_harihara_brahma_yoga" = "ಹೋಲಿ ಟ್ರಿನಿಟಿಯ ಸರ್ವೋಚ್ಚ ದೈವಿಕ ಆಶೀರ್ವಾದ; ಅಸಾಧಾರಣ ಆಧ್ಯಾತ್ಮಿಕ ಅಧಿಕಾರ ಮತ್ತು ಕಾಸ್ಮಿಕ್ ಸಂಪರ್ಕ.";
"yoga_formation_harihara_brahma_yoga" = "2ನೇ ಮತ್ತು 12ನೇ ಅಧಿಪತಿಗಳಿಂದ ಅಥವಾ 7ನೇ/ಲಗ್ನಾಧಿಪತಿಗಳಿಂದ ನಿರ್ದಿಷ್ಟ ಮನೆಗಳಲ್ಲಿ ಲಾಭಗಳು.";

// [+] Harsha Yoga
"yoga_name_harsha_yoga" = "ಹರ್ಷ ಯೋಗ";
"yoga_outcome_harsha_yoga" = "ಪ್ರತಿಕೂಲತೆಯನ್ನು ಪ್ರಯೋಜನವಾಗಿ ಪರಿವರ್ತಿಸುತ್ತದೆ; ಶತ್ರುಗಳನ್ನು ಜಯಿಸಿ ಬಲಶಾಲಿಯಾಗುತ್ತಾನೆ.";
"yoga_formation_harsha_yoga" = "6ನೇ, 8ನೇ, ಅಥವಾ 12ನೇ ಮನೆಯಲ್ಲಿ 6ನೇ ಅಧಿಪತಿ (ದುಸ್ಥಾನದಲ್ಲಿ ದುಸ್ಥಾನ).";

// [+] Indra Yoga
"yoga_name_indra_yoga" = "ಇಂದ್ರ ಯೋಗ";
"yoga_outcome_indra_yoga" = "ಇಂದ್ರನಂತಹ ಶಕ್ತಿ; ಸೈನ್ಯಗಳು, ಸಂಸ್ಥೆಗಳು ಅಥವಾ ದೊಡ್ಡ ಉದ್ಯಮಗಳಿಗೆ ಆದೇಶ ನೀಡುತ್ತದೆ.";
"yoga_formation_indra_yoga" = "5 ಮತ್ತು 11 ನೇ ಅಧಿಪತಿಗಳು ಪರಸ್ಪರ ಕೇಂದ್ರಗಳಲ್ಲಿ ಶುಭ ಮಂಗಳನೊಂದಿಗೆ.";

// [−] Jada Yoga
"yoga_name_jada_yoga" = "ಜಡ ಯೋಗ";
"yoga_outcome_jada_yoga" = "ಮಾನಸಿಕ ಆಲಸ್ಯ, ಮಂದತೆ ಅಥವಾ ಖಿನ್ನತೆಯ ಪ್ರವೃತ್ತಿಗಳು; ಸಕ್ರಿಯ ಜೀವನಶೈಲಿ ಮತ್ತು ಪ್ರಚೋದನೆ ಸಹಾಯ.";
"yoga_formation_jada_yoga" = "ಯಾವುದೇ ಪ್ರಯೋಜನಕಾರಿ ಪ್ರಭಾವವಿಲ್ಲದ ಶನಿಯಿಂದ ಚಂದ್ರನ ದೃಷ್ಟಿ.";

// [−] Jananatpurvam Pitru Marana Yoga
"yoga_name_jananatpurvam_pitru_marana_yoga" = "ಜನನತಪೂರ್ವಂ ಪಿತೃ ಮರಣ ಯೋಗ";
"yoga_outcome_jananatpurvam_pitru_marana_yoga" = "ತಂದೆಯ ಪ್ರಭಾವದ ಆರಂಭಿಕ ನಷ್ಟ; ಚಿಕ್ಕ ವಯಸ್ಸಿನಿಂದಲೇ ವ್ಯಕ್ತಿಯು ಸ್ವಾವಲಂಬನೆಯನ್ನು ಬೆಳೆಸಿಕೊಳ್ಳಬೇಕು.";
"yoga_formation_jananatpurvam_pitru_marana_yoga" = "ಆರಂಭಿಕ ತಂದೆಯ ನಷ್ಟವನ್ನು ಸೂಚಿಸುವ ನಿರ್ದಿಷ್ಟ ಸೂರ್ಯನ ಬಾಧೆಗಳು.";

// [−] Jara Yoga
"yoga_name_jara_yoga" = "ಜರ ಯೋಗ";
"yoga_outcome_jara_yoga" = "ಅಕಾಲಿಕ ವೃದ್ಧಾಪ್ಯ, ವೃದ್ಧಾಪ್ಯದ ಕಷ್ಟಗಳು ಅಥವಾ ನಂತರದ ವರ್ಷಗಳಲ್ಲಿ ಚೈತನ್ಯದ ಕುಸಿತ.";
"yoga_formation_jara_yoga" = "ಲಗ್ನಾಧಿಪತಿ ಮತ್ತು 7ನೇ ಅಧಿಪತಿ ಶನಿಯ ಪ್ರಭಾವದಿಂದ ಪೀಡಿತರಾಗಿದ್ದಾರೆ.";

// [−] Jarajaputra Yoga
"yoga_name_jarajaputra_yoga" = "ಜರಾಜಪುತ್ರ ಯೋಗ";
"yoga_outcome_jarajaputra_yoga" = "ಜೀವನದಲ್ಲಿ ಬಹಳ ತಡವಾಗಿ ಜನಿಸಿದ ಮಕ್ಕಳು; ಸಂಯೋಜಿತ ಸವಾಲುಗಳೊಂದಿಗೆ ವಿಳಂಬಿತ ಪಿತೃತ್ವ.";
"yoga_formation_jarajaputra_yoga" = "5 ನೇ ಅಧಿಪತಿ ಶನಿಗೆ ತಡವಾಗಿ ಸಕ್ರಿಯಗೊಳಿಸುವ ದಶಾದೊಂದಿಗೆ ಸಂಪರ್ಕ ಹೊಂದಿದ್ದಾನೆ.";

// [+] Jaya Yoga
"yoga_name_jaya_yoga" = "ಜಯ ಯೋಗ";
"yoga_outcome_jaya_yoga" = "ಸ್ಪರ್ಧಿಗಳ ಮೇಲೆ ವಿಜಯ; ಸ್ಪರ್ಧಾತ್ಮಕ ಮತ್ತು ಕಾನೂನು ವಿಷಯಗಳಲ್ಲಿ ವಿಜಯಗಳು.";
"yoga_formation_jaya_yoga" = "6ನೇ ಅಧಿಪತಿ ದುರ್ಬಲ, ಲಗ್ನಾಧಿಪತಿ ಬಲಿಷ್ಠ.";

// [+] Kahala Yoga
"yoga_name_kahala_yoga" = "ಕಹಲ ಯೋಗ";
"yoga_outcome_kahala_yoga" = "ಸಂಪೂರ್ಣ ಇಚ್ಛಾಶಕ್ತಿಯ ಮೂಲಕ ದಿಟ್ಟ ನಿರ್ಣಯ ಮತ್ತು ಅಧಿಕಾರ.";
"yoga_formation_kahala_yoga" = "4 ನೇ ಅಧಿಪತಿ ಮತ್ತು ಗುರು ಪರಸ್ಪರ ಕೇಂದ್ರಗಳಲ್ಲಿ, ಲಗ್ನಾಧಿಪತಿ ಬಲಶಾಲಿ.";

// [+] Kalanidhi Yoga
"yoga_name_kalanidhi_yoga" = "ಕಲಾನಿಧಿ ಯೋಗ";
"yoga_outcome_kalanidhi_yoga" = "ಕಲೆ ಮತ್ತು ಕಲಿಕೆಯ ನಿಧಿ; ಲಲಿತಕಲೆಗಳು, ಸಂಗೀತ ಮತ್ತು ಸಾಂಸ್ಕೃತಿಕ ಸಾಧನೆಗಳಲ್ಲಿ ಪಾಂಡಿತ್ಯ.";
"yoga_formation_kalanidhi_yoga" = "ಗುರು 2ನೇ ಅಥವಾ 5ನೇ ಮಗ್ಗುಲಲ್ಲಿ ಬುಧ ಮತ್ತು ಶುಕ್ರ.";

// [+] Kalanirdesat Putra Yoga (227)
"yoga_name_kalanirdesat_putra_yoga_227" = "ಕಲನಿರ್ದೇಸತ್ ಪುತ್ರ ಯೋಗ (227)";
"yoga_outcome_kalanirdesat_putra_yoga_227" = "ಮಕ್ಕಳು ನಿರ್ದಿಷ್ಟ, ಜ್ಯೋತಿಷ್ಯಶಾಸ್ತ್ರದ ಅನುಕೂಲಕರ ಅವಧಿಯನ್ನು ತಲುಪುತ್ತಾರೆ.";
"yoga_formation_kalanirdesat_putra_yoga_227" = "5 ನೇ ಅಧಿಪತಿಯನ್ನು ನಿರ್ದಿಷ್ಟ ದಶಾ ಸಮಯದಲ್ಲಿ ಸಕ್ರಿಯಗೊಳಿಸಲಾಗಿದೆ (ವರ್. 1).";

// [+] Kalanirdesat Putra Yoga (228)
"yoga_name_kalanirdesat_putra_yoga_228" = "ಕಲಾನಿರ್ದೇಸತ್ ಪುತ್ರ ಯೋಗ (228)";
"yoga_outcome_kalanirdesat_putra_yoga_228" = "ಹೆರಿಗೆಯ ಸಮಯವು ಗ್ರಹಗಳ ಅವಧಿಗೆ ಸಂಬಂಧಿಸಿದೆ; ಅನುಕೂಲಕರ ದಶಾಗಳ ಸಮಯದಲ್ಲಿ ಮಕ್ಕಳು.";
"yoga_formation_kalanirdesat_putra_yoga_228" = "5 ನೇ ಅಧಿಪತಿಯನ್ನು ನಿರ್ದಿಷ್ಟ ದಶಾ ಸಮಯದಲ್ಲಿ ಸಕ್ರಿಯಗೊಳಿಸಲಾಗಿದೆ (ವರ್. 2).";

// [−] Kalanirdesat Putranasa Yoga (229)
"yoga_name_kalanirdesat_putranasa_yoga_229" = "ಕಲನಿರ್ದೇಸತ್ ಪುತ್ರನಾಶ ಯೋಗ (229)";
"yoga_outcome_kalanirdesat_putranasa_yoga_229" = "ನಿರ್ದಿಷ್ಟ ಪ್ರತಿಕೂಲ ಗ್ರಹಗಳ ಅವಧಿಯಲ್ಲಿ ಮಗುವಿನ ನಷ್ಟ.";
"yoga_formation_kalanirdesat_putranasa_yoga_229" = "5 ನೇ ಅಧಿಪತಿ ನಿರ್ದಿಷ್ಟ ದುಷ್ಕೃತ್ಯದ ದಶಾ (ವರ್. 1) ಸಮಯದಲ್ಲಿ ಪೀಡಿತ.";

// [−] Kalanirdesat Putranasa Yoga (230)
"yoga_name_kalanirdesat_putranasa_yoga_230" = "ಕಲನಿರ್ದೇಸತ್ ಪುತ್ರನಾಶ ಯೋಗ (230)";
"yoga_outcome_kalanirdesat_putranasa_yoga_230" = "ಮಕ್ಕಳ ಸಂಬಂಧಿತ ದುಃಖವು ದೋಷಪೂರಿತ ಗ್ರಹಗಳ ಅವಧಿಗಳ ಸಮಯಕ್ಕೆ ಸಂಬಂಧಿಸಿದೆ.";
"yoga_formation_kalanirdesat_putranasa_yoga_230" = "5 ನೇ ಅಧಿಪತಿ ನಿರ್ದಿಷ್ಟ ದುಷ್ಕೃತ್ಯದ ದಶಾ (ವರ್. 2) ಸಮಯದಲ್ಲಿ ಪೀಡಿತ.";

// [+] Kalatramooladhana Yoga
"yoga_name_kalatramooladhana_yoga" = "ಕಲತ್ರಮೂಲಾಧನ ಯೋಗ";
"yoga_outcome_kalatramooladhana_yoga" = "ಮದುವೆ, ವ್ಯಾಪಾರ ಪಾಲುದಾರಿಕೆ ಅಥವಾ ಸಂಗಾತಿಯ ಗಳಿಕೆಯ ಮೂಲಕ ಸಂಪತ್ತು.";
"yoga_formation_kalatramooladhana_yoga" = "7 ನೇ ಅಧಿಪತಿ 2 ನೇ ಮತ್ತು 11 ನೇ ಮನೆಗಳಿಗೆ ಸಂಪರ್ಕ ಹೊಂದಿದ್ದಾನೆ.";

// [−] Kalatrashanda Yoga
"yoga_name_kalatrashanda_yoga" = "ಕಲತ್ರಷಂಡ ಯೋಗ";
"yoga_outcome_kalatrashanda_yoga" = "ಲೈಂಗಿಕ ಅಪಸಾಮಾನ್ಯ ಕ್ರಿಯೆ ಅಥವಾ ಸಂತಾನೋತ್ಪತ್ತಿ ಸವಾಲುಗಳು; ವೈದ್ಯಕೀಯ ಸಮಾಲೋಚನೆಯನ್ನು ಶಿಫಾರಸು ಮಾಡಲಾಗಿದೆ.";
"yoga_formation_kalatrashanda_yoga" = "ಶುಕ್ರನು ಕ್ಷುದ್ರಾವಸ್ಥೆಯಲ್ಲಿ 7ನೇ ಅಧಿಪತಿಯೊಂದಿಗೆ ತೀವ್ರವಾಗಿ ಬಾಧಿತನಾದ.";

// [−] Kapata Yoga (202)
"yoga_name_kapata_yoga_202" = "ಕಪಟ ಯೋಗ (202)";
"yoga_outcome_kapata_yoga_202" = "ಕುತಂತ್ರದ ನಡವಳಿಕೆಯ ಕಡೆಗೆ ಒಲವನ್ನು ಸೂಚಿಸುತ್ತದೆ; ಪಾರದರ್ಶಕತೆ ಬೆಳೆಸಲು ಸೂಚಿಸಲಾಗಿದೆ.";
"yoga_formation_kapata_yoga_202" = "ಮೋಸಗೊಳಿಸುವ ಪ್ರವೃತ್ತಿಯನ್ನು ಸೂಚಿಸುವ ನಿರ್ದಿಷ್ಟ ದೋಷಪೂರಿತ ಸಂಯೋಜನೆಗಳು (var. 1).";

// [−] Kapata Yoga (203)
"yoga_name_kapata_yoga_203" = "ಕಪಟ ಯೋಗ (203)";
"yoga_outcome_kapata_yoga_203" = "ಕುಶಲ ವರ್ತನೆಯ ಸಂಭಾವ್ಯತೆಯನ್ನು ಸೂಚಿಸುತ್ತದೆ; ನೈತಿಕ ಶಿಸ್ತು ಇದನ್ನು ತಗ್ಗಿಸಬಹುದು.";
"yoga_formation_kapata_yoga_203" = "ಮೋಸಗೊಳಿಸುವ ಪ್ರವೃತ್ತಿಯನ್ನು ಸೂಚಿಸುವ ನಿರ್ದಿಷ್ಟ ದೋಷಪೂರಿತ ಸಂಯೋಜನೆಗಳು (var. 2).";

// [−] Kapata Yoga (204)
"yoga_name_kapata_yoga_204" = "ಕಪಟ ಯೋಗ (204)";
"yoga_outcome_kapata_yoga_204" = "ದ್ವಂದ್ವತೆಯ ಪ್ರವೃತ್ತಿಯನ್ನು ಸೂಚಿಸುತ್ತದೆ; ಸಮಗ್ರತೆ ಅಭ್ಯಾಸಗಳು ಮತ್ತು ಸ್ವಯಂ ಅರಿವು ಶಿಫಾರಸು.";
"yoga_formation_kapata_yoga_204" = "ಮೋಸಗೊಳಿಸುವ ಪ್ರವೃತ್ತಿಯನ್ನು ಸೂಚಿಸುವ ನಿರ್ದಿಷ್ಟ ದೋಷಪೂರಿತ ಸಂಯೋಜನೆಗಳು (var. 3).";

// [−] Karascheda Yoga
"yoga_name_karascheda_yoga" = "ಕರಶ್ಚೇದ ಯೋಗ";
"yoga_outcome_karascheda_yoga" = "ಕೈ / ತೋಳಿನ ಗಾಯಗಳು ಅಥವಾ ಅಂಗಗಳನ್ನು ಒಳಗೊಂಡ ಶಸ್ತ್ರಚಿಕಿತ್ಸಾ ವಿಧಾನಗಳ ಅಪಾಯ.";
"yoga_formation_karascheda_yoga" = "ಮಂಗಳ ಮತ್ತು ಶನಿ 3ನೇ ಮನೆ ಮತ್ತು ಲಗ್ನವನ್ನು ತೀವ್ರವಾಗಿ ಬಾಧಿಸುತ್ತವೆ.";

// [−] Kemadruma Yoga
"yoga_name_kemadruma_yoga" = "ಕೇಮದ್ರುಮ ಯೋಗ";
"yoga_outcome_kemadruma_yoga" = "ಅಂತರ್ಗತ ಸಾಮರ್ಥ್ಯಗಳ ಹೊರತಾಗಿಯೂ ಭಾವನಾತ್ಮಕ ಒಂಟಿತನ, ಆರ್ಥಿಕ ಏರಿಳಿತಗಳು ಮತ್ತು ಹೋರಾಟಗಳನ್ನು ಸೂಚಿಸುತ್ತದೆ.";
"yoga_formation_kemadruma_yoga" = "ಚಂದ್ರನಿಂದ 2 ಅಥವಾ 12 ರಲ್ಲಿ ಯಾವುದೇ ಗ್ರಹಗಳಿಲ್ಲ (ಚಂದ್ರನನ್ನು ಪ್ರತ್ಯೇಕಿಸಲಾಗಿದೆ).";

// [−] Khalawata Yoga
"yoga_name_khalawata_yoga" = "ಖಲಾವತ ಯೋಗ";
"yoga_outcome_khalawata_yoga" = "ಕಠಿಣ ಅಥವಾ ಅಸಂಸ್ಕೃತ ವರ್ತನೆಯನ್ನು ಸೂಚಿಸುತ್ತದೆ; ಸಾಮಾಜಿಕ ಸಂವಹನಗಳಲ್ಲಿ ಪರಿಷ್ಕರಣೆ ಅಗತ್ಯವಿದೆ.";
"yoga_formation_khalawata_yoga" = "ಲಗ್ನ ಅಧಿಪತಿ ಶನಿಯ ಅಂಶ ಅಥವಾ ಸಂಯೋಗದೊಂದಿಗೆ ಕ್ರಿಯಾತ್ಮಕವಾಗಿ ದೋಷಪೂರಿತ.";

// [−] Krisanga Yoga
