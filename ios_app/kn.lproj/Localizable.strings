// [−] Matrunasa Yoga (198)
"yoga_name_matrunasa_yoga_198" = "ಮಾತೃನಾಸ ಯೋಗ (198)";
"yoga_outcome_matrunasa_yoga_198" = "ತಾಯಿಯ ಆರಂಭಿಕ ನಷ್ಟ ಅಥವಾ ತೀವ್ರ ತಾಯಿಯ ಆರೋಗ್ಯ ಬಿಕ್ಕಟ್ಟು.";
"yoga_formation_matrunasa_yoga_198" = "4 ನೇ ಅಧಿಪತಿ ಮತ್ತು ಚಂದ್ರನು ದುಷ್ಕೃತ್ಯಗಳಿಂದ ತೀವ್ರವಾಗಿ ಪೀಡಿತರಾಗಿದ್ದಾರೆ (ವರ್. 1).";

// [−] Matrunasa Yoga (199)
"yoga_name_matrunasa_yoga_199" = "ಮಾತೃನಾಸ ಯೋಗ (199)";
"yoga_outcome_matrunasa_yoga_199" = "ತಾಯಿಯು ಜೀವಕ್ಕೆ-ಬೆದರಿಕೆಯ ಸಂದರ್ಭಗಳನ್ನು ಎದುರಿಸುತ್ತಾಳೆ; ತಾಯಿಯ ಕಲ್ಯಾಣ ಅಪಾಯದಲ್ಲಿದೆ.";
"yoga_formation_matrunasa_yoga_199" = "ಮಂಗಳ ಮತ್ತು ಶನಿ 4 ನೇ ಮನೆ ಮತ್ತು ಚಂದ್ರನನ್ನು ಬಾಧಿಸುತ್ತದೆ (ವರ್. 2).";

// [−] Matrusapa Sutakshaya Yoga
"yoga_name_matrusapa_sutakshaya_yoga" = "ಮಾತೃಸಪ ಸುತಕ್ಷಯ ಯೋಗ";
"yoga_outcome_matrusapa_sutakshaya_yoga" = "ಸಂತತಿಯ ಮೇಲೆ ಪರಿಣಾಮ ಬೀರುವ ತಾಯಿಯ ಶಾಪ; ಪರಿಹರಿಸಲಾಗದ ತಾಯಿಯ ಕರ್ಮವು ಮಕ್ಕಳ ಮೇಲೆ ಪರಿಣಾಮ ಬೀರುತ್ತದೆ.";
"yoga_formation_matrusapa_sutakshaya_yoga" = "ದೋಷಪೂರಿತ ಸಂಯೋಜನೆಯಲ್ಲಿ 5 ನೇ ಅಧಿಪತಿಯೊಂದಿಗೆ ಚಂದ್ರ ಪೀಡಿತ.";

// [+] Matsya Yoga
"yoga_name_matsya_yoga" = "ಮತ್ಸ್ಯ ಯೋಗ";
"yoga_outcome_matsya_yoga" = "ಆಳವಾದ, ಸಾಗರದಂತಹ ಬುದ್ಧಿವಂತಿಕೆ ಮತ್ತು ಆಧ್ಯಾತ್ಮಿಕ ಜ್ಞಾನ; ಕಲಿತ, ಸಹಾನುಭೂತಿ, ವ್ಯಾಪಕವಾಗಿ ಪ್ರಯಾಣಿಸಿದ.";
"yoga_formation_matsya_yoga" = "ಲಗ್ನ/9ರಲ್ಲಿ ದೋಷಗಳು, 5ರಲ್ಲಿ ಲಾಭಿಗಳು, 4ನೇ/8ರಲ್ಲಿ ಮಿಶ್ರಣ.";

// [−] Mooka Yoga
"yoga_name_mooka_yoga" = "ಮುಕ ಯೋಗ";
"yoga_outcome_mooka_yoga" = "ಮಾತಿನ ಅಡಚಣೆಗಳು ಅಥವಾ ಸಂವಹನ ತೊಂದರೆಗಳು; ಚಿಕಿತ್ಸೆ ಮತ್ತು ಪರಿಹಾರಗಳು ಸಹಾಯ ಮಾಡಬಹುದು.";
"yoga_formation_mooka_yoga" = "ಬುಧವು ತೀವ್ರವಾಗಿ ಬಾಧಿತವಾಗಿದೆ, 2ನೇ ಅಧಿಪತಿಯು ದುಷ್ಕೃತ್ಯಗಳಿಂದ ದುರ್ಬಲಗೊಂಡಿದ್ದಾನೆ.";

// [+] Mridanga Yoga
"yoga_name_mridanga_yoga" = "ಮೃದಂಗ ಯೋಗ";
"yoga_outcome_mridanga_yoga" = "ವಿಧ್ಯುಕ್ತವಾದ ಡ್ರಮ್‌ನಂತೆ ಸುಪ್ರೀಂ ರಾಯಲ್ ಸ್ಥಾನಮಾನ; ಖ್ಯಾತಿಯು ಭೂಮಿಯಾದ್ಯಂತ ಪ್ರತಿಧ್ವನಿಸುತ್ತದೆ.";
"yoga_formation_mridanga_yoga" = "ಲಗ್ನಾಧಿಪತಿ ಬಲಶಾಲಿ, ಕೇಂದ್ರ/ತ್ರಿಕೋನಗಳಲ್ಲಿ ಎಲ್ಲಾ ಗ್ರಹಗಳು.";

// [+] Ardha Chandra Yoga
"yoga_name_nabhasa_ardha_chandra" = "ಅರ್ಧ ಚಂದ್ರ ಯೋಗ";
"yoga_outcome_nabhasa_ardha_chandra" = "ಅರ್ಧ ಚಂದ್ರನ ರಚನೆ; ಸೈನ್ಯದ ಕಮಾಂಡರ್, ದೈಹಿಕವಾಗಿ ಬಲಶಾಲಿ, ಆಕರ್ಷಕ ಮತ್ತು ಶ್ರೀಮಂತ.";
"yoga_formation_nabhasa_ardha_chandra" = "ಒಂದು ಕೇಂದ್ರದಿಂದ ಸತತ ಏಳು ಮನೆಗಳಲ್ಲಿ ಎಲ್ಲಾ ಗ್ರಹಗಳು.";

// [+] Chandra Yoga (Nabhasa)
"yoga_name_nabhasa_chandra" = "ಚಂದ್ರ ಯೋಗ (ನಭಸ)";
"yoga_outcome_nabhasa_chandra" = "ಚಂದ್ರನ ರಚನೆ; ಆಹ್ಲಾದಕರ ನೋಟ, ಕಮಾಂಡಿಂಗ್ ನಿಲುವು, ರಾಜ ಸಲಹೆಗಾರರು.";
"yoga_formation_nabhasa_chandra" = "ರಾಶಿಚಕ್ರದ ಮೇಲಿನ ಅರ್ಧದಲ್ಲಿರುವ ಎಲ್ಲಾ ಗ್ರಹಗಳು (7ನೇ-12ನೇ ಮನೆಗಳು).";

// [+] Chapa Yoga (Nabhasa)
"yoga_name_nabhasa_chapa" = "ಚಾಪ ಯೋಗ (ನಭಾಸ)";
"yoga_outcome_nabhasa_chapa" = "ಬಿಲ್ಲು ರಚನೆ; ಸತ್ಯವಂತ, ಗಾರ್ಡ್ ನಿಧಿ, ಆರಂಭಿಕ ಮತ್ತು ಕೊನೆಯಲ್ಲಿ ಜೀವನದಲ್ಲಿ ಸಂತೋಷ.";
"yoga_formation_nabhasa_chapa" = "10-4 ಮನೆಗಳಲ್ಲಿನ ಎಲ್ಲಾ ಗ್ರಹಗಳು (10 ರಿಂದ 4 ನೇ ಅವಧಿ).";

// [+] Chhatra Yoga
"yoga_name_nabhasa_chhatra" = "ಛತ್ರ ಯೋಗ";
"yoga_outcome_nabhasa_chhatra" = "ಛತ್ರಿ ರಚನೆ; ಇತರರ ರಕ್ಷಕ, ಎಲ್ಲರಿಗೂ ಸಹಾಯಕ, ಆರಾಮದಾಯಕ ವೃದ್ಧಾಪ್ಯ.";
"yoga_formation_nabhasa_chhatra" = "7-1 ಮನೆಗಳಲ್ಲಿನ ಎಲ್ಲಾ ಗ್ರಹಗಳು (7 ರಿಂದ 1 ನೇ ಅವಧಿ).";

// [+] Damini Yoga
"yoga_name_nabhasa_damini" = "ದಾಮಿನಿ ಯೋಗ";
"yoga_outcome_nabhasa_damini" = "ಮಿಂಚಿನ ರಚನೆ; ಉದಾರ, ಸಹಾಯಕ, ಶ್ರೀಮಂತ ಮತ್ತು ಪರೋಪಕಾರಿ ಸ್ವಭಾವ.";
"yoga_formation_nabhasa_damini" = "ಆರು ಸತತ ಮನೆಗಳಲ್ಲಿ ಎಲ್ಲಾ ಗ್ರಹಗಳು.";

// [+] Danda Yoga
"yoga_name_nabhasa_danda" = "ದಂಡ ಯೋಗ";
"yoga_outcome_nabhasa_danda" = "ಸಿಬ್ಬಂದಿ ರಚನೆ; ಕುಟುಂಬದ ನಷ್ಟ ಅಥವಾ ಪ್ರತ್ಯೇಕತೆ; ಸೇವಾ ಆಧಾರಿತ ಜೀವನ.";
"yoga_formation_nabhasa_danda" = "10 ರಿಂದ ಪ್ರಾರಂಭವಾಗುವ ನಾಲ್ಕು ಸತತ ಮನೆಗಳಲ್ಲಿ ಗ್ರಹಗಳು.";

// [+] Gada Yoga
"yoga_name_nabhasa_gada" = "ಗದಾ ಯೋಗ";
"yoga_outcome_nabhasa_gada" = "ಗದೆಯಂತಹ ಶಕ್ತಿ; ಆಚರಣೆಗಳು, ಧಾರ್ಮಿಕ ಚಟುವಟಿಕೆಗಳು ಅಥವಾ ಸಾಂಪ್ರದಾಯಿಕ ಅನ್ವೇಷಣೆಗಳ ಮೂಲಕ ಸಂಪತ್ತು.";
"yoga_formation_nabhasa_gada" = "ಎರಡು ಸತತ ಕೇಂದ್ರ ಮನೆಗಳಲ್ಲಿ ಗ್ರಹಗಳು.";

// [+] Gola Yoga (Nabhasa)
"yoga_name_nabhasa_gola" = "ಗೋಲ ಯೋಗ (ನಭಾಸ)";
"yoga_outcome_nabhasa_gola" = "ಗೋಳ ರಚನೆ; ಬಡ, ಕೊಳಕು, ಅಜ್ಞಾನ, ಆದರೆ ಬಲವಾದ ಮತ್ತು ಅಲೆದಾಡುವ ಸ್ವಭಾವ.";
"yoga_formation_nabhasa_gola" = "ಎಲ್ಲಾ ಗ್ರಹಗಳು ಒಂದೇ ಮನೆಯಲ್ಲಿ.";

// [+] Hala Yoga
"yoga_name_nabhasa_hala" = "ಹಲ ಯೋಗ";
"yoga_outcome_nabhasa_hala" = "ಕೃಷಿ ಸಮೃದ್ಧಿ; ಮಧ್ಯಮ ವರ್ಗದ ಸೌಕರ್ಯಗಳೊಂದಿಗೆ ಕಷ್ಟಪಟ್ಟು ದುಡಿಯುವ ಸ್ವಭಾವ.";
"yoga_formation_nabhasa_hala" = "ಕೇಂದ್ರಗಳನ್ನು ಹೊರತುಪಡಿಸಿ ಇತರ ಮನೆಗಳಲ್ಲಿನ ಗ್ರಹಗಳು ನೇಗಿಲಿನ ಆಕಾರವನ್ನು ರೂಪಿಸುತ್ತವೆ.";

// [+] Ishu Yoga
"yoga_name_nabhasa_ishu" = "ಈಶು ಯೋಗ";
"yoga_outcome_nabhasa_ishu" = "ಬಾಣದ ರಚನೆ; ಮಿಲಿಟರಿ, ಪೊಲೀಸ್ ಅಥವಾ ಜೈಲು ಆಡಳಿತಕ್ಕೆ ಸಂಪರ್ಕ ಹೊಂದಿದೆ.";
"yoga_formation_nabhasa_ishu" = "4ರಿಂದ ಆರಂಭವಾಗಿ ಸತತ ನಾಲ್ಕು ಮನೆಗಳಲ್ಲಿ ಗ್ರಹಗಳು.";

// [+] Kamala Yoga
"yoga_name_nabhasa_kamala" = "ಕಮಲ ಯೋಗ";
"yoga_outcome_nabhasa_kamala" = "ಕಮಲದ ರಚನೆ; ನಿರಂತರ ಖ್ಯಾತಿ, ಸದ್ಗುಣಶೀಲ ಜೀವನ ಮತ್ತು ನೂರು ವರ್ಷಗಳ ಸಮೃದ್ಧಿ.";
"yoga_formation_nabhasa_kamala" = "ನಾಲ್ಕು ಕೇಂದ್ರ ಮನೆಗಳಲ್ಲಿ ಎಲ್ಲಾ ಗ್ರಹಗಳು (1/4/7/10).";

// [+] Kedara Yoga
"yoga_name_nabhasa_kedara" = "ಕೇದಾರ ಯೋಗ";
"yoga_outcome_nabhasa_kedara" = "ಕ್ಷೇತ್ರ ರಚನೆ; ಕೃಷಿ ಸಂಪತ್ತು, ಅನೇಕರಿಗೆ ಸಹಾಯಕಾರಿ, ಸತ್ಯವಂತರು.";
"yoga_formation_nabhasa_kedara" = "ಐದು ಸತತ ಮನೆಗಳಲ್ಲಿ ಎಲ್ಲಾ ಗ್ರಹಗಳು.";

// [+] Kuta Yoga
"yoga_name_nabhasa_kuta" = "ಕೂಟ ಯೋಗ";
"yoga_outcome_nabhasa_kuta" = "ಕೋಟೆ ರಚನೆ; ಸುಳ್ಳುಗಾರ ಅಥವಾ ರಾಜತಾಂತ್ರಿಕ, ಕಾರಾಗೃಹಗಳು ಅಥವಾ ಬಂಧನದ ಪಾತ್ರಗಳಿಗೆ ಸಂಪರ್ಕ ಹೊಂದಿದವರು.";
"yoga_formation_nabhasa_kuta" = "4-10 ಮನೆಗಳಲ್ಲಿ ಎಲ್ಲಾ ಗ್ರಹಗಳು.";

// [+] Mala Yoga
"yoga_name_nabhasa_mala" = "ಮಾಲಾ ಯೋಗ";
"yoga_outcome_nabhasa_mala" = "ಗಾರ್ಲ್ಯಾಂಡ್ ರಚನೆ; ವಾಹನಗಳು, ಆಸ್ತಿ ಮತ್ತು ಶಾಶ್ವತ ಸಂತೋಷದೊಂದಿಗೆ ಆರಾಮದಾಯಕ ಜೀವನ.";
"yoga_formation_nabhasa_mala" = "ಮೂರು ಸತತ ತ್ರಿಕೋನಗಳಲ್ಲಿ ಗ್ರಹಗಳು (1-5-9, 2-6-10, ಅಥವಾ 3-7-11).";

// [+] Musala Yoga
"yoga_name_nabhasa_musala" = "ಮುಸಲ ಯೋಗ";
"yoga_outcome_nabhasa_musala" = "ದೃಢ ಸಂಕಲ್ಪ, ಕೀರ್ತಿ ಮತ್ತು ಸಂಪತ್ತು; ಸ್ಥಿರ, ನಿರ್ಣಯದ ಪಾತ್ರ.";
"yoga_formation_nabhasa_musala" = "ಸ್ಥಿರ ಚಿಹ್ನೆಗಳಲ್ಲಿ ಎಲ್ಲಾ ಗ್ರಹಗಳು (ವೃಷಭ, ಸಿಂಹ, ಸ್ಕಾರ್ಪಿಯೋ, ಅಕ್ವೇರಿಯಸ್).";

// [+] Nala Yoga
"yoga_name_nabhasa_nala" = "ನಳ ಯೋಗ";
"yoga_outcome_nabhasa_nala" = "ಬಹುಮುಖ, ಹಲವು ಕ್ಷೇತ್ರಗಳಲ್ಲಿ ನುರಿತ; ಏರಿಳಿತದ ಅದೃಷ್ಟದೊಂದಿಗೆ ಸುಂದರ ನೋಟ.";
"yoga_formation_nabhasa_nala" = "ಉಭಯ ಚಿಹ್ನೆಗಳಲ್ಲಿ ಎಲ್ಲಾ ಗ್ರಹಗಳು (ಜೆಮಿನಿ, ಕನ್ಯಾರಾಶಿ, ಧನು ರಾಶಿ, ಮೀನ).";

// [+] Nauka Yoga
"yoga_name_nabhasa_nauka" = "ನೌಕ ಯೋಗ";
"yoga_outcome_nabhasa_nauka" = "ದೋಣಿ ರಚನೆ; ಜಲ ಸಂಬಂಧಿ ಅನ್ವೇಷಣೆಗಳ ಮೂಲಕ ಸಂಪತ್ತು, ಸಮುದ್ರಗಳಲ್ಲಿ ಖ್ಯಾತಿ.";
"yoga_formation_nabhasa_nauka" = "1-7 ಮನೆಗಳಲ್ಲಿನ ಎಲ್ಲಾ ಗ್ರಹಗಳು (ರಾಶಿಚಕ್ರದ ಅರ್ಧದಷ್ಟು).";

// [−] Pasa Yoga
"yoga_name_nabhasa_pasa" = "ಪಾಸ ಯೋಗ";
"yoga_outcome_nabhasa_pasa" = "ನೂಸ್ ರಚನೆ; ತೊಂದರೆಗಳಲ್ಲಿ ಸಿಕ್ಕಿಹಾಕಿಕೊಂಡ, ಸೆರೆಮನೆಯಲ್ಲಿ ಅಥವಾ ಸೇವಕ-ತರಹದ ಅಸ್ತಿತ್ವ.";
"yoga_formation_nabhasa_pasa" = "ನಿರ್ದಿಷ್ಟ ಬೌಂಡ್ ಮಾದರಿಗಳಲ್ಲಿ ಮಾತ್ರ ಗ್ರಹಗಳು.";

// [+] Rajju Yoga
"yoga_name_nabhasa_rajju" = "ರಜ್ಜು ಯೋಗ";
"yoga_outcome_nabhasa_rajju" = "ಪ್ರಯಾಣದ ಪ್ರೀತಿ, ಅಲೆದಾಡುವ ಸ್ವಭಾವ; ಚಲನಶೀಲತೆ ಮತ್ತು ಹೊಂದಾಣಿಕೆಯ ಮೂಲಕ ಯಶಸ್ಸು.";
"yoga_formation_nabhasa_rajju" = "ಚಲಿಸಬಲ್ಲ ಚಿಹ್ನೆಗಳಲ್ಲಿ ಎಲ್ಲಾ ಗ್ರಹಗಳು (ಮೇಷ, ಕರ್ಕ, ತುಲಾ, ಮಕರ ಸಂಕ್ರಾಂತಿ).";

// [+] Samudra Yoga
"yoga_name_nabhasa_samudra" = "ಸಮುದ್ರ ಯೋಗ";
"yoga_outcome_nabhasa_samudra" = "ಸಾಗರ ರಚನೆ; ಶ್ರೀಮಂತ, ಅನೇಕ ಸಂತೋಷಗಳು, ಭೋಗದಲ್ಲಿ ರಾಜನಿಗೆ ಸಮಾನ.";
"yoga_formation_nabhasa_samudra" = "ಗ್ರಹಗಳನ್ನು ಎಲ್ಲಾ ಕೇಂದ್ರ ಗುಂಪುಗಳಲ್ಲಿ ಸಮವಾಗಿ ವಿತರಿಸಲಾಗಿದೆ.";

// [−] Sarpa Yoga
"yoga_name_nabhasa_sarpa" = "ಸರ್ಪ ಯೋಗ";
"yoga_outcome_nabhasa_sarpa" = "ದುಃಖ, ಬಡತನ ಮತ್ತು ಹಾವಿನಂತಹ ಸಂಕಟ; ಜೀವನೋಪಾಯಕ್ಕಾಗಿ ಇತರರ ಮೇಲೆ ಅವಲಂಬಿತವಾಗಿದೆ.";
"yoga_formation_nabhasa_sarpa" = "ಕಾರ್ಡಿನಲ್ ಮನೆಗಳಲ್ಲಿ ಎಲ್ಲಾ ಗ್ರಹಗಳು (ಲಗ್ನದಿಂದ 4/8/12 ನೇ).";

// [−] Shakata Yoga
"yoga_name_nabhasa_shakata" = "ಶಕಟ ಯೋಗ";
"yoga_outcome_nabhasa_shakata" = "ಬಂಡಿಯಂತಹ ಜೀವನ - ಏರಿಳಿತಗಳು; ಚಕ್ರಗಳಲ್ಲಿ ಬಡತನದ ನಂತರ ಸಂಪತ್ತು.";
"yoga_formation_nabhasa_shakata" = "1 ಮತ್ತು 7 ನೇ ಮನೆಗಳಲ್ಲಿ ಮಾತ್ರ ಗ್ರಹಗಳು.";

// [+] Shakti Yoga
"yoga_name_nabhasa_shakti" = "ಶಕ್ತಿ ಯೋಗ";
"yoga_outcome_nabhasa_shakti" = "ಈಟಿ ರಚನೆ; ಸೋಮಾರಿತನ ಆದರೆ ಪರಿಶ್ರಮದಿಂದ ಸಂಪತ್ತು ಗಳಿಸುತ್ತಾನೆ.";
"yoga_formation_nabhasa_shakti" = "7ರಿಂದ ಆರಂಭವಾಗಿ ಸತತ ನಾಲ್ಕು ಮನೆಗಳಲ್ಲಿ ಗ್ರಹಗತಿಗಳು.";

// [+] Shringataka Yoga
"yoga_name_nabhasa_shringataka" = "ಶೃಂಗಾಟಕ ಯೋಗ";
"yoga_outcome_nabhasa_shringataka" = "ಪೀಕ್ ರಚನೆ; ತೃಪ್ತಿ, ಪರೋಪಕಾರ ಮತ್ತು ಸೌಹಾರ್ದಯುತ ಮನೋಭಾವ.";
"yoga_formation_nabhasa_shringataka" = "ತ್ರಿಕೋನ ಮನೆಗಳಲ್ಲಿನ ಗ್ರಹಗಳು (1 ನೇ, 5 ನೇ, 9 ನೇ).";

// [−] Shula Yoga
"yoga_name_nabhasa_shula" = "ಶೂಲ ಯೋಗ";
"yoga_outcome_nabhasa_shula" = "ಟ್ರೈಡೆಂಟ್ ರಚನೆ; ತೀಕ್ಷ್ಣವಾದ, ಪರಾಕ್ರಮಶಾಲಿ, ಆದರೆ ಕಳಪೆ; ಅನಾರೋಗ್ಯ ಪೀಡಿತ ಮತ್ತು ಮುಖಾಮುಖಿ.";
"yoga_formation_nabhasa_shula" = "ಮೂರು ಸತತ ಮನೆಗಳಲ್ಲಿ ಗ್ರಹಗಳು.";

// [+] Vajra Yoga
"yoga_name_nabhasa_vajra" = "ವಜ್ರ ಯೋಗ";
"yoga_outcome_nabhasa_vajra" = "ವಜ್ರದಂತಹ ತೇಜಸ್ಸು; ಸುಂದರ, ಯೌವನ ಮತ್ತು ವೃದ್ಧಾಪ್ಯದಲ್ಲಿ ಸಂತೋಷ, ಸಮರ ಶೌರ್ಯ.";
"yoga_formation_nabhasa_vajra" = "1ನೇ/7ನೇ ಸ್ಥಾನದಲ್ಲಿ ಬೆನಿಫಿಕ್ಸ್, 4ನೇ/10ನೇ ಸ್ಥಾನದಲ್ಲಿ ಮಾಲ್ಫಿಕ್ಸ್.";

// [+] Vapi Yoga
"yoga_name_nabhasa_vapi" = "ವಾಪಿ ಯೋಗ";
"yoga_outcome_nabhasa_vapi" = "ಬಾವಿ ರಚನೆ; ಸಂಪತ್ತು ಶೇಖರಣೆ, ಸಂಗ್ರಹಣೆ ಪ್ರವೃತ್ತಿ, ಶಾಶ್ವತ ಅದೃಷ್ಟ.";
"yoga_formation_nabhasa_vapi" = "ಕೇಂದ್ರೇತರ ಮನೆಗಳಲ್ಲಿರುವ ಎಲ್ಲಾ ಗ್ರಹಗಳು (ಪಾನಪರ/ಅಪೋಕ್ಲಿಮಾ).";

// [+] Veena Yoga
"yoga_name_nabhasa_veena" = "ವಿನಾ ಯೋಗ";
"yoga_outcome_nabhasa_veena" = "ಲೂಟ್ ರಚನೆ; ಸಂಗೀತ, ನೃತ್ಯ ಮತ್ತು ಕಲೆಗಳ ಪ್ರೇಮಿ; ನುರಿತ ಮತ್ತು ಸಂತೋಷದ ಮನೋಭಾವ.";
"yoga_formation_nabhasa_veena" = "ಎಲ್ಲಾ ಏಳು ಗ್ರಹಗಳು ಸತತ ಏಳು ಮನೆಗಳಲ್ಲಿ.";

// [+] Vihaga Yoga
"yoga_name_nabhasa_vihaga" = "ವಿಹಾಗ ಯೋಗ";
"yoga_outcome_nabhasa_vihaga" = "ಹಕ್ಕಿಯಂತಹ ಸ್ವಾತಂತ್ರ್ಯ; ರಾಯಭಾರಿ ಸ್ವಭಾವ, ಅಲೆದಾಡುವುದು ಮತ್ತು ಸಂದೇಶವನ್ನು ಹೊತ್ತ ಪಾತ್ರಗಳು.";
"yoga_formation_nabhasa_vihaga" = "4 ಮತ್ತು 10 ನೇ ಮನೆಗಳಲ್ಲಿ ಮಾತ್ರ ಗ್ರಹಗಳು.";

// [+] Yava Yoga
"yoga_name_nabhasa_yava" = "ಯವ ಯೋಗ";
"yoga_outcome_nabhasa_yava" = "ಬಾರ್ಲಿ-ಧಾನ್ಯ ಮಾದರಿ; ದಾನ ಸ್ವಭಾವ, ಮಧ್ಯವಯಸ್ಸಿನಲ್ಲಿ ಸಂತೋಷ.";
"yoga_formation_nabhasa_yava" = "4ನೇ/10ನೇ ಸ್ಥಾನದಲ್ಲಿ ಬೆನಿಫಿಕ್ಸ್, 1ನೇ/7ನೇ ಸ್ಥಾನದಲ್ಲಿ ಮಾಲ್ಫಿಕ್ಸ್.";

// [+] Yuga Yoga
"yoga_name_nabhasa_yuga" = "ಯುಗ ಯೋಗ";
"yoga_outcome_nabhasa_yuga" = "ನೊಗ ರಚನೆ; ಧರ್ಮದ್ರೋಹಿ, ಕಳಪೆ, ಬಹಿಷ್ಕೃತ ಪ್ರವೃತ್ತಿಗಳು; ಅಸಾಂಪ್ರದಾಯಿಕ ಮಾರ್ಗ.";
"yoga_formation_nabhasa_yuga" = "ಎರಡು ಸತತ ಮನೆಗಳಲ್ಲಿ ಎಲ್ಲಾ ಗ್ರಹಗಳು.";

// [+] Yupa Yoga
"yoga_name_nabhasa_yupa" = "ಯೂಪ ಯೋಗ";
"yoga_outcome_nabhasa_yupa" = "ತ್ಯಾಗದ ಪೋಸ್ಟ್; ಉದಾರ, ಕಲಿತ, ಧಾರ್ಮಿಕ ಮತ್ತು ಕೇಂದ್ರೀಕೃತ ಸ್ವಭಾವ.";
"yoga_formation_nabhasa_yupa" = "ಲಗ್ನದಿಂದ ಆರಂಭವಾಗಿ ಸತತ ನಾಲ್ಕು ಮನೆಗಳಲ್ಲಿ ಗ್ರಹಗಳು.";

// [−] Netranasa Yoga
"yoga_name_netranasa_yoga" = "ನೇತ್ರನಾಸ ಯೋಗ";
"yoga_outcome_netranasa_yoga" = "ಕಣ್ಣಿನ ಸಮಸ್ಯೆಗಳು ಅಥವಾ ದೃಷ್ಟಿ ದುರ್ಬಲತೆಗೆ ಒಳಗಾಗುವಿಕೆ; ನಿಯಮಿತ ಕಣ್ಣಿನ ಆರೈಕೆ ಅಗತ್ಯ.";
"yoga_formation_netranasa_yoga" = "2ನೇ/12ನೇ ಅಧಿಪತಿಗಳು ದುಷ್ಕರ್ಮಿಗಳಿಂದ ಪೀಡಿತರು, ಸೂರ್ಯ/ಚಂದ್ರ ದುರ್ಬಲರು.";

// [+] Nishkapata Yoga (205)
"yoga_name_nishkapata_yoga_205" = "ನಿಷ್ಕಪಟ ಯೋಗ (205)";
"yoga_outcome_nishkapata_yoga_205" = "ಪಾರದರ್ಶಕ, ಮೋಸವಿಲ್ಲದ ಸ್ವಭಾವವನ್ನು ನೀಡುತ್ತದೆ; ಸ್ವಾಭಾವಿಕವಾಗಿ ಪ್ರಾಮಾಣಿಕ ಮತ್ತು ಸಮಗ್ರತೆಯ ಮೂಲಕ ಗೌರವವನ್ನು ಗಳಿಸುತ್ತದೆ.";
"yoga_formation_nishkapata_yoga_205" = "ಪ್ರಾಮಾಣಿಕತೆಯನ್ನು ಸೂಚಿಸುವ ಲಾಭದಾಯಕ ಗ್ರಹಗಳ ಸಂಯೋಜನೆಗಳು (ವರ್. 1).";

// [+] Nishkapata Yoga (206)
"yoga_name_nishkapata_yoga_206" = "ನಿಷ್ಕಪಟ ಯೋಗ (206)";
"yoga_outcome_nishkapata_yoga_206" = "ನೇರವಾದ ಪಾತ್ರ ಮತ್ತು ನೈತಿಕ ಶುದ್ಧತೆಯನ್ನು ನೀಡುತ್ತದೆ; ಪ್ರಾಮಾಣಿಕ ವ್ಯವಹಾರಗಳ ಮೂಲಕ ಅಭಿವೃದ್ಧಿ ಹೊಂದುತ್ತದೆ.";
"yoga_formation_nishkapata_yoga_206" = "ಪ್ರಾಮಾಣಿಕತೆಯನ್ನು ಸೂಚಿಸುವ ಲಾಭದಾಯಕ ಗ್ರಹಗಳ ಸಂಯೋಜನೆಗಳು (ವರ್. 2).";

// [−] Nishturabhashi Yoga
"yoga_name_nishturabhashi_yoga" = "ನಿಷ್ಠುರಭಾಷಿ ಯೋಗ";
"yoga_outcome_nishturabhashi_yoga" = "ಕಠಿಣ ಮಾತಿನ ಕಡೆಗೆ ಒಲವು ಸೂಚಿಸುತ್ತದೆ; ಎಚ್ಚರಿಕೆಯ ಸಂವಹನ ಸಲಹೆ.";
"yoga_formation_nishturabhashi_yoga" = "ಮಾಲೆಫಿಕ್ಸ್ ಬುಧ ಮತ್ತು 2 ನೇ ಮನೆಯ ಮೇಲೆ ಪ್ರಭಾವ ಬೀರುತ್ತದೆ.";

// [+] Obhayachari Yoga
"yoga_name_obhayachari_yoga" = "ಓಭಯಚಾರಿ ಯೋಗ";
"yoga_outcome_obhayachari_yoga" = "ವಾಕ್ಚಾತುರ್ಯ, ಸುಂದರ ನೋಟ, ರಾಯಲ್ ಬೇರಿಂಗ್ ಮತ್ತು ಜೀವನದಲ್ಲಿ ವ್ಯತ್ಯಾಸವನ್ನು ನೀಡುತ್ತದೆ.";
"yoga_formation_obhayachari_yoga" = "ಗ್ರಹಗಳು (ಚಂದ್ರ/ರಾಹು/ಕೇತು ಹೊರತುಪಡಿಸಿ) ಸೂರ್ಯನಿಂದ 2 ಮತ್ತು 12 ಎರಡರಲ್ಲೂ.";

// [+] Parakrama Yoga
"yoga_name_parakrama_yoga" = "ಪರಾಕ್ರಮ ಯೋಗ";
"yoga_outcome_parakrama_yoga" = "ಶೌರ್ಯ ಅಗತ್ಯವಿರುವ ಅನ್ವೇಷಣೆಗಳಲ್ಲಿ ಅಸಾಧಾರಣ ಧೈರ್ಯ, ದೈಹಿಕ ಶಕ್ತಿ ಮತ್ತು ಸಾಹಸ ಮನೋಭಾವವನ್ನು ನೀಡುತ್ತದೆ.";
"yoga_formation_parakrama_yoga" = "ಲಾಭದಾಯಕ ನವಾಂಶದಲ್ಲಿ 3 ನೇ ಅಧಿಪತಿ ಲಾಭದಾಯಕ ಪ್ರಭಾವಗಳೊಂದಿಗೆ; ಅನುಕೂಲಕರ ಘನತೆಯಲ್ಲಿ ಮಂಗಳ.";

// [−] Parannabhojana Yoga
"yoga_name_parannabhojana_yoga" = "ಪರನ್ನಭೋಜನ ಯೋಗ";
"yoga_outcome_parannabhojana_yoga" = "ಆಹಾರಕ್ಕಾಗಿ ಇತರರ ಮೇಲೆ ಅವಲಂಬಿತವಾಗಿದೆ; ಹಣಕಾಸಿನ ನಿರ್ಬಂಧಗಳು ದಾನ ಅಥವಾ ಪ್ರೋತ್ಸಾಹದ ಮೇಲೆ ಅವಲಂಬನೆಯನ್ನು ಒತ್ತಾಯಿಸುತ್ತವೆ.";
"yoga_formation_parannabhojana_yoga" = "2ನೇ ಅಧಿಪತಿ ದುರ್ಬಲ, 6ನೇ ಅಧಿಪತಿ ಆಹಾರ ಮನೆಗಳ ಮೇಲೆ ಪ್ರಭಾವ ಬೀರುತ್ತಾನೆ.";

// [+] Parihasaka Yoga
"yoga_name_parihasaka_yoga" = "ಪರಿಹಾಸಕ ಯೋಗ";
"yoga_outcome_parihasaka_yoga" = "ಸಹಜ ಬುದ್ಧಿ, ಹಾಸ್ಯ ಮತ್ತು ಮನರಂಜನೆಯ ವ್ಯಕ್ತಿತ್ವ; ಸಾಮಾಜಿಕ ಸಭೆಗಳಲ್ಲಿ ಸಂತೋಷವನ್ನು ತರುತ್ತದೆ.";
"yoga_formation_parihasaka_yoga" = "ನಿರ್ದಿಷ್ಟ ಮನೆಗಳಲ್ಲಿನ ಪ್ರಯೋಜನಗಳು ಹಾಸ್ಯಮಯ ಮನೋಭಾವವನ್ನು ಸೃಷ್ಟಿಸುತ್ತವೆ.";

// [+] Parijatha Yoga
"yoga_name_parijatha_yoga" = "ಪಾರಿಜಾತ ಯೋಗ";
"yoga_outcome_parijatha_yoga" = "ಅರ್ಹತೆ ಮತ್ತು ಪರಿಶ್ರಮದ ಮೂಲಕ ಅಧಿಕಾರಕ್ಕೆ ಕ್ರಮೇಣ ಆದರೆ ತಡೆಯಲಾಗದ ಏರಿಕೆ.";
"yoga_formation_parijatha_yoga" = "ಲಗ್ನ ಅಧಿಪತಿಯ ವಿಲೇವಾರಿ ಸರಪಳಿಯು ಕೇಂದ್ರ/ತ್ರಿಕೋಣದಲ್ಲಿ ಸ್ವಂತ/ಉನ್ನತ ಗ್ರಹಕ್ಕೆ ಕಾರಣವಾಗುತ್ತದೆ.";

// [+] Parvata Yoga
"yoga_name_parvata_yoga" = "ಪರ್ವತ ಯೋಗ";
"yoga_outcome_parvata_yoga" = "ಪರ್ವತದಂತಹ ವೃತ್ತಿ ಸ್ಥಿರತೆ, ಸಂಪತ್ತು, ಖ್ಯಾತಿ ಮತ್ತು ಔದಾರ್ಯ.";
"yoga_formation_parvata_yoga" = "ಕೇಂದ್ರಗಳಲ್ಲಿ ಪ್ರಯೋಜನಗಳು; 6ನೇ ಮತ್ತು 8ನೇ ಮನೆಗಳು ಖಾಲಿ/ಬಾಧೆಯಿಲ್ಲ.";

// [−] Peenasaroga Yoga
"yoga_name_peenasaroga_yoga" = "ಪಿನಾಸರೋಗ ಯೋಗ";
"yoga_outcome_peenasaroga_yoga" = "ದೀರ್ಘಕಾಲದ ಸೈನುಟಿಸ್, ಮೂಗಿನ ಅಸ್ವಸ್ಥತೆಗಳು ಅಥವಾ ಉಸಿರಾಟದ ಅಲರ್ಜಿಗಳು.";
"yoga_formation_peenasaroga_yoga" = "ಚಂದ್ರ ಮತ್ತು 4 ನೇ ಅಧಿಪತಿ ಶನಿ ಮತ್ತು ರಾಹುಗಳಿಂದ ಪೀಡಿತ.";

// [−] Pisacha Grastha Yoga
"yoga_name_pisacha_grastha_yoga" = "ಪಿಶಾಚ ಗ್ರಸ್ಥ ಯೋಗ";
"yoga_outcome_pisacha_grastha_yoga" = "ಮಾನಸಿಕ ಅಡಚಣೆಗಳು ಅಥವಾ ಅಭಾಗಲಬ್ಧ ಭಯ; ಮಾನಸಿಕ ಸ್ವಾಸ್ಥ್ಯ ಅಭ್ಯಾಸಗಳು ಪರಿಹಾರ ನೀಡುತ್ತವೆ.";
"yoga_formation_pisacha_grastha_yoga" = "ರಾಹು/ಕೇತು ಸಂಯೋಗ ಚಂದ್ರ ಅಥವಾ ಲಗ್ನಾಧಿಪತಿ ಯಾವುದೇ ಲಾಭದಾಯಕ ಪರಿಹಾರವಿಲ್ಲ.";

// [−] Pitrusapa Sutakshaya Yoga
"yoga_name_pitrusapa_sutakshaya_yoga" = "ಪಿತೃಸಪ ಸುತಕ್ಷಯ ಯೋಗ";
"yoga_outcome_pitrusapa_sutakshaya_yoga" = "ಸಂತತಿಯನ್ನು ಬಾಧಿಸುವ ತಂದೆಯ ಶಾಪ; ಪರಿಹರಿಸಲಾಗದ ಪಿತೃ ಕರ್ಮ ಮಕ್ಕಳ ಮೇಲೆ ಪರಿಣಾಮ ಬೀರುತ್ತದೆ.";
"yoga_formation_pitrusapa_sutakshaya_yoga" = "ಸೂರ್ಯನು 5 ನೇ ಅಧಿಪತಿಯೊಂದಿಗೆ ದೋಷಪೂರಿತ ಸಂಯೋಜನೆಯಲ್ಲಿ ಪೀಡಿತ.";

// [−] Pittaroga Yoga
"yoga_name_pittaroga_yoga" = "ಪಿತ್ತರೋಗ ಯೋಗ";
"yoga_outcome_pittaroga_yoga" = "ಪಿಟ್ಟಾ-ಸಂಬಂಧಿತ ಕಾಯಿಲೆಗಳಿಗೆ (ಉರಿಯೂತ, ಆಮ್ಲೀಯತೆ, ಯಕೃತ್ತಿನ ಸಮಸ್ಯೆಗಳು) ಒಳಗಾಗುವಿಕೆ.";
"yoga_formation_pittaroga_yoga" = "ಅಗ್ನಿ-ಅಂಶ ಅಸಮತೋಲನದಿಂದ ಲಗ್ನ/6ನೇ ಬಾಧಿಸುವ ಸೂರ್ಯ ಮತ್ತು ಮಂಗಳ.";

// [−] Pretasapa Yoga
"yoga_name_pretasapa_yoga" = "ಪ್ರೇತಸಾಪ ಯೋಗ";
"yoga_outcome_pretasapa_yoga" = "ಕುಟುಂಬದ ಮೇಲೆ ಪರಿಣಾಮ ಬೀರುವ ಪೂರ್ವಜರ ಆತ್ಮ ಸಂಕಟ; ಆಧ್ಯಾತ್ಮಿಕ ಶುದ್ಧೀಕರಣವನ್ನು ಶಿಫಾರಸು ಮಾಡಲಾಗಿದೆ.";
"yoga_formation_pretasapa_yoga" = "ಶನಿ ಮತ್ತು ರಾಹು ಯಾವುದೇ ಪ್ರಯೋಜನಕಾರಿ ಅಂಶಗಳಿಲ್ಲದೆ 5 ನೇ ಸ್ಥಾನದಲ್ಲಿರುತ್ತಾರೆ.";

// [+] Pushkala Yoga
"yoga_name_pushkala_yoga" = "ಪುಷ್ಕಲ ಯೋಗ";
"yoga_outcome_pushkala_yoga" = "ಹೇರಳವಾದ ಸಮೃದ್ಧಿ, ಸಿಹಿ ಮಾತು, ಖ್ಯಾತಿ ಮತ್ತು ರಾಜ ಗೌರವವನ್ನು ನೀಡುತ್ತದೆ.";
"yoga_formation_pushkala_yoga" = "ಲಗ್ನ ಅಧಿಪತಿ ಚಂದ್ರನ ಸಂಯೋಗ, ಬಲವಾದ ಲಗ್ನಾ ವಿಲೇವಾರಿದಾರರಿಂದ ದೃಷ್ಟಿ.";

// [+] Putra Sukha Yoga
