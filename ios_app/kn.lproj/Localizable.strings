// [+] Bandhu Pujya Yoga (194)
"yoga_name_bandhu_pujya_yoga_194" = "ಬಂಧು ಪೂಜ್ಯ ಯೋಗ (194)";
"yoga_outcome_bandhu_pujya_yoga_194" = "ಕುಟುಂಬ ಬಂಧಗಳನ್ನು ಬಲಪಡಿಸುತ್ತದೆ ಮತ್ತು ರಕ್ತಸಂಬಂಧ ಮತ್ತು ವಿಶ್ವಾಸಾರ್ಹ ಸಲಹೆಯ ಮೂಲಕ ಗೌರವವನ್ನು ತರುತ್ತದೆ.";
"yoga_formation_bandhu_pujya_yoga_194" = "ಗುರುಗ್ರಹವು ಅಂಶ ಅಥವಾ ಉದ್ಯೋಗದ ಮೂಲಕ 4 ನೇ ಮನೆಗೆ ಸಂಪರ್ಕ ಹೊಂದಿದೆ.";

// [−] Bandhubhisthyaktha Yoga
"yoga_name_bandhubhisthyaktha_yoga" = "ಬಂಧುಭಿಷ್ಟ್ಯಕ್ತ ಯೋಗ";
"yoga_outcome_bandhubhisthyaktha_yoga" = "ಸಂಬಂಧಿಕರು ಮತ್ತು ಸಂಭಾವ್ಯ ಕುಟುಂಬ ಘರ್ಷಣೆಗಳು ಅಥವಾ ಪ್ರತ್ಯೇಕತೆಯಿಂದ ದೂರವಾಗುವುದನ್ನು ಸೂಚಿಸುತ್ತದೆ.";
