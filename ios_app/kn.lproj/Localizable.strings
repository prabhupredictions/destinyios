// [+] Bhadra Yoga
"yoga_name_bhadra_yoga" = "ಭದ್ರ ಯೋಗ";
"yoga_outcome_bhadra_yoga" = "ತೀಕ್ಷ್ಣವಾದ ಬುದ್ಧಿಶಕ್ತಿ, ನಿರರ್ಗಳ ಮಾತು, ವ್ಯವಹಾರ ಕುಶಾಗ್ರಮತಿ ಮತ್ತು ವಿಶ್ಲೇಷಣಾತ್ಮಕ ವೃತ್ತಿಗಳಲ್ಲಿ ಶ್ರೇಷ್ಠತೆಯನ್ನು ನೀಡುತ್ತದೆ.";
